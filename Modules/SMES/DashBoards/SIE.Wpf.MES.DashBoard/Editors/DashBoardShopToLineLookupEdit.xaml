<UserControl
    x:Class="SIE.Wpf.MES.DashBoard.Editors.DashBoardShopToLineLookupEdit"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
    d:DesignHeight="52"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ControlTemplate x:Key="shopContentTemplate">
                <dxg:GridControl x:Name="PART_GridControl" AutoExpandAllGroups="True">
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn
                            FieldName="Code"
                            Header="{Binding [编码], Source={uic:L10N}}"
                            HeaderToolTip="{Binding [车间编码], Source={uic:L10N}}" />
                        <dxg:GridColumn
                            FieldName="Name"
                            Header="{Binding [名称], Source={uic:L10N}}"
                            HeaderToolTip="{Binding [车间名], Source={uic:L10N}}" />
                    </dxg:GridControl.Columns>
                    <dxg:GridControl.View>
                        <dxg:TableView
                            Name="View"
                            AllowPerPixelScrolling="True"
                            AutoWidth="True"
                            IsSynchronizedWithCurrentItem="False"
                            ScrollAnimationDuration="0"
                            ShowAutoFilterRow="True"
                            ShowGroupedColumns="True"
                            ShowTotalSummary="True" />
                    </dxg:GridControl.View>
                </dxg:GridControl>
            </ControlTemplate>
            <ControlTemplate x:Key="lineContentTemplate">
                <dxg:GridControl x:Name="PART_GridControl" AutoExpandAllGroups="True">
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn
                            FieldName="Code"
                            Header="{Binding [编码], Source={uic:L10N}}"
                            HeaderToolTip="{Binding [产线编码], Source={uic:L10N}}" />
                        <dxg:GridColumn
                            FieldName="Name"
                            Header="{Binding [名称], Source={uic:L10N}}"
                            HeaderToolTip="{Binding [产线名称], Source={uic:L10N}}" />
                    </dxg:GridControl.Columns>
                    <dxg:GridControl.View>
                        <dxg:TableView
                            Name="View"
                            AllowPerPixelScrolling="True"
                            AutoWidth="True"
                            IsSynchronizedWithCurrentItem="False"
                            ScrollAnimationDuration="0"
                            ShowAutoFilterRow="True"
                            ShowGroupedColumns="True"
                            ShowTotalSummary="True" />
                    </dxg:GridControl.View>
                </dxg:GridControl>
            </ControlTemplate>

        </ResourceDictionary>
    </UserControl.Resources>
    <Grid x:Name="displayGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="26" />
            <RowDefinition Height="26" />
        </Grid.RowDefinitions>
        <dxg:LookUpEdit
            x:Name="shopLookupEdit"
            Grid.Row="0"
            AllowNullInput="True"
            AutoPopulateColumns="False"
            DisplayMember="Name"
            EditValue="{Binding Shop}"
            NullText="{Binding [车间], Source={uic:L10N}}"
            PopupContentTemplate="{StaticResource shopContentTemplate}"
            PopupMaxWidth="500"
            PopupWidth="400"
            ValueMember="Id" />
        <dxg:LookUpEdit
            x:Name="lineLookupEdit"
            Grid.Row="1"
            AllowNullInput="True"
            AutoPopulateColumns="False"
            DisplayMember="Name"
            EditValue="{Binding Line}"
            NullText="{Binding [产线], Source={uic:L10N}}"
            PopupContentTemplate="{StaticResource lineContentTemplate}"
            PopupMaxWidth="500"
            PopupWidth="400"
            ValueMember="Id" />
    </Grid>
</UserControl>
