<UserControl
    x:Class="SIE.Wpf.MES.DashBoard.Editors.DashBoardTimeIntervalEdit"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dxe1="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="26"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <Grid x:Name="contaolGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>
        <dxe1:ComboBoxEdit
            x:Name="timePart"
            Grid.Column="0"
            DisplayMember="TranslatedLabel"
            EditValue="{Binding TimePart}"
            ValueMember="EnumValue" />
        <dxe1:TextEdit
            x:Name="timeValue"
            Grid.Column="1"
            Text="{Binding TimeValue, Mode=TwoWay}" />
    </Grid>
</UserControl>
