<UserControl x:Class="SIE.Wpf.MES.DashBoard.Reports.Commons.ProceessDirectRateStatistics"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.DashBoard.Reports.Commons"
             xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxl="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core" 
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <dxc:ChartControl x:Name="fpyStatisticsChart">
            <dxc:ChartControl.Titles>
                <dxc:Title x:Name="fpyChartTitle" FontSize="18" Content="{Binding [直通率统计图], Source={uic:L10N}}" HorizontalAlignment="Center" />
            </dxc:ChartControl.Titles>
            <dxc:ChartControl.CrosshairOptions>
                <dxc:CrosshairOptions ShowArgumentLine="True" CrosshairLabelMode="ShowForNearestSeries" />
            </dxc:ChartControl.CrosshairOptions>

            <dxc:ChartControl.Diagram>
                <dxc:XYDiagram2D Name="fpyStatisticsChartGram" Rotated="True" SeriesDataMember="Series" EnableAxisXNavigation="True" >
                    <dxc:XYDiagram2D.AxisX>
                        <dxc:AxisX2D x:Name="fpyAxisX" TickmarksMinorVisible="False"
                                                 GridLinesMinorVisible="False" GridLinesVisible="False">
                            <dxc:AxisX2D.CrosshairAxisLabelOptions>
                                <dxc:CrosshairAxisLabelOptions/>
                            </dxc:AxisX2D.CrosshairAxisLabelOptions>
                            <dxc:AxisX2D.QualitativeScaleOptions>
                                <dxc:QualitativeScaleOptions AutoGrid="True" GridSpacing="1"/>
                            </dxc:AxisX2D.QualitativeScaleOptions>
                            <dxc:AxisX2D.Label>
                                <dxc:AxisLabel Background="Transparent" BorderBrush="#FF343246" Padding="0,1" FontSize="12"/>
                            </dxc:AxisX2D.Label>
                        </dxc:AxisX2D>
                    </dxc:XYDiagram2D.AxisX>

                    <dxc:XYDiagram2D.AxisY>
                        <dxc:AxisY2D x:Name="fpyAxisY"  GridLinesMinorVisible="False" GridLinesVisible="False"
                                     TickmarksMinorVisible="True" Interlaced="False">
                            <dxc:AxisY2D.VisualRange>
                                <dxc:Range MinValue="0.0" MaxValue="1.0" />
                            </dxc:AxisY2D.VisualRange>
                            <dxc:AxisY2D.Label>
                                <dxc:AxisLabel Background="Transparent" BorderBrush="#FF343246" Padding="0,1"  FontSize="12" TextPattern="{}{V:P0}"/>
                            </dxc:AxisY2D.Label>
                        </dxc:AxisY2D>
                    </dxc:XYDiagram2D.AxisY>

                    <dxc:XYDiagram2D.Series>
                        <dxc:BarSideBySideSeries2D x:Name="rateSerie" CrosshairLabelPattern="{}{A}: {V:P2}" ArgumentScaleType="Qualitative" BarWidth="0.3" LabelsVisibility="True">
                            <dxc:BarSideBySideSeries2D.Model>
                                <dxc:BorderlessSimpleBar2DModel/>
                            </dxc:BarSideBySideSeries2D.Model>
                            <dxc:BarSideBySideSeries2D.Label>
                                <dxc:SeriesLabel ConnectorVisible="False" Indent="0" Background="{x:Null}" dxc:BarSideBySideSeries2D.LabelPosition="Outside" TextPattern="{}{V:P2}">
                                    <dxc:SeriesLabel.ElementTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Text}" Background="Transparent" BorderThickness="0"/>
                                        </DataTemplate>
                                    </dxc:SeriesLabel.ElementTemplate>
                                </dxc:SeriesLabel>
                            </dxc:BarSideBySideSeries2D.Label>
                        </dxc:BarSideBySideSeries2D>
                    </dxc:XYDiagram2D.Series>
                </dxc:XYDiagram2D>
            </dxc:ChartControl.Diagram>
        </dxc:ChartControl>

        <dxl:DockLayoutControl x:Name="defectCodeLayout" Grid.Column="1" Margin="5,0,0,5" >
            <Label HorizontalAlignment="Center" Height="auto" dxl:DockLayoutControl.Dock="Top" FontSize="18" Content="{Binding [缺陷代码TOP5], Source={uic:L10N}}" Margin="0,15,0,5" Background="Transparent"></Label>
            <Border dxl:DockLayoutControl.Dock="Client" BorderThickness="1" Background="Transparent">
                <Canvas x:Name="defectRecChart" Background="Transparent" Margin="0,0,0,0">
                </Canvas>
            </Border>
        </dxl:DockLayoutControl>

        <dxc:ChartControl x:Name="passQtyStatisticsChart"  Grid.Row="1" Grid.ColumnSpan="2">
            <dxc:ChartControl.Titles>
                <dxc:Title x:Name="qtyChartTitle" FontSize="18" Content="{Binding [工序一次良品/不良品统计], Source={uic:L10N}}" HorizontalAlignment="Center" />
            </dxc:ChartControl.Titles>
            <dxc:ChartControl.CrosshairOptions>
                <dxc:CrosshairOptions ShowArgumentLine="True" CrosshairLabelMode="ShowForNearestSeries" />
            </dxc:ChartControl.CrosshairOptions>

            <dxc:ChartControl.Diagram>
                <dxc:XYDiagram2D Name="qtyStatisticsCharttGram" SeriesDataMember="Series" EnableAxisXNavigation="True" BarDistance="20">
                    <dxc:XYDiagram2D.AxisX>
                        <dxc:AxisX2D x:Name="qtyAxisX" TickmarksMinorVisible="False" TickmarksLength="3"  
                                                 GridLinesMinorVisible="False" GridLinesVisible="False">
                            <dxc:AxisX2D.CrosshairAxisLabelOptions>
                                <dxc:CrosshairAxisLabelOptions />
                            </dxc:AxisX2D.CrosshairAxisLabelOptions>
                            <dxc:AxisX2D.QualitativeScaleOptions>
                                <dxc:QualitativeScaleOptions AutoGrid="True" GridSpacing="1"/>
                            </dxc:AxisX2D.QualitativeScaleOptions>
                            <dxc:AxisX2D.Label>
                                <dxc:AxisLabel Background="Transparent" BorderBrush="#FF343246" Padding="0,1" FontSize="12"/>
                            </dxc:AxisX2D.Label>
                        </dxc:AxisX2D>
                    </dxc:XYDiagram2D.AxisX>

                    <dxc:XYDiagram2D.AxisY>
                        <dxc:AxisY2D x:Name="qtyAxisY" Thickness="0" GridLinesMinorVisible="False" GridLinesVisible="False"
                                     TickmarksMinorVisible="True" TickmarksLength="3" Interlaced="False" Title="{Binding [数量], Source={uic:L10N}}">
                            <dxc:AxisY2D.Label>
                                <dxc:AxisLabel Background="Transparent" BorderBrush="#FF343246" Padding="0,1"  FontSize="12"/>
                            </dxc:AxisY2D.Label>
                        </dxc:AxisY2D>
                    </dxc:XYDiagram2D.AxisY>
                    <dxc:XYDiagram2D.Series>
                        <dxc:BarStackedSeries2D CrosshairLabelPattern="{}{A} {S}: {V}"  x:Name="passQtySerie" DisplayName="{Binding [一次良品], Source={uic:L10N}}" 
                                                ShowInLegend="True" ArgumentScaleType="Qualitative" Brush="YellowGreen" BarWidth="0.3" LabelsVisibility="True">
                            <dxc:BarStackedSeries2D.Model>
                                <dxc:SimpleBar2DModel/>
                            </dxc:BarStackedSeries2D.Model>
                            <dxc:BarStackedSeries2D.Label>
                                <dxc:SeriesLabel dxc:BarSideBySideSeries2D.LabelPosition="Center">
                                    <dxc:SeriesLabel.ElementTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Text}" Background="Transparent" BorderThickness="0"/>
                                        </DataTemplate>
                                    </dxc:SeriesLabel.ElementTemplate>
                                </dxc:SeriesLabel>
                            </dxc:BarStackedSeries2D.Label>
                        </dxc:BarStackedSeries2D>

                        <dxc:BarStackedSeries2D CrosshairLabelPattern="{}{A} {S}: {V}" x:Name="failedQtySerie" DisplayName="{Binding [一次不良品], Source={uic:L10N}}" 
                                                ShowInLegend="True" ArgumentScaleType="Qualitative" Brush="Red" BarWidth="0.3" LabelsVisibility="True">
                            <dxc:BarStackedSeries2D.Model>
                                <dxc:SimpleBar2DModel/>
                            </dxc:BarStackedSeries2D.Model>
                            <dxc:BarStackedSeries2D.Label>
                                <dxc:SeriesLabel dxc:BarSideBySideSeries2D.LabelPosition="Center" >
                                    <dxc:SeriesLabel.ElementTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Text}" Background="Transparent" BorderThickness="0"/>
                                        </DataTemplate>
                                    </dxc:SeriesLabel.ElementTemplate>
                                </dxc:SeriesLabel>
                            </dxc:BarStackedSeries2D.Label>
                        </dxc:BarStackedSeries2D>
                    </dxc:XYDiagram2D.Series>
                </dxc:XYDiagram2D>
            </dxc:ChartControl.Diagram>

            <dxc:ChartControl.Legend>
                <dxc:Legend HorizontalPosition="Right" VerticalPosition="Top" Orientation="Horizontal" ReverseItems="True" Background="{x:Null}"
                                                    FontSize="12" Margin="-150, -45, 0, 0" Padding="0" BorderThickness="0">
                </dxc:Legend>
            </dxc:ChartControl.Legend>
        </dxc:ChartControl>
    </Grid>
</UserControl>
