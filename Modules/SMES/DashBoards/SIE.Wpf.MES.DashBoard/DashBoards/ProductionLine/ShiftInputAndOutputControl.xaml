<sd:ComponentItem x:Class="SIE.Wpf.MES.DashBoard.DashBoards.ProductionLine.ShiftInputAndOutputControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.DashBoard.DashBoards.ProductionLine" 
             xmlns:converter="clr-namespace:SIE.Wpf.MES.DashBoard.DashBoards.Converters"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
             sd:DiagramDesigner.ToolBarTitle="{Binding [班次日统计], Source={uic:L10N}}"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="750" DataContext="{Binding RelativeSource={RelativeSource Self}}">
    <!--<sd:ComponentItem.ToolbarItem>
        <TextBlock TextWrapping="WrapWithOverflow" Text="{Binding [班次日统计], Source={uic:L10N}}"></TextBlock>
    </sd:ComponentItem.ToolbarItem>-->
    <sd:ComponentItem.Resources>
        <ResourceDictionary>
            <Style x:Key="CellCenterStyle" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <local:BoolToColorConverter x:Key="boolToColorConverter"/>
            <converter:StingToColorConverter x:Key="stingToColorConverter"/>
        </ResourceDictionary>
    </sd:ComponentItem.Resources>
    <Grid Background="#333434">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#666666" Name="title" >
            <TextBlock Text="{Binding [班次日统计], Source={uic:L10N}}" FontSize="20"  Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0"/>
        </Border>

        <Border Grid.Row="1" Background="#333434" Name="body" BorderBrush="#666666">
            <DataGrid  DataContext="{Binding}" Background="#333434" x:Name="displayGrid" GridLinesVisibility="All" 
              HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" SelectionUnit="Cell"  
               ItemsSource="{Binding Path=ShiftInputAndOutputs}" AutoGenerateColumns="False"  ColumnWidth="*" 
               BorderBrush="White" IsReadOnly="True" RowHeaderWidth="0"  CanUserAddRows="False" CanUserDeleteRows="False">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="#333434"/>
                        <Setter Property="Foreground" Value="#FFFFFF"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="BorderBrush" Value="#666666"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Focusable" Value="False"/>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderBrush" Value="#666666"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Padding" Value="0,0,0,0"/>
                        <Setter Property="Margin" Value="0,0,0,0"/>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="BorderBrush" Value="#666666"/>
                        <Setter Property="FontSize" Value="16"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="#333434"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="{Binding [时段],Source={uic:L10N}}" Width="150" MaxWidth="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <!--设置当单元格内容超过最大长度时，显示...-->
                                <TextBlock Text="{Binding TimeBetween}" HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="WordEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellStyle>
                            <Style>
                                <!--加tooltip，显示单元格内容-->
                                <Setter Property="ToolTipService.ToolTip" Value="{Binding TimeBetween}"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="{Binding [目标产能],Source={uic:L10N}}" Width="120" MaxWidth="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding PlanQty}" HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="WordEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellStyle>
                            <Style>
                                <Setter Property="ToolTipService.ToolTip" Value="{Binding PlanQty}"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="{Binding [投入], Source={uic:L10N}}" Width="120" MaxWidth="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding OnlineQty}" HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="WordEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellStyle>
                            <Style>
                                <Setter Property="ToolTipService.ToolTip" Value="{Binding OnlineQty}"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="{Binding [产出], Source={uic:L10N}}" Width="120" MaxWidth="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Path=OfflineQty}" HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="WordEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellStyle>
                            <Style>
                                <Setter Property="ToolTipService.ToolTip" Value="{Binding Path=OfflineQty}" />
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="{Binding [达成率], Source={uic:L10N}}" Width="80" MaxWidth="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Background="{Binding Path=CRateBackgroundStr,Converter={StaticResource ResourceKey=stingToColorConverter}}">
                                    <TextBlock Text="{Binding CompletionRate, StringFormat={}{0:P2}}" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="WordEllipsis"
                                           Background="{Binding Path=CRateBackgroundStr,Converter={StaticResource ResourceKey=stingToColorConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellStyle>
                            <Style>
                                <Setter Property="ToolTipService.ToolTip" Value="{Binding CompletionRate, StringFormat={}{0:P2}}"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="{Binding [直通率], Source={uic:L10N}}" Width="100" MaxWidth="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Background="{Binding Path=RolledYieldBackgroundStr,Converter={StaticResource ResourceKey=stingToColorConverter}}">
                                    <TextBlock Text="{Binding Path=RolledYield, StringFormat={}{0:P2}}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="WordEllipsis"
                                        Background="{Binding Path=RolledYieldBackgroundStr,Converter={StaticResource ResourceKey=stingToColorConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellStyle>
                            <Style>
                                <Setter Property="ToolTipService.ToolTip" Value="{Binding Path=RolledYield, StringFormat={}{0:P2}}"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
</sd:ComponentItem>
