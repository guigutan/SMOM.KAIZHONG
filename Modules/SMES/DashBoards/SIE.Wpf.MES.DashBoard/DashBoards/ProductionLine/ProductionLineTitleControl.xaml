<sd:ComponentItem x:Class="SIE.Wpf.MES.DashBoard.DashBoards.ProductionLine.ProductionLineTitleControl"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
                  xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
                  sd:DiagramDesigner.ToolBarTitle="{Binding [产线看板-标题], Source={uic:L10N}}" 
                  sd:DiagramDesigner.DefaultSize="1366,100"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="1366"> 
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/> 
        </Grid.ColumnDefinitions> 
        <Grid Grid.Column="0" Background="#3a3a3a">
            <Border HorizontalAlignment="Left" VerticalAlignment="Center" Padding="2">
                <Image Name="leftTitleImage" HorizontalAlignment="Stretch" VerticalAlignment="Center" Stretch="UniformToFill" ></Image>
            </Border>
        </Grid>
        <Grid Grid.Column="1" Background="#3a3a3a">
            <TextBlock Name="boardTitle" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
        </Grid>
        <Grid Grid.Column="2" Background="#3a3a3a">
            <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,10,30,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding [当前时间：], Source={uic:L10N}}" FontSize="{Binding ElementName=dateTime,Path=FontSize}" Foreground="{Binding ElementName=dateTime, Path=Foreground}"/>
                    <TextBlock Name="dateTime" FontSize="18" Foreground="#CCCCCC" Text="2000/01/01 00:00:00"  Padding="0" HorizontalAlignment="Right"  VerticalAlignment="Bottom"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</sd:ComponentItem>
