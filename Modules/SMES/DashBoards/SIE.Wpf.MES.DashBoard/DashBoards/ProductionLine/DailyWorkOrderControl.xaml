<sd:ComponentItem x:Class="SIE.Wpf.MES.DashBoard.DashBoards.ProductionLine.DailyWorkOrderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.DashBoard.DashBoards.ProductionLine"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core" 
             sd:DiagramDesigner.ToolBarTitle="{Binding [当日工单], Source={uic:L10N}}"
             mc:Ignorable="d"  Name="curWorkOrderControl"
             d:DesignHeight="300" d:DesignWidth="750" DataContext="{Binding RelativeSource={RelativeSource Self}}">
    <!--<sd:ComponentItem.ToolbarItem>
        <TextBlock TextWrapping="WrapWithOverflow" Text="{Binding [当日工单], Source={uic:L10N}}"></TextBlock>
    </sd:ComponentItem.ToolbarItem>-->
    <sd:ComponentItem.Resources>
        <ResourceDictionary>
            <Style x:Key="CellCenterStyle" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <local:BoolToColorConverter x:Key="boolToColorConverter"/>
        </ResourceDictionary>
    </sd:ComponentItem.Resources>
    <Grid Background="#333434">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#666666" Name="title" >
            <TextBlock Text="{Binding [当日计划工单], Source={uic:L10N}}" FontSize="20"  Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0"/>
        </Border>

        <Border Grid.Row="1" Background="#333434" Name="body" BorderBrush="#666666">
            <DataGrid  DataContext="{Binding}" Background="#333434" x:Name="displayGrid" GridLinesVisibility="All" 
              HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" SelectionUnit="Cell"  
               ItemsSource="{Binding Path=WorkOrderInfos}" AutoGenerateColumns="False"  ColumnWidth="*" 
               BorderBrush="White" IsReadOnly="True" RowHeaderWidth="0"  CanUserAddRows="False" CanUserDeleteRows="False">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="{Binding Path=IsProducing,Converter={StaticResource ResourceKey=boolToColorConverter}}"/>
                        <Setter Property="Foreground" Value="#FFFFFF"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="BorderBrush" Value="#666666"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Focusable" Value="False"/>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderBrush" Value="#666666"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Padding" Value="0,0,0,0"/>
                        <Setter Property="Margin" Value="0,0,0,0"/>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="BorderBrush" Value="#666666"/>
                        <Setter Property="FontSize" Value="16"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="#333434"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="{Binding [工单], Source={uic:L10N}}" Width="150" MaxWidth="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <!--设置当单元格内容超过最大长度时，显示...-->
                                <TextBlock Text="{Binding No}" HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="WordEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellStyle>
                            <Style>
                                <!--加tooltip，显示单元格内容-->
                                <Setter Property="ToolTipService.ToolTip" Value="{Binding No}"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="{Binding [类型], Source={uic:L10N}}" Width="50" MaxWidth="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding WorkOrderType}" HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="WordEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellStyle>
                            <Style>
                                <Setter Property="ToolTipService.ToolTip" Value="{Binding WorkOrderType}"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="{Binding [产品编码], Source={uic:L10N}}" Width="120" MaxWidth="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ProductCode}" HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="WordEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellStyle>
                            <Style>
                                <Setter Property="ToolTipService.ToolTip" Value="{Binding ProductCode}"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="{Binding [计划完成时间], Source={uic:L10N}}" Width="120" MaxWidth="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Path=PlanEndDate, StringFormat='yyyy-MM-dd'}" HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="WordEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellStyle>
                            <Style>
                                <Setter Property="ToolTipService.ToolTip" Value="{Binding Path=PlanEndDate, StringFormat='yyyy-MM-dd'}" />
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="{Binding [计划数], Source={uic:L10N}}" Width="80" MaxWidth="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding PlanQty}" HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="WordEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellStyle>
                            <Style>
                                <Setter Property="ToolTipService.ToolTip" Value="{Binding PlanQty}"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="{Binding [累计完成数], Source={uic:L10N}}" Width="100" MaxWidth="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FinishQty}" HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="WordEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellStyle>
                            <Style>
                                <Setter Property="ToolTipService.ToolTip" Value="{Binding FinishQty}"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Width="*" Binding="{Binding Path=CompletionRate, StringFormat={}{0:P2}}" Header="{Binding [完成率], Source={uic:L10N}}" ElementStyle="{StaticResource CellCenterStyle}"></DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        
    </Grid>
</sd:ComponentItem>
