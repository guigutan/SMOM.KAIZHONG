<UserControl x:Class="SIE.Wpf.MES.DashBoard.DashBoards.Editors.DataRangeEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.DashBoard.DashBoards.Editors"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
             mc:Ignorable="d" 
             d:DesignHeight="26" d:DesignWidth="300" Name="dataRangeView">
    <Grid>
        <StackPanel Name="sp" Orientation="Horizontal">
            <TextBox Width="60" Text="{Binding Path=LowerLimitValue,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Margin="3" />
            <TextBlock Text="{Binding [% 至], Source={uic:L10N}}" Margin="0,3"/>
            <TextBox Width="60" Text="{Binding Path=UpperLimitValue,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Margin="3" />
            <TextBlock Text="%" Margin="0,3"/>
        </StackPanel>  
    </Grid>
</UserControl>
