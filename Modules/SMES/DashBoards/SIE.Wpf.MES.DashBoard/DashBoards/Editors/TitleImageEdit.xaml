<UserControl x:Class="SIE.Wpf.MES.DashBoard.DashBoards.Editors.TitleImageEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.DashBoard.DashBoards.Editors"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:swe="clr-namespace:SIE.Wpf.Editors;assembly=SIE.Wpf"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <UserControl.Resources>
        <ResourceDictionary>
            <local:ImageToStringConverter x:Key="ImageEditConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>
    <dxe:ImageEdit Name="image" HorizontalAlignment="Center" Height="26" Source="{Binding Value, Mode = TwoWay, UpdateSourceTrigger = PropertyChanged, Converter = {StaticResource ImageEditConverter}}" />
</UserControl>
