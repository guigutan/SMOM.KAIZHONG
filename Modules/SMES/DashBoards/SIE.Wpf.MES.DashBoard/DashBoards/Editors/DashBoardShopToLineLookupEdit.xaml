<UserControl x:Class="SIE.Wpf.MES.DashBoard.DashBoards.Editors.DashBoardShopToLineLookupEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.DashBoard.DashBoards.Editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
             mc:Ignorable="d" 
             d:DesignHeight="52" d:DesignWidth="300">
    <UserControl.Resources>
        <ResourceDictionary>
            <ControlTemplate x:Key="shopContentTemplate">
                <dxg:GridControl x:Name="PART_GridControl" AutoExpandAllGroups="True">
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="Code" Header="{Binding [编码], Source={uic:L10N}}" HeaderToolTip="{Binding [车间编码], Source={uic:L10N}}"/>
                        <dxg:GridColumn FieldName="Name" Header="{Binding [名称], Source={uic:L10N}}" HeaderToolTip="{Binding [车间名], Source={uic:L10N}}"/>
                    </dxg:GridControl.Columns>
                    <dxg:GridControl.View>
                        <dxg:TableView
                        Name="View"
                        ShowGroupedColumns="True"
                        AutoWidth="True"
                        AllowPerPixelScrolling="True"
                        ScrollAnimationDuration="0"
                        ShowAutoFilterRow="True"
                        ShowTotalSummary="True"
                        IsSynchronizedWithCurrentItem="False">
                        </dxg:TableView>
                    </dxg:GridControl.View>
                </dxg:GridControl>
            </ControlTemplate>
            <ControlTemplate x:Key="lineContentTemplate">
                <dxg:GridControl x:Name="PART_GridControl" AutoExpandAllGroups="True">
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="Code" Header="{Binding [编码], Source={uic:L10N}}" HeaderToolTip="{Binding [产线编码], Source={uic:L10N}}"/>
                        <dxg:GridColumn FieldName="Name" Header="{Binding [名称], Source={uic:L10N}}" HeaderToolTip="{Binding [产线名称], Source={uic:L10N}}"/>
                    </dxg:GridControl.Columns>
                    <dxg:GridControl.View>
                        <dxg:TableView
                        Name="View"
                        ShowGroupedColumns="True"
                        AutoWidth="True"
                        AllowPerPixelScrolling="True"
                        ScrollAnimationDuration="0"
                        ShowAutoFilterRow="True"
                        ShowTotalSummary="True"
                        IsSynchronizedWithCurrentItem="False">
                        </dxg:TableView>
                    </dxg:GridControl.View>
                </dxg:GridControl>
            </ControlTemplate>
            <local:ListToStringConverter x:Key="listToStringConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid x:Name="displayGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="26"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>
        <dxg:LookUpEdit Grid.Row="0" x:Name="shopLookupEdit" AllowNullInput="True" NullText="{Binding [车间], Source={uic:L10N}}" EditValue="{Binding Shop}" DisplayMember="Name" ValueMember="Id" PopupWidth="400" PopupMaxWidth="500" AutoPopulateColumns="False" PopupContentTemplate="{StaticResource shopContentTemplate}"/>
        <dxg:LookUpEdit Grid.Row="1" x:Name="lineLookupEdit" AllowNullInput="True" NullText="{Binding [产线], Source={uic:L10N}}" EditValue="{Binding Lines, Converter={StaticResource listToStringConverter}}" DisplayMember="Name" ValueMember="Id" PopupWidth="400" PopupMaxWidth="500" AutoPopulateColumns="False" PopupContentTemplate="{StaticResource lineContentTemplate}">
            <dxg:LookUpEdit.StyleSettings>
                <dxg:MultiSelectLookUpEditStyleSettings/>
            </dxg:LookUpEdit.StyleSettings>
        </dxg:LookUpEdit>
    </Grid>
</UserControl>
