<sd:ComponentItem x:Class="SIE.Wpf.MES.DashBoard.DashBoards.ProductionLine.WorkShopControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
             xmlns:local="clr-namespace:SIE.Wpf.MES.DashBoard.DashBoards.ProductionLine"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
             xmlns:converter="clr-namespace:SIE.Wpf.MES.DashBoard.DashBoards.Converters"
             sd:DiagramDesigner.ToolBarTitle="{Binding [车间看板], Source={uic:L10N}}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" DataContext="{Binding RelativeSource={RelativeSource Self}}">
    <!--<sd:ComponentItem.ToolbarItem>
        <TextBlock TextWrapping="WrapWithOverflow" Text="{Binding [车间看板], Source={uic:L10N}}"></TextBlock>
    </sd:ComponentItem.ToolbarItem>-->
    <sd:ComponentItem.Resources>
        <ResourceDictionary>
            <Style x:Key="CellCenterStyle" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <converter:StateColorToConvert x:Key="StateColorToConvert"/> 
        </ResourceDictionary>
    </sd:ComponentItem.Resources>
    <Grid Background="#3a3a3a">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Name="title" Margin="0,0,0,5" BorderBrush="#666666" BorderThickness="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Row="0" Grid.Column="0">
                    <Border HorizontalAlignment="Left" VerticalAlignment="Center" Padding="2">
                        <Image Name="leftTitleImage" HorizontalAlignment="Stretch" VerticalAlignment="Center" Stretch="UniformToFill" ></Image>
                    </Border>
                </Grid>
                <Grid Grid.Row="0" Grid.Column="1" >
                    <TextBlock Name="workShopTitle" Text="{Binding [车间看板], Source={uic:L10N}}" FontSize="24" Foreground="WhiteSmoke" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
                <Grid Grid.Row="0" Grid.Column="2">
                    <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"  Margin="30,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding [当前时间：], Source={uic:L10N}}"  FontSize="12" Foreground="WhiteSmoke"/>
                            <TextBlock Name="dateTime"  FontSize="12" Foreground="WhiteSmoke" Text="2018/07/04 19:02:30"  Padding="0" HorizontalAlignment="Right"  VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
        <Border Grid.Row="1" Name="workShopBody" Padding="0,0,5,5">
            <DataGrid  DataContext="{Binding}" Background="#3a3a3a" x:Name="workShopGrid" GridLinesVisibility="None"  
              HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" SelectionUnit="FullRow"  
               ItemsSource="{Binding Path=WorkShopInfo}" AutoGenerateColumns="False"  ColumnWidth="*" 
               BorderBrush="#666666" IsReadOnly="True" RowHeaderWidth="0" >
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="#3a3a3a"/>
                        <Setter Property="Foreground" Value="WhiteSmoke"/>
                        <Setter Property="FontSize" Value="16"/>
                        <Setter Property="Focusable" Value="False"/>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderBrush" Value="#666666"/>
                        <Setter Property="BorderThickness" Value="1,0,0,1"/>
                        <Setter Property="Padding" Value="0,0,0,0"/>
                        <Setter Property="Margin" Value="0,0,0,0"/>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="BorderBrush" Value="#666666"/>
                        <Setter Property="Height" Value="30"/>
                        <Setter Property="FontSize" Value="16"/>
                        <Setter Property="BorderThickness" Value="1,0,0,1"/>
                        <Setter Property="Foreground" Value="WhiteSmoke"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Background" Value="#333434"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Path=Line}"  Header="{Binding [生产线], Source={uic:L10N}}" Width="*" ElementStyle="{StaticResource CellCenterStyle}"/>
                    <DataGridTextColumn Binding="{Binding Path=PlanQty}"  Header="{Binding [计划量], Source={uic:L10N}}" Width="*" ElementStyle="{StaticResource CellCenterStyle}"/>
                    <DataGridTextColumn Binding="{Binding Path=FinishQty}"  Header="{Binding [已完成], Source={uic:L10N}}" Width="*" ElementStyle="{StaticResource CellCenterStyle}"/>
                    <DataGridTextColumn Binding="{Binding Path=HourOutputQty}" Header="{Binding [小时产量], Source={uic:L10N}}" Width="*" ElementStyle="{StaticResource CellCenterStyle}"/>
                    <DataGridTextColumn Binding="{Binding  Path=ThroughRate, StringFormat={}{0:P2}}" Header="{Binding [直通率], Source={uic:L10N}}" Width="120"  ElementStyle="{StaticResource CellCenterStyle}"/>
                    <DataGridTemplateColumn Header="{Binding [状态], Source={uic:L10N}}" Width="*"  >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock  HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding State}" Foreground="{Binding Path=State,Converter={StaticResource StateColorToConvert} }"   />
                          </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</sd:ComponentItem>
