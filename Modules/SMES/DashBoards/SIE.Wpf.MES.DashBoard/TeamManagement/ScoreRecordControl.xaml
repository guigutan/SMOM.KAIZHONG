<sd:ComponentItem x:Class="SIE.Wpf.MES.DashBoard.TeamManagement.ScoreRecordControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"       
             xmlns:local="clr-namespace:SIE.Wpf.MES.DashBoard.TeamManagement"
             xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"             
             sd:DiagramDesigner.ToolBarTitle="{Binding [绩效评分看板], Source={uic:L10N}}"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920">
    <sd:ComponentItem.Resources>
        <ResourceDictionary>
            <Style x:Key="CellCenterStyle" TargetType="TextBlock">
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Padding" Value="0, 11, 0, 11"/>
            </Style>
            <Style x:Key="LabelStyle" TargetType="Label">
                <Setter Property="Foreground" Value="White"></Setter>
                <Setter Property="FontWeight" Value="Bold"></Setter>
                <Setter Property="VerticalAlignment" Value="Center"></Setter>
            </Style>
           
            <Style  TargetType="DataGridRow">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Height" Value="{Binding cellHeight}"/>
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontSize" Value="{Binding cellFontSize}"/>
                <Setter Property="Focusable" Value="False"/>
                <Style.Triggers>
                    <!--隔行换色-->
                    <Trigger Property="AlternationIndex" Value="0" >
                        <Setter Property="Background" Value="#146481" />
                    </Trigger>
                    <Trigger Property="AlternationIndex" Value="1" >
                        <Setter Property="Background" Value="#1F7E96" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="Transparent"></Setter>
                <!--<Setter Property="FontSize" Value="{Binding headFontSize}"/>-->
                <Setter Property="FontWeight" Value="Normal"/>
                <!--<Setter Property="Height" Value="{Binding headHeight}"/>-->
                <Setter Property="FontFamily" Value="MicrosoftYaHeiUI"/>
                <Setter Property="Foreground" Value="#04FEFC"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </sd:ComponentItem.Resources>
    <Grid x:Name="OutestGird">
        <Grid.Background>
            <ImageBrush ImageSource="../Images/bg.png"  Stretch="UniformToFill" TileMode="None"></ImageBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="30"></RowDefinition>
        </Grid.RowDefinitions>
        <Label FontSize="37" Name="laTitle" Width="700" Height="63" Content="总装车间-装配一线-绩效评分看板"  Foreground="#04FEFC"  VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontWeight="Bold"  >
            <Label.Background>
                <ImageBrush ImageSource="../Images/titlebg.png"></ImageBrush>
            </Label.Background>

        </Label>

        <Grid Grid.Row="1" Margin="20,0,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.18*"></ColumnDefinition>
                <ColumnDefinition ></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <dxlc:GroupBox  CornerRadius="0" TitleVisibility="Hidden" Grid.Column="0">
                <dxlc:GroupBox.Background>
                    <ImageBrush ImageSource="../Images/leftbg.png"></ImageBrush>
                </dxlc:GroupBox.Background>
                <Grid  Margin="-8,-8,-8,0" Name="top3Grid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="95"></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Label FontSize="32" Foreground="#04FEFC"  FontWeight="Bold"  VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Grid.Row="0">
                        绩效总分TOP3
                    </Label>
                    <Grid Grid.Row="1" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"></ColumnDefinition>
                            <ColumnDefinition Width="3*"></ColumnDefinition>
                            <ColumnDefinition Width="0.5*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Image Width="51" Height="62" Source="../Images/No1.png"  Grid.Column="0"></Image>
                        <StackPanel Name="Stack1" Grid.Column="1"  Height="auto" VerticalAlignment="Center" Orientation="Vertical" >
                            <Image Name="imgFirst" Width="145" Height="145" Source="../Images/emp.png"  ></Image>
                            <Label Name="laFirst" FontSize="27" Foreground="#04FEFC" HorizontalContentAlignment="Center"></Label>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="2" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"></ColumnDefinition>
                            <ColumnDefinition Width="3*"></ColumnDefinition>
                            <ColumnDefinition Width="0.5*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Image x:Name="imgCup2"  Width="51" Height="62" Source="../Images/No2.png"  Grid.Column="0"></Image>
                        <StackPanel Name="Stack2" Grid.Column="1"  Height="auto" VerticalAlignment="Center" Orientation="Vertical" >
                            <Image Name="imgSecond" Width="145" Height="145" Source="../Images/emp.png"  ></Image>
                            <Label Name="laSecond" FontSize="27" Foreground="#04FEFC" HorizontalContentAlignment="Center"></Label>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="3" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"></ColumnDefinition>
                            <ColumnDefinition Width="3*"></ColumnDefinition>
                            <ColumnDefinition Width="0.5*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Image x:Name="imgCup3"  Width="51" Height="62" Source="../Images/No3.png"  Grid.Column="0"></Image>
                        <StackPanel Name="StackFirst" Grid.Column="1"  Height="auto" VerticalAlignment="Center" Orientation="Vertical" >
                            <Image x:Name="imgThird"  Width="145" Height="145" Source="../Images/emp.png"  ></Image>
                            <Label Name="laThird" FontSize="27" Foreground="#04FEFC" HorizontalContentAlignment="Center"></Label>
                        </StackPanel>
                    </Grid>
                </Grid>
            </dxlc:GroupBox>
            <Grid Grid.Column="1" Margin="10,0,20,0" x:Name="GridColumn">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3.5*"></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <DataGrid  x:Name="displayGrid" GridLinesVisibility="None" Grid.Row="0"  AlternationCount="2" 
              HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" SelectionUnit="Cell"  
              ItemsSource="{Binding}" AutoGenerateColumns="False" IsReadOnly="True" RowHeaderWidth="0" LayoutUpdated="displayGrid_LayoutUpdated">
                    <DataGrid.Background>
                        <ImageBrush ImageSource="../Images/contentbg.png"></ImageBrush>
                    </DataGrid.Background>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent"></Setter>
                            <Setter Property="Padding" Value="0,0,0,0"/>
                            <Setter Property="Margin" Value="0,0,0,0"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"></Setter>
                            <Setter Property="FontSize" Value="30"/>
                            <Setter Property="FontWeight" Value="Normal"/>
                            <Setter Property="Height" Value="80"/>
                            <Setter Property="FontFamily" Value="MicrosoftYaHeiUI"/>
                            <Setter Property="Foreground" Value="#04FEFC"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="*"  Binding="{Binding WorkGroupName}" Header="{Binding [班组], Source={uic:L10N}}" ElementStyle="{StaticResource CellCenterStyle}"></DataGridTextColumn>
                        <DataGridTextColumn Width="*"  Binding="{Binding EmployeeName}" Header="{Binding [员工], Source={uic:L10N}}" ElementStyle="{StaticResource CellCenterStyle}"></DataGridTextColumn>
                        <DataGridTextColumn Width="*"  Binding="{Binding FirstWeek}" Header="{Binding [第一周], Source={uic:L10N}}" ElementStyle="{StaticResource CellCenterStyle}"></DataGridTextColumn>
                        <DataGridTextColumn Width="*"  Binding="{Binding SecondWeek}" Header="{Binding [第二周], Source={uic:L10N}}" ElementStyle="{StaticResource CellCenterStyle}"></DataGridTextColumn>
                        <DataGridTextColumn Width="*"  Binding="{Binding ThirdWeek}" Header="{Binding [第三周], Source={uic:L10N}}" ElementStyle="{StaticResource CellCenterStyle}"></DataGridTextColumn>
                        <DataGridTextColumn Width="*"  Binding="{Binding FourthWeek}" Header="{Binding [第四周], Source={uic:L10N}}" ElementStyle="{StaticResource CellCenterStyle}"></DataGridTextColumn>
                        <DataGridTextColumn Width="*"  Binding="{Binding FifthWeek}" Header="{Binding [第五周], Source={uic:L10N}}" ElementStyle="{StaticResource CellCenterStyle}"></DataGridTextColumn>
                        <DataGridTemplateColumn Header="{Binding [月绩效评分], Source={uic:L10N}}" Width="{Binding imgRowWidth}"  CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" >
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="HorizontalAlignment" Value="Center"></Setter>
                                            </Style>
                                        </StackPanel.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition></ColumnDefinition>
                                                <ColumnDefinition></ColumnDefinition>
                                            </Grid.ColumnDefinitions>
                                            <Label x:Name="laPfCup" Grid.Column="0" FontWeight="Regular" FontSize="{Binding cellFontSize}" HorizontalContentAlignment="Left"  VerticalContentAlignment="Center" VerticalAlignment="Center" Foreground="White" Content="{Binding MonthScore}">
                                            </Label>
                                            <Image x:Name="imgCup1" Grid.Column="1" Width="{Binding imgWidth}" Height="{Binding imgHeight}"  Source="{Binding ScorePic}"  ></Image>
                                        </Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <Grid Grid.Row="1" Name="bottomGrid" Margin="0,20,0,0">
                    <Grid.Background>
                        <ImageBrush ImageSource="../Images/bottombg.png"></ImageBrush>
                    </Grid.Background>
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <Image Visibility="Collapsed" Source="../Images/biaoqing.png" Width="50" Height="50"></Image>
                        <Label Style="{StaticResource LabelStyle}" FontSize="32" />
                    </StackPanel>
                    <StackPanel Grid.Row="1">
                        <Image Visibility="Collapsed" Source="../Images/biaoqing.png" Width="50" Height="50"></Image>
                        <Label Style="{StaticResource LabelStyle}" FontSize="32" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <Image Visibility="Collapsed" Source="../Images/biaoqing.png" Width="50" Height="50"></Image>
                        <Label Style="{StaticResource LabelStyle}" FontSize="32"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1">
                        <Image Visibility="Collapsed" Source="../Images/biaoqing.png" Width="50" Height="50"></Image>
                        <Label Style="{StaticResource LabelStyle}" FontSize="32" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</sd:ComponentItem>
