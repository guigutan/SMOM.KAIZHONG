<UserControl x:Class="SIE.Wpf.MES.DashBoard.WorkOrderReachs.WorkOrderReachPivotGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxpg="http://schemas.devexpress.com/winfx/2008/xaml/pivotgrid"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:local="clr-namespace:SIE.Wpf.MES.DashBoard.WorkOrderReachs"
             xmlns:rt="clr-namespace:SIE.Wpf.MES.DashBoard.Reports"
             xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core" 
             xmlns:icon="http://schemas.siestudio.com/winfx/xaml/controls"
             mc:Ignorable="d"
             d:DesignHeight="480" d:DesignWidth="840">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" HorizontalAlignment="Left" Orientation="Horizontal">
            <Button  Margin="0,0,5,0"  HorizontalAlignment="Left" VerticalAlignment="Center" Click="ExportButton_Click"  ToolTip="{Binding [导出数据],Source={uic:L10N}}">
                <StackPanel Orientation="Horizontal">
                    <icon:PackIcon HorizontalAlignment="Left" Margin="2"   Kind="ExportData" Foreground="#326ab3"/>
                    <TextBlock Text="{Binding [导出],Source={uic:L10N}}" Margin="0,2,2,2" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Margin="0,0,5,0" HorizontalAlignment="Left" VerticalAlignment="Center" Click="BtnClick_SaveLayOut" ToolTip="{Binding [保存设置],Source={uic:L10N}}">
                <StackPanel Orientation="Horizontal">
                    <icon:PackIcon   HorizontalAlignment="Left" Margin="2"   Kind="SaveEntity" Foreground="#326ab3"/>
                    <TextBlock Text="{Binding [保存设置],Source={uic:L10N}}" Margin="0,2,2,2" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <dxlc:LayoutControl x:Name="mainLayout" Grid.Row="1" AllowItemSizing="True" Padding="2" Orientation="Vertical" >
            <dxlc:LayoutGroup dxlc:LayoutControl.AllowVerticalSizing="True" Margin="0,0,0,2">
                <dxpg:PivotGridControl x:Name="pivotGrid" DataContext="{Binding}" DataSource="{Binding WorkOrderReachList}" RowTreeWidth="120"
                           AllowCustomizationForm="False" rt:FieldAreaHelper.FixAreas="True"
                           ShowGrandTotalsForSingleValues="False" ShowCustomTotalsForSingleValues="False"
                           ShowRowTotals="False" ShowRowGrandTotals="False" ShowRowGrandTotalHeader="True" 
                           ShowColumnTotals="False" ShowColumnGrandTotals="False" ShowColumnGrandTotalHeader="True"
                           ChartProvideColumnGrandTotals="False" ChartProvideColumnCustomTotals="False"  ChartProvideRowGrandTotals="False"  ChartProvideRowCustomTotals="False" 
                           ChartFieldValuesProvideMode="DisplayText" ChartAutoTranspose="True"
                           ChartProvideDataByColumns="False" ChartSelectionOnly="True"                         
                           ShowRowHeaders="False" ShowDataHeaders="False"
                           FieldAreaChanged="PivotGrid_FieldAreaChanged"            
                           FieldValueDisplayText="pivotGrid_FieldValueDisplayText"
                           CustomCellDisplayText="pivotGrid_CustomCellDisplayText"
                           CellSelectionChanged="pivotGrid_CellSelectionChanged"
                           CellDoubleClick="pivotGrid_CellDoubleClick"
                           CustomCellValue="pivotGrid_CustomCellValue"  
                           CustomFieldSort="pivotGrid_CustomFieldSort"
                           >
                </dxpg:PivotGridControl>
            </dxlc:LayoutGroup>

            <dxlc:LayoutGroup dxlc:LayoutControl.AllowVerticalSizing="True" Margin="0,2,0,0">

                <dxc:ChartControl Name="chart" CrosshairEnabled="True"  AnimationMode="OnLoad"  Grid.Row="0">
                    <dxc:ChartControl.CrosshairOptions>
                        <dxc:CrosshairOptions ShowArgumentLine="True"/>
                    </dxc:ChartControl.CrosshairOptions>
                    <dxc:ChartControl.Legend>
                        <dxc:Legend Background="{x:Null}" HorizontalPosition="Center" VerticalPosition="BottomOutside" 
                                        Orientation="Horizontal" FontSize="12" Margin="0" Padding="0" BorderThickness="0">
                            <dxc:Legend.CustomItems>
                                <dxc:CustomLegendItem Name="totalQty" Text="{Binding [工单总数],Source={uic:L10N}}" MarkerBrush="#5a9bd5"/>
                                <dxc:CustomLegendItem Name="compQty"  Text="{Binding [准时完工数],Source={uic:L10N}}"  MarkerBrush ="#ed7c30"/>
                                <dxc:CustomLegendItem Name="closeQty"  Text="{Binding [工单完工数],Source={uic:L10N}}"  MarkerBrush ="#F0CFA7"/>
                                <dxc:CustomLegendItem Name="reachRate"  Text="{Binding [准时达成率],Source={uic:L10N}}" MarkerBrush ="#FF0000"/>
                                <dxc:CustomLegendItem Name="closeRate"  Text="{Binding [工单完工率],Source={uic:L10N}}" MarkerBrush ="Yellow"/>
                            </dxc:Legend.CustomItems>
                        </dxc:Legend>
                    </dxc:ChartControl.Legend>
                    <dxc:ChartControl.Diagram>
                        <dxc:XYDiagram2D EnableAxisXNavigation="True" Name="diagram">
                            <dxc:XYDiagram2D.AxisX>
                                <dxc:AxisX2D x:Name="_AxisX" Visible="True"  TickmarksMinorVisible="False" TickmarksLength="1"  
                                                 GridLinesMinorVisible="False" GridLinesVisible="False">
                                    <dxc:AxisX2D.CrosshairAxisLabelOptions>
                                        <dxc:CrosshairAxisLabelOptions/>
                                    </dxc:AxisX2D.CrosshairAxisLabelOptions>
                                    <dxc:AxisX2D.Label>
                                        <dxc:AxisLabel Background="Transparent" BorderBrush="#FF343246" Padding="0,1" FontSize="12"/>
                                    </dxc:AxisX2D.Label>
                                </dxc:AxisX2D>
                            </dxc:XYDiagram2D.AxisX>
                            <dxc:XYDiagram2D.AxisY>
                                <dxc:AxisY2D x:Name="_AxisY">
                                    <dxc:AxisY2D.Label>
                                        <dxc:AxisLabel Background="Transparent" BorderBrush="#FF343246" Padding="0,1"  FontSize="12"/>
                                    </dxc:AxisY2D.Label>
                                </dxc:AxisY2D>
                            </dxc:XYDiagram2D.AxisY>
                            <dxc:XYDiagram2D.Series>
                                <dxc:BarSideBySideSeries2D Name="BarSideSerie" ArgumentScaleType="Qualitative" ValueScaleType="Numerical" Brush="#5a9bd5" LabelsVisibility="True" BarWidth="1" ShowInLegend="True">
                                    <dxc:BarSideBySideSeries2D.Model>
                                        <dxc:BorderlessSimpleBar2DModel/>
                                    </dxc:BarSideBySideSeries2D.Model>
                                    <dxc:BarSideBySideSeries2D.Label>
                                        <dxc:SeriesLabel dxc:BarSideBySideSeries2D.LabelPosition="Outside" Indent="10" ConnectorVisible="False">
                                            <dxc:SeriesLabel.ElementTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Text}" FontSize="12" FontFamily="微软雅黑"/>
                                                </DataTemplate>
                                            </dxc:SeriesLabel.ElementTemplate>
                                        </dxc:SeriesLabel>
                                    </dxc:BarSideBySideSeries2D.Label>
                                </dxc:BarSideBySideSeries2D>
                                <dxc:BarSideBySideSeries2D Name="BarSideSerie2" ArgumentScaleType="Qualitative" ValueScaleType="Numerical"  Brush="#ed7c30" LabelsVisibility="True" BarWidth="1" ShowInLegend="True">
                                    <dxc:BarSideBySideSeries2D.Model>
                                        <dxc:BorderlessSimpleBar2DModel/>
                                    </dxc:BarSideBySideSeries2D.Model>
                                    <dxc:BarSideBySideSeries2D.Label>
                                        <dxc:SeriesLabel dxc:BarSideBySideSeries2D.LabelPosition="Outside" Indent="10" ConnectorVisible="False">
                                            <dxc:SeriesLabel.ElementTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Text}" FontSize="12" FontFamily="微软雅黑"/>
                                                </DataTemplate>
                                            </dxc:SeriesLabel.ElementTemplate>
                                        </dxc:SeriesLabel>
                                    </dxc:BarSideBySideSeries2D.Label>
                                </dxc:BarSideBySideSeries2D>
                                <dxc:BarSideBySideSeries2D Name="BarSideSerie3" ArgumentScaleType="Qualitative" ValueScaleType="Numerical" Brush="#F0CFA7" LabelsVisibility="True" BarWidth="1" ShowInLegend="True">
                                    <dxc:BarSideBySideSeries2D.Model>
                                        <dxc:BorderlessSimpleBar2DModel/>
                                    </dxc:BarSideBySideSeries2D.Model>
                                    <dxc:BarSideBySideSeries2D.Label>
                                        <dxc:SeriesLabel dxc:BarSideBySideSeries2D.LabelPosition="Outside" Indent="10" ConnectorVisible="False">
                                            <dxc:SeriesLabel.ElementTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Text}" FontSize="12" FontFamily="微软雅黑"/>
                                                </DataTemplate>
                                            </dxc:SeriesLabel.ElementTemplate>
                                        </dxc:SeriesLabel>
                                    </dxc:BarSideBySideSeries2D.Label>
                                </dxc:BarSideBySideSeries2D>
                                <dxc:LineSeries2D Name="LineSerie"  Brush="Red"   Foreground="Red" dxc:XYDiagram2D.SeriesAxisY="{Binding ElementName=_SecondaryAxisY2D}"
                                                      MarkerVisible="True"
                                                      LabelsVisibility="True" 
                                                      CrosshairLabelVisibility="True"
                                                      Visibility="Visible"
                                                      AnimationAutoStartMode="SetStartState"
                                                      ArgumentDataMember="Argument"
                                                      ValueDataMember="Value"
                                                      ShowInLegend="True">
                                    <dxc:LineSeries2D.MarkerModel>
                                        <dxc:TriangleMarker2DModel/>
                                    </dxc:LineSeries2D.MarkerModel>
                                    <dxc:LineSeries2D.Label>
                                        <dxc:SeriesLabel 
                                                Background="Gray"
                                                Opacity="0.75"
                                                ConnectorVisible="False"
                                                ResolveOverlappingMode="Default"
                                                Indent="20"
                                                Visible="True"
                                                dxc:MarkerSeries2D.Angle="90"
                                                TextPattern="{}{V:P2}" >
                                            <dxc:SeriesLabel.ElementTemplate>
                                                <DataTemplate>
                                                    <Border Background="Gray">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Path=Text}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </dxc:SeriesLabel.ElementTemplate>
                                        </dxc:SeriesLabel>
                                    </dxc:LineSeries2D.Label>
                                </dxc:LineSeries2D>
                                <dxc:LineSeries2D Name="LineSerie2"   Brush="Yellow"  Foreground="Yellow" dxc:XYDiagram2D.SeriesAxisY="{Binding ElementName=_SecondaryAxisY2D}"
                                                      MarkerVisible="True"
                                                      LabelsVisibility="True" 
                                                      CrosshairLabelVisibility="True"
                                                      Visibility="Visible"
                                                      AnimationAutoStartMode="SetStartState"
                                                      ArgumentDataMember="Argument"
                                                      ValueDataMember="Value"
                                                      ShowInLegend="True">
                                    <dxc:LineSeries2D.MarkerModel>
                                        <dxc:TriangleMarker2DModel/>
                                    </dxc:LineSeries2D.MarkerModel>
                                    <dxc:LineSeries2D.Label>
                                        <dxc:SeriesLabel 
                                                Background="Gray"
                                                Opacity="0.75"
                                                ConnectorVisible="False"
                                                ResolveOverlappingMode="Default"
                                                Indent="20"
                                                Visible="True"
                                                dxc:MarkerSeries2D.Angle="90"
                                                TextPattern="{}{V:P2}" >
                                            <dxc:SeriesLabel.ElementTemplate>
                                                <DataTemplate>
                                                    <Border Background="Gray">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Path=Text}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </dxc:SeriesLabel.ElementTemplate>
                                        </dxc:SeriesLabel>
                                    </dxc:LineSeries2D.Label>
                                </dxc:LineSeries2D>
                            </dxc:XYDiagram2D.Series>
                            <dxc:XYDiagram2D.SecondaryAxesY>
                                <dxc:SecondaryAxisY2D Name="_SecondaryAxisY2D">
                                    <dxc:SecondaryAxisY2D.Label>
                                        <dxc:AxisLabel Background="Transparent" FontSize="12" TextPattern="{}{VP:P0}"/>
                                    </dxc:SecondaryAxisY2D.Label>
                                </dxc:SecondaryAxisY2D>
                            </dxc:XYDiagram2D.SecondaryAxesY>
                            <dxc:XYDiagram2D.DefaultPane>
                                <dxc:Pane Name="DefaultPaneBackground"/>
                            </dxc:XYDiagram2D.DefaultPane>
                        </dxc:XYDiagram2D>
                    </dxc:ChartControl.Diagram>
                </dxc:ChartControl>
            </dxlc:LayoutGroup>
        </dxlc:LayoutControl>
    </Grid>
</UserControl>
