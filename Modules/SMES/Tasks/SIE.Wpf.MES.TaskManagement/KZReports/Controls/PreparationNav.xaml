<UserControl x:Class="SIE.Wpf.MES.TaskManagement.KZReports.Controls.PreparationNav"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.TaskManagement.KZReports.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary Source="/SIE.Wpf.MES.TaskManagement;component/Styles/ReportStyle.xaml"></ResourceDictionary>
        
    </UserControl.Resources>
    <Grid Background="White">
        <Grid.RowDefinitions >
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" >
            <StackPanel  Grid.Column="0" Orientation="Horizontal"  Margin="0" HorizontalAlignment="Left">
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1" Margin="20 0">
            <StackPanel  Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Grid.Column="2" Name="btnEquip" Content="工装/检具准备" Style="{StaticResource CommonButtonStyle}" Width="200" Height="55" VerticalContentAlignment="Center" Foreground="White" Background="#2D8CF0" FontSize="22" Click="btnEquip_Click" Margin="50" ></Button>
                <Button Grid.Column="2" Name="btnModel" Content="上模" Style="{StaticResource CommonButtonStyle}" Width="200" Height="55" VerticalContentAlignment="Center" Foreground="White" Background="#2D8CF0" FontSize="22" Click="btnModel_Click" Margin="50" ></Button>
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="2" Margin="10 30"  Orientation="Horizontal" HorizontalAlignment="Left">
        </StackPanel>
    </Grid>

</UserControl>
