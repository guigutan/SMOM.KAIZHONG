<UserControl x:Class="SIE.Wpf.MES.TaskManagement.KZReports.Controls.LabelPrintControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.TaskManagement.KZReports.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary Source="/SIE.Wpf.MES.TaskManagement;component/Styles/ReportStyle.xaml"></ResourceDictionary>
    </UserControl.Resources>
    <Border Background="White">
        <Grid  Margin="10 30">
            <Grid.RowDefinitions >
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="0"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border x:Name="templateBorder" Grid.Row="1" Margin="20 5" BorderThickness="1" BorderBrush="#CCC" VerticalAlignment="Top" >
                <Grid >
                    <Grid.RowDefinitions >
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    

                    <Border Grid.Row="0" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                        <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                            <Label Style="{StaticResource FormLabelStyle_16}" Content="打印机" HorizontalContentAlignment="Center" ></Label>
                            <ComboBox x:Name="cbbPrinter" Width="300" VerticalContentAlignment="Center" FontSize="18" Margin="2"></ComboBox>
                        </StackPanel>
                    </Border>

                </Grid>
            </Border>

            <TabControl Grid.Row="2" Margin="20 0" FontSize="18" >
                <TabItem Header="标签列表" >
                    <DataGrid x:Name="dataGrid" Background="White" GridLinesVisibility="None" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Extended">
                        <DataGrid.Columns>
                            <!--<DataGridCheckBoxColumn >
                                <DataGridCheckBoxColumn.HeaderTemplate >
                                    <DataTemplate>
                                        <CheckBox Click="CheckBox_Click_2" HorizontalContentAlignment="Center" HorizontalAlignment="Center"  VerticalAlignment="Center" Tag="{Binding Id}"></CheckBox>
                                    </DataTemplate>
                                </DataGridCheckBoxColumn.HeaderTemplate>
                                --><!--为该列的CheckBox Tag属性绑定值--><!--
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="Tag" Value="{Binding Id}"></Setter>
                                        <Setter Property="CheckBox.VerticalAlignment"  Value="Center"></Setter>
                                        <Setter Property="CheckBox.HorizontalAlignment"  Value="Center"></Setter>
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>

                                --><!--设置一点样式--><!--
                                <DataGridCheckBoxColumn.CellStyle >
                                    <Style  >
                                        <Setter Property="CheckBox.Width"  Value="50"></Setter>
                                        <Setter Property="CheckBox.Height"  Value="30"></Setter>
                                        <Setter Property="CheckBox.VerticalAlignment"  Value="Center"></Setter>
                                        <Setter Property="CheckBox.HorizontalAlignment"  Value="Center"></Setter>
                                    </Style>
                                </DataGridCheckBoxColumn.CellStyle>

                            </DataGridCheckBoxColumn>-->
                            <DataGridTextColumn Header="标签号" Binding="{Binding BatchNo}" Width="200"/>
                            <!--<DataGridTextColumn Header="产品编码" Binding="{Binding ProductCode}" Width="150"/>
                            <DataGridTextColumn Header="产品名称" Binding="{Binding ProductName}" Width="150"/>-->
                            <DataGridTextColumn Header="数量" Binding="{Binding Qty}" Width="150"/>
                            <DataGridTextColumn Header="是否可疑品标签" Binding="{Binding IsSuspectProduct}" Width="150"/>
                        </DataGrid.Columns>
                        
                    </DataGrid>
                </TabItem>
            </TabControl>

            <StackPanel Grid.Row="3" Margin="50 10"  Orientation="Horizontal" HorizontalAlignment="Center">
                <Button  Content="关闭" Style="{StaticResource CommonButtonStyle}" Width="120" Height="50" Margin="50 0" Name="btnCancel" Click="btnCancel_Click" Background="Red"></Button>
                <Button  Content="打印" Style="{StaticResource CommonButtonStyle}" Width="120" Height="50" Margin="50 0" Name="btnSubmit" Click="btnSubmit_Click"></Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
