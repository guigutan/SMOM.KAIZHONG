<UserControl x:Class="SIE.Wpf.MES.TaskManagement.KZReports.Controls.PreparationModel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.TaskManagement.KZReports.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary Source="/SIE.Wpf.MES.TaskManagement;component/Styles/ReportStyle.xaml"></ResourceDictionary>
    </UserControl.Resources>
    <Border Background="White">
        <Grid  Margin="30" MaxWidth="2500">
            <Grid.RowDefinitions >
                <!--<RowDefinition Height="auto"/>-->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!--<ctl:XPTitle Grid.Row="0" x:Name="xpTitle" AType="Default" AShowWinTitle="False" ATitle="报工主界面"></ctl:XPTitle>-->
            <Grid Grid.Row="0" Margin="0 0 0 0">
                <StackPanel  Grid.Column="0" Orientation="Horizontal"  Margin="0" HorizontalAlignment="Left">
                    <Button  Content="返回" Style="{StaticResource CommonButtonStyle}" Width="120" Height="40" Margin="20" Name="btnBack" Background="Gray" Click="btnBack_Click"></Button>
                </StackPanel>
                <StackPanel  Orientation="Horizontal" Height="40" HorizontalAlignment="Right">
                    <Label Content="报工资源" FontSize="18" FontWeight="Bold" Foreground="Gray" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" Margin="5" ></Label>
                    <Label Content="{Binding Resource.Name}" Name="lbResourceName" Foreground="Blue" Margin="0 0 20 0" MinWidth="80" Width="auto" Height="40" FontSize="18" FontWeight="Bold" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" ></Label>

                    <Label Content="报工操作员:" FontSize="18" FontWeight="Bold" Foreground="Gray" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" Margin="5" ></Label>
                    <Label Content="{Binding ReportEmployee.Name}" Name="lbOparetorName" Foreground="Blue" Margin="0 0 20 0" MinWidth="80" Width="auto" Height="40" FontSize="18" FontWeight="Bold" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" ></Label>
                </StackPanel >
            </Grid>
            <Border Grid.Row="1" Margin="0 0 0 0" BorderThickness="1" BorderBrush="#ccc">
                <Grid >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Label Grid.Column="0" Style="{StaticResource FormLabelStyle_18}" Content="模具编码" HorizontalContentAlignment="Center" Height="50"></Label>
                    <TextBox Grid.Column="1" x:Name="txtBarcode" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" Text="" FontSize="18" Background="LightGreen" Margin="2" KeyUp="txtBarcode_KeyUp"></TextBox>

                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2">
                        <TextBox x:Name="txtTip" Text="提示" IsReadOnly="True" Focusable="False" BorderThickness="0.5" Foreground="Red" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" Height="50" FontSize="18" Background="White" Margin="2" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Border x:Name="templateBorder" Grid.Row="2" Margin="0 5" BorderThickness="1" BorderBrush="#CCC" VerticalAlignment="Top">
                <Grid Grid.Row="2" >
                    <Grid.RowDefinitions >
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="40"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Row="0" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                        <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                            <Label Style="{StaticResource FormLabelStyle_16}" Content="派工单号" Width="150" VerticalContentAlignment="Center" ></Label>
                            <Label Style="{StaticResource FormLabelStyle2_16}" Content="{Binding DispatchTask.No}" ></Label>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                            <Label Style="{StaticResource FormLabelStyle_16}" Content="数量"  ></Label>
                            <Label Style="{StaticResource FormLabelStyle2_16}" Content="{Binding DispatchTask.DispatchQty}" ></Label>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                        <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                            <Label Style="{StaticResource FormLabelStyle_16}" Content="产品编码"  ></Label>
                            <Label Style="{StaticResource FormLabelStyle2_16}" Content="{Binding DispatchTask.ProductCode}" ></Label>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                            <Label Style="{StaticResource FormLabelStyle_16}" Content="产品名称"  ></Label>
                            <Label Style="{StaticResource FormLabelStyle2_16}" Content="{Binding DispatchTask.ProductName}" ></Label>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                        <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                            <Label Style="{StaticResource FormLabelStyle_16}" Content="工序编码"  ></Label>
                            <Label Style="{StaticResource FormLabelStyle2_16}" Content="{Binding DispatchTask.ProcessCode}" ></Label>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                            <Label Style="{StaticResource FormLabelStyle_16}" Content="工序名称"  ></Label>
                            <Label Style="{StaticResource FormLabelStyle2_16}" Content="{Binding DispatchTask.ProcessName}" ></Label>
                        </StackPanel>
                    </Border>

                </Grid>
            </Border>

            <TabControl Grid.Row="3" Margin="0 0" FontSize="18" >
                <TabItem Header="扫描明细" x:Name="tabItemScanDetail" >
                    <DataGrid x:Name="dataGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="编码" Binding="{Binding Code}" Width="150"/>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="150"/>
                            <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="150"/>
                            <DataGridTextColumn Header="日期" Binding="{Binding ScanTimeStr}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <TabItem Header="已上资源明细" x:Name="tabItemModelDetail" IsSelected="True">
                    <DataGrid x:Name="dataGrid2" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="编码" Binding="{Binding Code}" Width="150"/>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="150"/>
                            <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="150"/>
                            <DataGridTextColumn Header="日期" Binding="{Binding ScanTimeStr}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>

            <StackPanel Grid.Row="4" Margin="0 20 0 10"  Orientation="Horizontal" HorizontalAlignment="Center">
                <Button  Content="重置" Style="{StaticResource CommonButtonStyle}" Width="120" Height="50" Margin="50 20" Name="btnCancel" Background="Red" Click="btnCancel_Click"></Button>
                <Button  Content="确认" Style="{StaticResource CommonButtonStyle}" Width="120" Height="50" Margin="50 20" Name="btnSubmit" Click="btnSubmit_Click"></Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
