<UserControl x:Class="SIE.Wpf.MES.TaskManagement.KZReports.Controls.SWRecordScanControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.TaskManagement.KZReports.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary Source="/SIE.Wpf.MES.TaskManagement;component/Styles/ReportStyle.xaml"></ResourceDictionary>
    </UserControl.Resources>
    <Border Background="White" MaxWidth="2500">
        <DockPanel x:Name ="dockPanel" Margin="30">
            <Grid>
                <Grid.RowDefinitions >
                    <!--<RowDefinition Height="auto"/>-->
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0 0 0 0">
                    <StackPanel  Grid.Column="0" Orientation="Horizontal"  Margin="0" HorizontalAlignment="Left">
                        <Button Name="btnBack" Content="返回" Style="{StaticResource CommonButtonStyle}" Width="120" Height="40" Margin="0 20"  Click="btnBack_Click" Background="Gray" ></Button>
                        <Button Name="btnReset" Content="重新开始" Style="{StaticResource CommonButtonStyle}" Width="120" Height="40" Margin="20" Click="btnReStart_Click" Background="DeepSkyBlue" ></Button>
                        <Button Name="btnSubmit" Content="提交" Style="{StaticResource CommonButtonStyle}" Width="120" Height="40" Margin="20"   Click="btnSubmit_Click" Background="DeepSkyBlue"></Button>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Margin="0 0 0 0" BorderThickness="1" BorderBrush="#ccc">
                    <Grid >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Label Grid.Column="0" Style="{StaticResource FormLabelStyle_18}" Content="扫描标签" HorizontalContentAlignment="Center" Height="50"></Label>
                        <TextBox Grid.Column="1" x:Name="txtBarcode" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" Text="{Binding Path=Barcode, Mode=TwoWay}" FontSize="18" Background="LightGreen" Margin="2" KeyUp="txtBarcode_KeyUp"></TextBox>
                        <StackPanel Grid.Row="1" Grid.ColumnSpan="3">
                            <TextBox x:Name="txtTip" Text="提示信息" IsReadOnly="True" Focusable="False" BorderThickness="0.5" Foreground="Red" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" Height="50" FontSize="18" Background="White" Margin="2" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border x:Name="templateBorder" Grid.Row="2" Margin="0 5" BorderThickness="1" BorderBrush="#CCC" VerticalAlignment="Top">
                    <Grid Grid.Row="2" >
                        <Grid.RowDefinitions >
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Row="0" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                            <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_16}" Content="物料标签号" Width="150" VerticalContentAlignment="Center" ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_16}" Content="{Binding Sn}" ></Label>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_16}" Content="物料批次号"  ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_16}" Content="{Binding Lot}" ></Label>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                            <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_16}" Content="物料编码"  ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_16}" Content="{Binding ItemCode}" ></Label>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_16}" Content="物料名称"  ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_16}" Content="{Binding ItemName}" ></Label>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                            <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_16}" Content="物料单位"  ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_16}" Content="{Binding ItemUnit}" ></Label>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="2" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_16}" Content="状态"  ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_16}" Content="{Binding ItemLabelState}" ></Label>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="3" Grid.Column="0" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_16}" Content="上料数量"  ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_16}" Content="{Binding FeedingQty}" ></Label>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="3" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_16}" Content="下料数量"  ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_16}" Content="{Binding BlankingQty}" ></Label>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="4" Grid.Column="0" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_16}" Content="理论剩余数量"  ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_16}" Content="{Binding RemainingQty}" ></Label>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="4" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_16}" Content="实际重量数量"  ></Label>
                                <TextBox x:Name="txtActualQty" VerticalContentAlignment="Center" MinWidth="250" Height="auto" Text="{Binding ActualQty}"  FontSize="16" Background="LightGreen" Margin="2" Focusable="False"></TextBox>
                                <Button x:Name="btnActualQty" Content="C" MinWidth="40" Margin="2" Background="LightGreen" Click="btnActualQty_Click" />
                                <!--<Label Style="{StaticResource FormLabelStyle2_16}" Content="{Binding ActualQty}" ></Label>-->
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

        </DockPanel>
    </Border>

</UserControl>
