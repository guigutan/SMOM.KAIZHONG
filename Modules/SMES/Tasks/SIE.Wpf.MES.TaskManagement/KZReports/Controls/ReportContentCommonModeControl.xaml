<UserControl x:Class="SIE.Wpf.MES.TaskManagement.KZReports.Controls.ReportContentCommonModeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.TaskManagement.KZReports.Controls"
             xmlns:conv="clr-namespace:SIE.Wpf.MES.TaskManagement.KZReports.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1200">
    <UserControl.Resources>
        <ResourceDictionary >
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SIE.Wpf.MES.TaskManagement;component/Styles/ReportStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:IotStatusConverter x:Key="IotStatusConverter"/>
            <conv:TaskStatusConverter x:Key="TaskStatusConverter"/>
            <conv:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <conv:LengthToVisibilityConverter x:Key="LengthToVisibilityConverter" />

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Height" Value="50"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate>
                            <Border Background="#E0E8EF" BorderThickness="0" BorderBrush="Black">
                                <TextBlock Text="{Binding}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="Black"
                               FontFamily="Times New Roman"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="DataGridRow">
                <Setter Property="BorderThickness" Value="0.5"/>
                <Setter Property="BorderBrush" Value="#e0e8eF"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value=" true">
                        <Setter Property="Background" Value="#F0F8FF"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="DataGridCell">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="BorderBrush" Value="#e0e8eF"/>
                <Setter Property="MinHeight" Value="50"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value=" true">
                        <Setter Property="Background" Value="IndianRed"/>
                        <Setter Property="Foreground" Value="White"/>
                        <!--<Setter Property="FontWeight" Value="Normal"/>-->
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Grid.Row="1" x:Name="borderMain" Background="White" Margin="0 0" BorderThickness="0" BorderBrush="#CCC" VerticalAlignment="Center">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" >
            <StackPanel Name="templetePanel"  >
                <!--<Label Style="{StaticResource FormLabelStyle_14}" Margin="20 0 20 5" HorizontalAlignment="Left">生产详情</Label>-->
                <Expander Header="生产详情" IsExpanded="True" FontSize="14" FontWeight="Normal" Margin="10 0" Padding="0 4">
                    <Border BorderThickness="1" Name="templeteBorder" Margin="0 0" BorderBrush="#CCC" Background="AliceBlue"  HorizontalAlignment="Stretch" VerticalAlignment="Center">
                        <!--<Label HorizontalContentAlignment="Center" FontSize="35"  Foreground="#CCCCCC" VerticalContentAlignment="Center" Content="请选择派工任务"></Label>-->
                        <Grid Grid.Row="2" x:Name="grid1" >
                            <Grid.RowDefinitions >
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Row="0" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                                <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                    <Label Style="{StaticResource FormLabelStyle_14}" Content="产线" Width="150" VerticalContentAlignment="Center" ></Label>
                                    <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding Resource.Name}" ></Label>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                    <Label Style="{StaticResource FormLabelStyle_14}" Content="模具"  ></Label>
                                    <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding Model}" ></Label>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                                <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                    <Label Style="{StaticResource FormLabelStyle_14}" Content="IOT实体"  ></Label>
                                    <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding IotEntity}" ></Label>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                    <Label Style="{StaticResource FormLabelStyle_14}" Content="模具穴位"  ></Label>
                                    <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding ModelCavityCount}" ></Label>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                                <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                    <Label Style="{StaticResource FormLabelStyle_14}" Content="设备产出数"  ></Label>
                                    <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding IotOuptQty}" Foreground="Red"></Label>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="2" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                    <Label Style="{StaticResource FormLabelStyle_14}" Content="IOT设备状态"  ></Label>
                                    <!--<Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding DispatchTask.IotStatus, Converter={StaticResource IotStatusConverter}}" Foreground="Red"></Label>-->
                                    <ProgressBar x:Name="progressBar" Width="100" MinHeight="15" MaxHeight="20" Margin="10 0" IsIndeterminate="True" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding IsShowLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </Border>

                        </Grid>
                    </Border>
                </Expander>

                <Expander Header="任务单信息" IsExpanded="True" FontSize="14" FontWeight="Normal" Margin="10 0" Padding="0 4">
                    <Border BorderThickness="0.5" Name="templeteBorder2"  Margin="0 0" BorderBrush="#CCC" Background="AliceBlue"  HorizontalAlignment="Stretch" VerticalAlignment="Top">
                        <!--<Label HorizontalContentAlignment="Center" FontSize="35"  Foreground="#CCCCCC" VerticalContentAlignment="Center" Content="请选择派工任务"></Label>-->

                        <ListBox x:Name="listQueue" Margin="0" Padding="0" ItemsSource="{Binding ReportTaskQueueList}" BorderThickness="0" MinHeight="130" MaxHeight="260"  HorizontalAlignment="Stretch" HorizontalContentAlignment ="Stretch" SelectionChanged="listQueue_SelectionChanged" >
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <!--<StackPanel Orientation="Horizontal" Height="20"  Background="AntiqueWhite"/>-->

                                    <Grid ShowGridLines="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"  Background="AliceBlue">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Row="1" Grid.Column="1" BorderThickness="1" BorderBrush="LightGray" Margin="0 0">
                                            <Grid  x:Name="grid1"  >
                                                <Grid.RowDefinitions >
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Row="0" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                                                    <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                                        <Label Style="{StaticResource FormLabelStyle_14}"  Width="130" MaxWidth="150" Content="派工单号" VerticalContentAlignment="Center" ></Label>
                                                        <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding DispatchTaskNo}" ></Label>
                                                        <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding TaskStatus, Converter={StaticResource TaskStatusConverter}}" Foreground="Red"></Label>

                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Row="0" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                                        <Label Style="{StaticResource FormLabelStyle_14}" Width="130" MaxWidth="150" Content="工单号"  ></Label>
                                                        <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding WorkOrderNo}" ></Label>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Row="1" Grid.Column="0" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                                        <Label Style="{StaticResource FormLabelStyle_14}"  Width="130" MaxWidth="150" Content="物料编码"   ></Label>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                                            <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding ProductCode}" ></Label>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Row="1" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                                        <Label Style="{StaticResource FormLabelStyle_14}" Width="130" MaxWidth="150" Content="旧物料号/父旧料号"  ></Label>
                                                        <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding ShortDescription}" ></Label>
                                                        <Label Style="{StaticResource FormLabelStyle2_14}" Content="/" Margin="0" Padding="0"></Label>
                                                        <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding ParShortDescription}" ></Label>
                                                    </StackPanel>
                                                </Border>


                                                <Border Grid.Row="2" BorderThickness="0 0 0 1" BorderBrush="#CCC" >
                                                    <Grid  HorizontalAlignment="Stretch" >
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="130" MaxWidth="150"></ColumnDefinition>
                                                            <ColumnDefinition Width="*"></ColumnDefinition>
                                                        </Grid.ColumnDefinitions>

                                                        <Label Grid.Column="0" Style="{StaticResource FormLabelStyle_14}"  Width="130" MaxWidth="150" Content="实际数/计划数" ></Label>
                                                        <Grid Grid.Column="1"  HorizontalAlignment="Stretch" >

                                                            <StackPanel  Orientation="Horizontal" HorizontalAlignment="Left"  >
                                                                <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding ActualReportQty}" Margin="5 0 0 0" Padding="0"></Label>
                                                                <Label Style="{StaticResource FormLabelStyle2_14}" Content="/" Margin="0" ></Label>
                                                                <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding DispatchQty}" Margin="0" Padding="0"></Label>
                                                                <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding UnitName}" ></Label>

                                                            </StackPanel>
                                                            <StackPanel  Orientation="Horizontal" HorizontalAlignment="Right" MaxWidth="180" Margin="0 0 10 0" >
                                                                <ProgressBar x:Name="progressBarReport" Maximum="{Binding DispatchQty}" MinHeight="15" MaxHeight="20" MinWidth="80" MaxWidth="150" Margin="5 5"
                                                             Foreground="LightGreen" Background="#eee" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Value="{Binding ActualReportQty,Mode=OneWay}" />
                                                                <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding ReportProgress}" Margin="0" Padding="0" MinWidth="35" ></Label>
                                                                <Label Style="{StaticResource FormLabelStyle2_14}" Content="%" Margin="0" Padding="0" ></Label>

                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </Border>

                                                <Border Grid.Row="2" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                                        <Label Style="{StaticResource FormLabelStyle_14}" Width="130" MaxWidth="150" Content="分单数量"  ></Label>
                                                        <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding Zcode}" ></Label>
                                                        <!--<Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding IotStatus, Converter={StaticResource IotStatusConverter}}" Foreground="Red"></Label>-->
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Row="3" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                                                    <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                                        <Label Style="{StaticResource FormLabelStyle_14}" Width="130" MaxWidth="150" Content="设备数 * 穴位"  ></Label>
                                                        <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding IotQty}" Foreground="Red" ></Label>
                                                        <Label Style="{StaticResource FormLabelStyle2_14}" Content="*" ></Label>
                                                        <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding CavityCount}" ></Label>

                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Row="3" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">

                                                    <Grid  HorizontalAlignment="Stretch" >
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="130" MaxWidth="150"></ColumnDefinition>
                                                            <ColumnDefinition Width="50*"></ColumnDefinition>
                                                        </Grid.ColumnDefinitions>

                                                        <Label Grid.Column="0" Style="{StaticResource FormLabelStyle_14}"  Width="130" MaxWidth="150" Content="良品数/可疑品数" ></Label>

                                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                            <TextBox x:Name="txtOkQty" VerticalContentAlignment="Center" MinWidth="100" Height="auto" Text="{Binding IotOkQty,Mode=OneWay}"  FontSize="14" Background="Transparent" Margin="2" Focusable="False"></TextBox>
                                                            <TextBox x:Name="txtSuspectQty" VerticalContentAlignment="Center" MinWidth="100" Height="auto" Text="{Binding IotSuspectQty}"  FontSize="14" Background="Yellow" Margin="2"  Focusable="False"></TextBox>
                                                            <Button x:Name="btnSuspectQty" Content="C" MinWidth="20" Margin="2"  Click="btnSuspectQty_Click" Tag="{Binding Id}" />
                                                        </StackPanel>

                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Border>

                                    </Grid>
                                </DataTemplate>

                            </ListBox.ItemTemplate>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Background="Transparent"/>

                                </ItemsPanelTemplate>

                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"></Setter>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"></Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                    </Border>
                </Expander>
                <Expander Header="打印配置" IsExpanded="True" FontSize="14" FontWeight="Normal" Margin="10 0" Padding="0 4">
                    <Border BorderThickness="1" Name="templeteBorder3" Margin="0 0" BorderBrush="#CCC" Background="AliceBlue"  HorizontalAlignment="Stretch" VerticalAlignment="Top">
                        <Grid Grid.Row="2" x:Name="grid3">
                            <Grid.RowDefinitions >
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Row="0" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                                <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                    <Label Style="{StaticResource FormLabelStyle_14}" Content="打印模式" Width="150" VerticalContentAlignment="Center" ></Label>
                                    <RadioButton Content="本地打印" IsChecked="{Binding IsLocalPrint}" VerticalContentAlignment="Center" Margin="10 0" IsEnabled="False"/>
                                    <RadioButton Content="远程打印" IsChecked="{Binding IsRemotePrint}" VerticalContentAlignment="Center" Margin="10 0" IsEnabled="False"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                    <Label Style="{StaticResource FormLabelStyle_14}" Content="打印机"  ></Label>
                                    <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding Printer}" Visibility="{Binding IsRemotePrint, Converter={StaticResource BoolToVisibilityConverter}}"></Label>
                                    <ComboBox x:Name="cbbPrinter" SelectedValue="{Binding Printer}" Width="250" VerticalContentAlignment="Center" FontSize="14" Margin="2" Visibility="{Binding IsLocalPrint, Converter={StaticResource BoolToVisibilityConverter}}"></ComboBox>

                                </StackPanel>
                            </Border>


                        </Grid>
                    </Border>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Border>

</UserControl>
