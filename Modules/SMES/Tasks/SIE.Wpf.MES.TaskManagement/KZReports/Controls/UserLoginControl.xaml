<UserControl x:Class="SIE.Wpf.MES.TaskManagement.KZReports.Controls.UserLoginControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.TaskManagement.KZReports.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary Source="/SIE.Wpf.MES.TaskManagement;component/Styles/ReportStyle.xaml"></ResourceDictionary>
        
    </UserControl.Resources>
    <Grid Background="White">
        <Grid.RowDefinitions >
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" >
            <StackPanel  Grid.Column="0" Orientation="Horizontal"  Margin="0" HorizontalAlignment="Left">
            </StackPanel>
        </Grid>
        <Grid Name="templeteGrid" Grid.Row="1" Margin="20 0">
            <StackPanel  Name="templeteBorder"  Orientation="Horizontal" HorizontalAlignment="Center">
                <!--<Label Content="{Binding OkQty}" Height="55" Width="50"></Label>-->
                <Label  Grid.Column="0"  Content="员工号" Height="55" HorizontalContentAlignment="Right" FontSize="22" VerticalContentAlignment="Center" Margin="5"></Label>
                <TextBox Name="txtUserName"  VerticalContentAlignment="Center" Grid.Column="1" Width="300" Height="55" KeyUp="txtUserName_KeyUp" Text="请输入员工号"  GotFocus="txtUserName_GotFocus" LostFocus="txtUserName_LostFocus" FontSize="22" Background="LightGreen" Margin="5" ></TextBox>
                <Button Grid.Column="2" Name="btnConfirmOk" Content="确认" Style="{StaticResource CommonButtonStyle}" Height="55" VerticalContentAlignment="Center" Foreground="White" Background="#2D8CF0" FontSize="22" Click="btnConfirmOk_Click" Margin="5" ></Button>
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="2" Margin="10 30"  Orientation="Horizontal" HorizontalAlignment="Left">
        </StackPanel>
    </Grid>

</UserControl>
