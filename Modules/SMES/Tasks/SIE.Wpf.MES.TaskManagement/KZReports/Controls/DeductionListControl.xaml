<UserControl x:Class="SIE.Wpf.MES.TaskManagement.KZReports.Controls.DeductionListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.TaskManagement.KZReports.Controls"
             xmlns:conv="clr-namespace:SIE.Wpf.MES.TaskManagement.KZReports.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary >
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SIE.Wpf.MES.TaskManagement;component/Styles/ReportStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:TaskStatusConverter x:Key="TaskStatusConverter"/>
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Height" Value="50"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate>
                            <Border Background="#E0E8EF" BorderThickness="0" BorderBrush="Black">
                                <TextBlock Text="{Binding}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="Black"
                               FontFamily="Times New Roman"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="DataGridRow">
                <Setter Property="BorderThickness" Value="0.5"/>
                <Setter Property="BorderBrush" Value="#e0e8eF"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value=" true">
                        <Setter Property="Background" Value="#F0F8FF"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="DataGridCell">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="BorderBrush" Value="#e0e8eF"/>
                <Setter Property="Height" Value="50"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value=" true">
                        <Setter Property="Background" Value="IndianRed"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border Background="White" MaxWidth="2500" VerticalAlignment="Stretch">

        <Grid Background="Transparent" Margin="30">
            <Grid.RowDefinitions >
                <RowDefinition MaxHeight="100"/>
                <RowDefinition Height="*"/>
                <!--<RowDefinition Height="200"/>-->
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0 0 0 0">
                <StackPanel  Grid.Column="0" Orientation="Horizontal"  Margin="0" HorizontalAlignment="Left">
                    <Button Name="btnBack" Content="返回" Style="{StaticResource CommonButtonStyle}" Width="120" Height="40" Margin="20 0 "  Click="btnBack_Click" Background="Gray" ></Button>
                    <Button Name="btnReset" Content="重新开始" Style="{StaticResource CommonButtonStyle}" Width="120" Height="40" Margin="20 0" Click="btnReStart_Click" Background="DeepSkyBlue" ></Button>
                    <Button Name="btnSubmit" Content="提交" Style="{StaticResource CommonButtonStyle}" Width="120" Height="40" Margin="20 0"   Click="btnSubmit_Click" Background="DeepSkyBlue"></Button>
                </StackPanel>
            </Grid>
            <Grid Name="templeteGrid" Grid.Row="1" Margin="20 0" VerticalAlignment="Top"  HorizontalAlignment="Stretch">
                <Border Grid.Row="0" Grid.Column="0"  BorderBrush="Gray" BorderThickness="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Top">
                    <DataGrid x:Name="dataGridRecord" MinHeight="500" BorderThickness="0" AutoGenerateColumns="False" FontSize="18" BorderBrush="#EEEEEE" Margin="0"
				   HorizontalAlignment="Stretch"   VerticalAlignment="Stretch"  CanUserSortColumns="True" IsReadOnly="True" SelectionMode="Single" GridLinesVisibility="None" MouseDoubleClick="dataGridRecord_MouseDoubleClick" >

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="RecordId" Visibility="Hidden" Binding="{Binding RecordId}" />
                            <!-- 复选框列使用模板列实现可编辑 -->
                            <DataGridTemplateColumn Header="选中">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <!-- 复选框启用编辑，绑定到IsSelected属性 -->
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                            </DataGridTemplateColumn>

                            <!--<DataGridCheckBoxColumn Header="选中" Binding="{Binding IsSelected}">
                            <DataGridCheckBoxColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridCheckBoxColumn.HeaderTemplate>
                        </DataGridCheckBoxColumn>-->
                            <DataGridTemplateColumn Header="物料标签"  MinWidth="180" >
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Sn}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Sn}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="物料编码" MinWidth="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ItemCode}" TextTrimming="CharacterEllipsis" ToolTip="{Binding ItemCode}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="标签批次" MinWidth="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ItemLabelLot}" TextTrimming="CharacterEllipsis" ToolTip="{Binding ItemLabelLot}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="上料时间" MinWidth="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FeedingTime}" TextTrimming="CharacterEllipsis" ToolTip="{Binding FeedingTime}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            

                            <DataGridTemplateColumn Header="物料描述"   Width="*" >
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ItemDesc}" TextTrimming="CharacterEllipsis" ToolTip="{Binding ItemDesc}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="物料总数"  Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Qty}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Qty}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="剩余数量"  Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RemainingQty}" TextTrimming="CharacterEllipsis" ToolTip="{Binding RemainingQty}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>


        </Grid>
    </Border>
</UserControl>
