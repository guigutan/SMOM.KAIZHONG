<UserControl x:Class="SIE.Wpf.MES.TaskManagement.KZReports.Controls.ReportMulitStationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.TaskManagement.KZReports.Controls"
             xmlns:conv="clr-namespace:SIE.Wpf.MES.TaskManagement.KZReports.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024">
    <UserControl.Resources>
        <ResourceDictionary >
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SIE.Wpf.MES.TaskManagement;component/Styles/ReportStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:IotStatusConverter x:Key="IotStatusConverter"/>
            <conv:TaskStatusConverter x:Key="TaskStatusConverter"/>
            <conv:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <conv:LengthToVisibilityConverter x:Key="LengthToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
    <Border Background="White">
        <Grid  Margin="5" Background="Transparent" MaxWidth="2500">
            <Grid.RowDefinitions >
                <!--<RowDefinition Height="auto"/>-->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid x:Name="topPanel" Grid.Row="0" Margin="0 0 0 0"  Background="Transparent">
                <StackPanel  Grid.Column="0" Orientation="Horizontal"  Margin="0" HorizontalAlignment="Left">
                    <Button Name="btnBack" Content="返回" Style="{StaticResource CommonButtonStyle}" Width="100" Height="40" FontSize="16" Margin="0 10 10 10"  Click="btnBack_Click" Background="Gray" ></Button>

                    <Button Content="全部开工" Style="{StaticResource CommonButtonStyle}" Background="DeepSkyBlue" Width="100" Height="40" FontSize="16" Margin="0" Name="btnStartWork" Click="btnStartWork_Click" ></Button>
                    <Button Content="全部暂停" Style="{StaticResource CommonButtonStyle}" Background="DeepSkyBlue" Width="100" Height="40" FontSize="16" Margin="10 0 0 0" Name="btnPauseWork" Click="btnPauseWork_Click" ></Button>
                    <Button Content="选择工位" Style="{StaticResource CommonButtonStyle}" Background="DeepSkyBlue" Width="100" Height="40" FontSize="16" Margin="10 0 0 0" x:Name="btnResource" Click="btnResource_Click" />
                    <Button Content="清除工位" Style="{StaticResource CommonButtonStyle}" Background="DeepSkyBlue" Width="100" Height="40" FontSize="16" Margin="10 0 0 0" x:Name="btnClearResource" Click="btnClearResource_Click" />
                    <Button Content="区域上料" Style="{StaticResource CommonButtonStyle}" Background="DeepSkyBlue" Width="100" Height="40" FontSize="16" Margin="10 0 0 0" x:Name="btnFeedingArea" Click="btnFeedingArea_Click" />
                </StackPanel>
                <StackPanel  Orientation="Horizontal" MinHeight="40" HorizontalAlignment="Right" VerticalAlignment="Center" >
                    <!--<Label Content="资源" FontSize="16" FontWeight="Bold" Foreground="Gray" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" Margin="5" ></Label>-->
                    <!--<Label Content="{Binding Resource.Name}" Name="lbResourceName" Foreground="Blue" Margin="0 0 0 0" MinWidth="80" Width="auto" MaxWidth="120" Height="40" FontSize="18" FontWeight="Bold" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" ></Label>-->
                    <!--<TextBox Text="{Binding Resource.Name}" TextWrapping="Wrap" Background="Transparent" BorderThickness="0" Foreground="Blue" Margin="0 0 0 0" MinWidth="60" MaxWidth="150" FontSize="16" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center" VerticalContentAlignment="Center" />-->

                    <Label Content="操作员:" FontSize="16" FontWeight="Bold" Foreground="Gray" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" Margin="5" ></Label>
                    <Label Content="{Binding ReportEmployee.Name}" Name="lbOparetorName" Foreground="Blue" Margin="0 0 0 0" MinWidth="60" Width="auto" Height="40" FontSize="16" FontWeight="Bold" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" ></Label>
                </StackPanel >
            </Grid>

            <Border x:Name="mainPanel" Grid.Row="1" Margin="0 0" BorderThickness="1" BorderBrush="#CCC" VerticalAlignment="Center" Background="Transparent">
                <ScrollViewer VerticalScrollBarVisibility="Auto" >
                    <ListBox x:Name="ctlMenu" Margin="0" ItemsSource="{Binding ReportViewModelList}" BorderThickness="0" MinHeight="100" HorizontalAlignment="Stretch" HorizontalContentAlignment ="Stretch" >
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <!--<StackPanel Orientation="Horizontal" Height="20"  Background="AntiqueWhite"/>-->

                                <Grid ShowGridLines="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"  Background="AliceBlue">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Row="0" Grid.Column="0" Margin="10" Padding="5" Height="auto"  x:Name="btnSelectResource" Click="btnSelectResource_Click"  Cursor="Hand" Tag="{Binding Id}" Content="{Binding MultipleResourceName}" FontSize="16" FontWeight="Bold" Style="{StaticResource CommonButtonStyle}" BorderThickness="1" BorderBrush="LightGray" Foreground="SaddleBrown" Background="Transparent" />

                                    <Border Grid.Row="1" Grid.Column="1" BorderThickness="1 1 1 1" BorderBrush="LightGray" Margin="0 10">
                                        <Grid  x:Name="grid1"  >
                                            <Grid.RowDefinitions >
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Row="0" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                                                <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                                    <Label Style="{StaticResource FormLabelStyle_14}" MaxWidth="120" Content="派工单号" Width="150" VerticalContentAlignment="Center" ></Label>
                                                    <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding DispatchTask.No}" ></Label>
                                                    <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding DispatchTask.TaskStatus, Converter={StaticResource TaskStatusConverter}}" Foreground="Red" ></Label>

                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Row="0" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                                    <Label Style="{StaticResource FormLabelStyle_14}" MaxWidth="120" Content="物料编码"   ></Label>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                                        <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding DispatchTask.ProductCode}" ></Label>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="1" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                                                <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                                    <Label Style="{StaticResource FormLabelStyle_14}" MaxWidth="120" Content="实际数/计划数" ></Label>
                                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch" MaxWidth="220" >

                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" MaxWidth="220" >
                                                            <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding DispatchTask.ActualReportQty}" Margin="5 0 0 0" Padding="0"></Label>
                                                            <Label Style="{StaticResource FormLabelStyle2_14}" Content="/" Margin="0" ></Label>
                                                            <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding DispatchTask.DispatchQty}" Margin="0" Padding="0"></Label>
                                                            <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding DispatchTask.UnitName}" ></Label>

                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" MaxWidth="220" >
                                                            <ProgressBar x:Name="progressBarReport" 
                                                             Maximum="{Binding DispatchTask.DispatchQty}"
                                                             MinHeight="15" MaxHeight="20" MinWidth="100" MaxWidth="220" Margin="5 5"
                                                             Foreground="LightGreen" Background="#eee"
                                                             HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                             Value="{Binding DispatchTask.ActualReportQty,Mode=OneWay}" />
                                                            <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding DispatchTask.ReportProgress}" Margin="0" Padding="0" ></Label>
                                                            <Label Style="{StaticResource FormLabelStyle2_14}" Content="%" Margin="0" Padding="0" ></Label>

                                                        </StackPanel>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Row="1" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                                    <Label Style="{StaticResource FormLabelStyle_14}" MaxWidth="120" Content="旧物料号"  ></Label>
                                                    <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding DispatchTask.ShortDescription}" ></Label>
                                                </StackPanel>                                                
                                            </Border>

                                            <Border Grid.Row="2" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                                    <Label Style="{StaticResource FormLabelStyle_14}" MaxWidth="120" Content="分单数量"  ></Label>
                                                    <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding Zcode}" ></Label>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Row="2" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                                                <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                                    <Label Style="{StaticResource FormLabelStyle_14}" MaxWidth="120" Content="设备产出数"  ></Label>
                                                    <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding DispatchTask.IotQty}" Foreground="Red" Width="100"></Label>
                                                    <!--<Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding DispatchTask.IotStatus, Converter={StaticResource IotStatusConverter}}" Foreground="Red"></Label>-->

                                                    <ProgressBar x:Name="progressBar" MinWidth="100" MaxWidth="200" MinHeight="15" MaxHeight="20" Margin="20 0" IsIndeterminate="True"  HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="{Binding IsShowLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                                </StackPanel>
                                            </Border>
                                            <TextBox Grid.Row="3" Grid.ColumnSpan="2" Margin="5" TextWrapping="Wrap" HorizontalAlignment="Left" Background="Transparent" BorderThickness="0" Text="{Binding Error}" FontSize="14" Foreground="Red" Visibility="{Binding Error, Converter={StaticResource LengthToVisibilityConverter}}"/>
                                        </Grid>
                                    </Border>
                                    <Button Grid.Row="0" Grid.Column="2" Margin="10" Height="auto"  x:Name="btnOperation" Click="btnOperation_Click" Cursor="Hand" Tag="{Binding Id}" Content="操作" FontSize="26" Style="{StaticResource CommonButtonStyle}" Background="LightGreen" Foreground="Black" />

                                </Grid>
                            </DataTemplate>

                        </ListBox.ItemTemplate>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Background="Transparent"/>

                            </ItemsPanelTemplate>

                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalAlignment" Value="Stretch"></Setter>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"></Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </ScrollViewer>
            </Border>

            <Border x:Name="bottomPanel" Grid.Row="2" Margin="0,10,0,10"  HorizontalAlignment="Stretch" Background="Transparent" >

            </Border>
        </Grid>
    </Border>
</UserControl>
