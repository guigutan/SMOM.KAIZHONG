<UserControl x:Class="SIE.Wpf.MES.TaskManagement.KZReports.Controls.ResourceListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.TaskManagement.KZReports.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary Source="/SIE.Wpf.MES.TaskManagement;component/Styles/ReportStyle.xaml"></ResourceDictionary>

    </UserControl.Resources>
    <Border Background="White" MaxWidth="2500" VerticalAlignment="Stretch">

        <Grid Background="Transparent" Margin="30">
            <Grid.RowDefinitions >
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" >
                <StackPanel  Grid.Column="0" Orientation="Horizontal"  Margin="20" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Label Content="请选择报工资源:" FontSize="20" Margin="0 0" HorizontalAlignment="Left"/>
                </StackPanel>
                <StackPanel  Grid.Column="0" Orientation="Horizontal"  Margin="180,20" HorizontalAlignment="Left" VerticalAlignment="Center" Width="302" >
                    <TextBox x:Name="scanTxt" Text=""  IsReadOnly ="False"  Focusable="True" BorderThickness="0.5"  VerticalContentAlignment="Center" Background="LightGreen" Height="40" FontSize="16"  Margin="1" Width="300" KeyDown="scanTxt_KeyDown" Cursor="ScrollNW"/>
                </StackPanel>
                <StackPanel  Grid.Column="0" Orientation="Horizontal"  Margin="20" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <CheckBox x:Name="cbShowAll" Content="显示全部资源" FontSize="14" HorizontalAlignment="Right" Checked="CheckBox_Checked" Unchecked="CheckBox_Unchecked"/>
                </StackPanel>
            </Grid>
            <Grid Name="templeteGrid" Grid.Row="1" Margin="0 0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Grid.Row="0" Grid.Column="0" BorderBrush="Gray" BorderThickness="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center">

                        <ItemsControl x:Name="ctlMenu" Margin="0" ItemsSource="{Binding ResourceList}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="10" Height="80" MinWidth="200" MaxWidth="250"
                                    x:Name="btnMenu"
                                    Click="btnMenu_Click"
                                    Cursor="Hand"
                                    Tag="{Binding Id}"
                                    Content="{Binding Name}" FontSize="16"
                                    Style="{StaticResource CommonButtonStyle}" >

                                    </Button>

                                </DataTemplate>

                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True" />
                                </ItemsPanelTemplate>

                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Border>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Border>
</UserControl>
