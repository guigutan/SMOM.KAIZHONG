<UserControl x:Class="SIE.Wpf.MES.TaskManagement.KZReports.Controls.ReportProcessControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.TaskManagement.KZReports.Controls"
             xmlns:conv="clr-namespace:SIE.Wpf.MES.TaskManagement.KZReports.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="1024">
    <UserControl.Resources>
        <ResourceDictionary >
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SIE.Wpf.MES.TaskManagement;component/Styles/ReportStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:IotStatusConverter x:Key="IotStatusConverter"/>
            <conv:TaskStatusConverter x:Key="TaskStatusConverter"/>
            <conv:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

            <Style TargetType="DataGridRow">
                <Setter Property="BorderThickness" Value="0.5"/>
                <Setter Property="BorderBrush" Value="#e0e8eF"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value=" true">
                        <Setter Property="Background" Value="#F0F8FF"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="DataGridCell">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="BorderBrush" Value="#e0e8eF"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected}" Value=" true">
                        <Setter Property="Background" Value="LightGreen"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <!--<Setter Property="FontWeight" Value="Normal"/>-->
                    </DataTrigger>
                    <Trigger Property="IsSelected" Value=" true">
                        <Setter Property="Background" Value="#e0e8eF"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <!--<Setter Property="FontWeight" Value="Normal"/>-->
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border Background="White">
        <DockPanel x:Name ="dockPanel" MaxWidth="2500" Margin="50 30">

            <Border DockPanel.Dock="Bottom" x:Name="bottomPanel" Grid.Row="2" Margin="0,0,0,10"  HorizontalAlignment="Stretch" Background="Transparent" >
                <Grid ShowGridLines="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="派工任务" Style="{StaticResource CommonButtonStyle}" MinWidth="100" Height="50" Margin="10" Name="btnSelectTask" Click="btnSelectTask_Click"></Button>
                    <Button Grid.Column="1" Content="扫码报工" Style="{StaticResource CommonButtonStyle}" MinWidth="100" Height="50" Margin="10" Name="btnScanReport" Click="btnScanReport_Click" ></Button>
                    <Button Grid.Column="2" Content="开机准备" Style="{StaticResource CommonButtonStyle}" MinWidth="100" Height="50" Margin="10" Name="btnStartPreparation" Click="btnStartPreparation_Click" ></Button>
                    <Button Grid.Column="3" Content="上料" Style="{StaticResource CommonButtonStyle}" MinWidth="100" Height="50" Margin="10" Name="btnFeeding" Click="btnFeeding_Click" ></Button>
                    <Button Grid.Column="4" Content="下料" Style="{StaticResource CommonButtonStyle}" MinWidth="100" Height="50" Margin="10" Name="btnDeduction" Click="btnDeduction_Click" ></Button>
                    <Button Grid.Column="5" Content="余料称重" Style="{StaticResource CommonButtonStyle}" MinWidth="100" Height="50" Margin="10" Name="btnSWRecordScan" Click="SWRecordScan_Click" ></Button>
                </Grid>
            </Border>
            <Grid  >
                <Grid.RowDefinitions >
                    <!--<RowDefinition Height="auto"/>-->
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>

                </Grid.RowDefinitions>
                <!--<ctl:XPTitle Grid.Row="0" x:Name="xpTitle" AType="Default" AShowWinTitle="False" ATitle="报工主界面"></ctl:XPTitle>-->
                <Grid Grid.Row="0" Margin="0 0 0 0">
                    <StackPanel  Grid.Column="0" Orientation="Horizontal"  Margin="0" HorizontalAlignment="Left">
                        <Button Content="返回" Style="{StaticResource CommonButtonStyle}" Width="100" Height="40" FontSize="16" Margin="0 10 10 10" Name="btnBack"  Click="btnBack_Click" Background="Gray" ></Button>
                        <Button Content="开工" Style="{StaticResource CommonButtonStyle}" Background="DeepSkyBlue" Width="100" Height="40" FontSize="16" Margin="10" Name="btnStartWork" Click="btnStartWork_Click" ></Button>
                        <Button Content="切换资源" Style="{StaticResource CommonButtonStyle}" Background="DeepSkyBlue" Width="100" Height="40" FontSize="16" Margin="10" x:Name="btnResource" Click="btnResource_Click" />
                        <Button Content="称重" Style="{StaticResource CommonButtonStyle}" Background="DeepSkyBlue" Width="100" Height="40" FontSize="16" Margin="10" x:Name="Weighing" Click="btnWeighing_Click" />
                        <Button Content="任务列表" Style="{StaticResource CommonButtonStyle}" Background="DeepSkyBlue" Width="100" Height="40" FontSize="16" Margin="10 0 0 0" x:Name="taskList" Click="taskList_Click" />
                        <!--<Button Name="btnReset" Content="重新开始" Style="{StaticResource CommonButtonStyle}" Width="120" Height="40" Margin="10" Click="btnReset_Click" Background="DeepSkyBlue" ></Button>
                        <Button Name="btnSubmit" Content="提交" Style="{StaticResource CommonButtonStyle}" Width="120" Height="40" Margin="10"   Click="btnSubmit_Click" Background="DeepSkyBlue"></Button>-->
                        <!--<Button Name="btnTaskList" Content="任务列表" Style="{StaticResource CommonButtonStyle}" Width="120" Height="40" Margin="10"   Click="btnTaskList_Click" Background="DeepSkyBlue"></Button>-->
                    </StackPanel>
                    <StackPanel  Orientation="Horizontal" MinHeight="40" HorizontalAlignment="Right" VerticalAlignment="Center" >
                        <Label Content="资源" FontSize="16" FontWeight="Bold" Foreground="Gray" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" Margin="5" ></Label>
                        <!--<Label Content="{Binding Resource.Name}" Name="lbResourceName" Foreground="Blue" Margin="0 0 0 0" MinWidth="80" Width="auto" MaxWidth="120" Height="40" FontSize="18" FontWeight="Bold" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" ></Label>-->
                        <TextBox Text="{Binding Resource.Name}" TextWrapping="Wrap" Background="Transparent" BorderThickness="0" Foreground="Blue" Margin="0 0 0 0" MinWidth="60" MaxWidth="150" FontSize="16" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center" VerticalContentAlignment="Center" />
                        <Label Content="工序" FontSize="16" FontWeight="Bold" Foreground="Gray" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" Margin="5" ></Label>
                        <!--<Label Content="{Binding Resource.Name}" Name="lbResourceName" Foreground="Blue" Margin="0 0 0 0" MinWidth="80" Width="auto" MaxWidth="120" Height="40" FontSize="18" FontWeight="Bold" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" ></Label>-->
                        <TextBox Text="{Binding Process.Name}" TextWrapping="Wrap" Background="Transparent" BorderThickness="0" Foreground="Blue" Margin="0 0 0 0" MinWidth="60" MaxWidth="150" FontSize="16" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center" VerticalContentAlignment="Center" />

                        <Label Content="操作员:" FontSize="16" FontWeight="Bold" Foreground="Gray" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" Margin="5" ></Label>
                        <Label Content="{Binding ReportEmployee.Name}" Name="lbOparetorName" Foreground="Blue" Margin="0 0 0 0" MinWidth="60" Width="auto" Height="40" FontSize="16" FontWeight="Bold" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" ></Label>
                    </StackPanel >
                </Grid>
                <Border Grid.Row="1" Margin="0 0 0 0" BorderThickness="1" BorderBrush="#ccc">
                    <Grid >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <Label Grid.Column="0" Style="{StaticResource FormLabelStyle_18}" Content="工序标签" HorizontalContentAlignment="Center" Height="40"></Label>
                        <TextBox Grid.Column="1" x:Name="txtBarcode" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" Text="{Binding Path=Barcode, Mode=TwoWay}" FontSize="16" Background="LightGreen" Margin="2" KeyUp="txtBarcode_KeyUp"></TextBox>
                        <StackPanel Grid.Column="2" Margin="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"  >
                            <RadioButton x:Name="radioBtnTurnIn" Content="加入" FontSize="16" Width="80" Margin="20 8 0 8" IsChecked="True"></RadioButton>
                            <RadioButton x:Name="radioBtnRemove" Content="移除" FontSize="16" Width="80" Margin="0 8 0 8"></RadioButton>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.ColumnSpan="3">
                            <TextBox x:Name="txtTip" Text="提示信息" IsReadOnly="True" Focusable="False" BorderThickness="0.5" Foreground="Red" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" Height="40" FontSize="16" Background="White" Margin="1" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border x:Name="templateBorder" Grid.Row="2" Margin="0 5" BorderThickness="1" BorderBrush="#CCC" VerticalAlignment="Top">
                    <Grid Grid.Row="2" >
                        <Grid.RowDefinitions >
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="40"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Row="0" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                            <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_14}" Content="工序标签"  ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding WipBatchQueue.BatchNo}" ></Label>
                                <!--<Label Style="{StaticResource FormLabelStyle_14}" Content="派工单号" Width="150" VerticalContentAlignment="Center" ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding DispatchTask.No}" ></Label>-->
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_14}" Content="标签数量"  ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding WipBatchQueue.BatchQty}" ></Label>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="2" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_14}" Content="产线"  ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding Resource.Name}" ></Label>
                                <!--<Label Style="{StaticResource FormLabelStyle_14}" Content="任务单/工单剩余数"></Label>
                                <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding MaxRemainQty}" ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_14}" Content="/" Margin="0" ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding ProcessMaxRemainQty}"></Label>-->
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                            <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_14}" Content="工单号"  ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding WipBatchQueue.WorkOrderNo}" ></Label>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                            <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_14}" Content="设备产出数"  ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding WipBatchQueue.IotQty}" Foreground="Red"></Label>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="2" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_14}" Content="IOT设备状态"  ></Label>
                                <!--<Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding DispatchTask.IotStatus, Converter={StaticResource IotStatusConverter}}" Foreground="Red"></Label>-->
                                <ProgressBar x:Name="progressBar" Width="100" MinHeight="15" MaxHeight="20" Margin="5 10" IsIndeterminate="True" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding IsShowLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="0" BorderThickness="0 0 0 1" BorderBrush="#CCC">
                            <StackPanel  Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_14}" Content="良品数"  ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding OkQty}" ></Label>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="2" Grid.Column="1" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_14}" Content="可疑品数"  ></Label>
                                <!--<Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding SuspectQty}" ></Label>-->
                                <TextBox x:Name="txtSuspectQty" VerticalContentAlignment="Center" MinWidth="120" Height="auto" Text="{Binding SuspectQty}"  FontSize="16" Background="Yellow" Margin="2"  Focusable="False"></TextBox>
                                <Button x:Name="btnSuspectQty" Content="C" MinWidth="40" Margin="2"  Click="btnSuspectQty_Click" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="2" BorderThickness="1 0 0 1" BorderBrush="#CCC">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                                <Label Style="{StaticResource FormLabelStyle_14}" Content="分单数量"  ></Label>
                                <Label Style="{StaticResource FormLabelStyle2_14}" Content="{Binding Zcode}" ></Label>
                            </StackPanel>
                        </Border>

                    </Grid>
                </Border>

                <TabControl Grid.Row="3" Margin="0 0" FontSize="18" >
                    <TabItem Header="标签明细" >
                        <DataGrid x:Name="dataGrid" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="None" ItemsSource="{Binding WipBatchQueueList}" >
                            <DataGrid.Columns>

                                <DataGridTemplateColumn Header="序号"  Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Seq}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="工序标签"  Width="250">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding BatchNo}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="数量"  Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding BatchQty}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </Grid>

        </DockPanel>
    </Border>
</UserControl>
