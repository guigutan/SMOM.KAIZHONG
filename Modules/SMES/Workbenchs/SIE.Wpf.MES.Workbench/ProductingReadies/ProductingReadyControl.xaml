<sd:ComponentItem x:Class="SIE.Wpf.MES.Workbench.ProductingReadies.ProductingReadyControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
             xmlns:local="clr-namespace:SIE.Wpf.MES.Workbench.ProductingReadies"
              xmlns:local1="clr-namespace:SIE.MES.Workbench.ProductingReadies;assembly=SIE.MES"
             xmlns:dxg ="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             sd:DiagramDesigner.ToolBarTitle="{Binding [生产-产前准备], Source={uic:L10N}}"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <sd:ComponentItem.Resources>
        <Style x:Key="HeadStyle" TargetType="{x:Type dxg:GridColumnHeader}">
            <Setter Property="Foreground" Value="#2895F0"/>
            <Setter Property="Background" Value="#E9F5FF"></Setter>
            <Setter Property="Height" Value="30"></Setter>
            <Setter Property="BorderBrush" Value="#E9F5FF"></Setter>
        </Style>
        <Style x:Key="CelStyle" TargetType="{x:Type dxg:LightweightCellEditor}">
            <Setter Property="Height" Value="30"></Setter>
        </Style>
        <Style  TargetType="{x:Type dxg:GridColumn}">
            <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
            <Setter Property="HeaderStyle" Value="{StaticResource HeadStyle}"></Setter>
            <Setter Property="CellStyle" Value="{StaticResource CelStyle}"></Setter>
            <Setter Property="EditSettings">
                <Setter.Value>
                    <dxe:TextEditSettings HorizontalContentAlignment="Center"   />
                </Setter.Value>
            </Setter>
        </Style>
    </sd:ComponentItem.Resources>
    <Grid>
        <dxg:GridControl Name="ctlProductReady" ShowBorder="False" AllowInitiallyFocusedRow="False" Width="Auto" AutoGenerateColumns="None" EnableSmartColumnsGeneration="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <dxg:GridControl.GroupSummary>
                <dxg:GridSummaryItem SummaryType="Count" />
            </dxg:GridControl.GroupSummary>
            <dxg:GridControl.View>
                <dxg:TableView AllowEditing="False" ShowGroupPanel="False"   ShowHorizontalLines="False" ShowVerticalLines="False" VerticalScrollbarVisibility="Auto"  AutoWidth="True"   ShowIndicator="False">
                    <!--<dxg:TableView.FormatConditions>
                        <dxg:FormatCondition FieldName="ItemState" ApplyToRow="False" ValueRule="Equal" Value1="NG" >
                            <dxg:FormatCondition.Format >
                                <dxg:Format Foreground="#E33043"></dxg:Format>
                            </dxg:FormatCondition.Format>
                        </dxg:FormatCondition>
                        <dxg:FormatCondition FieldName="ItemState" ApplyToRow="False" ValueRule="Equal" Value1="OK" >
                            <dxg:FormatCondition.Format >
                                <dxg:Format Foreground="#201F35"></dxg:Format>
                            </dxg:FormatCondition.Format>
                        </dxg:FormatCondition>
                    </dxg:TableView.FormatConditions>-->
                </dxg:TableView>
            </dxg:GridControl.View>
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="LineName" Header="{Binding [班组/线别], Source={uic:L10N}}" />
                <dxg:GridColumn FieldName="WorkOrderNo" Header="{Binding [工单号], Source={uic:L10N}}" />
                <dxg:GridColumn FieldName="ItemCode" Header="{Binding [物料编码], Source={uic:L10N}}" />
                <dxg:GridColumn FieldName="ProductQty" Header="{Binding [生产数量], Source={uic:L10N}}" />
                <dxg:GridColumn FieldName="ItemState" Header="{Binding [物料], Source={uic:L10N}}" />
                <dxg:GridColumn FieldName="ItemState" Header="{Binding [工具], Source={uic:L10N}}" />
                <dxg:GridColumn FieldName="PersonnelState" Header="{Binding [人员], Source={uic:L10N}}" />
                <dxg:GridColumn FieldName="EsopState" Header="{Binding [ESOP], Source={uic:L10N}}" />
                <dxg:GridColumn FieldName="QualityState"  Header="{Binding [品质预防], Source={uic:L10N}}" />

            </dxg:GridControl.Columns>
            <dxg:GridControl.TotalSummary>
                <dxg:GridSummaryItem SummaryType="Count" Alignment="Right"/>
                <dxg:GridSummaryItem FieldName="FullName" SummaryType="Count"/>
            </dxg:GridControl.TotalSummary>
         
        </dxg:GridControl>
    </Grid>
</sd:ComponentItem>
