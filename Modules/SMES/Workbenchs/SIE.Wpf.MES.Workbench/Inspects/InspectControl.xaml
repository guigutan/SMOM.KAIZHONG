<sd:ComponentItem x:Class="SIE.Wpf.MES.Workbench.Inspects.InspectControl"
                  xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core" 
                  xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors" 
                  xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol" 
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.Workbench.Inspects"
             xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
             xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
        xmlns:dxet="http://schemas.devexpress.com/winfx/2008/xaml/editors/themekeys"
             xmlns:converter="clr-namespace:SIE.Wpf.MES.Workbench.Converters"
             sd:DiagramDesigner.ToolBarTitle="{Binding [生产-生产采集检验], Source={uic:L10N}}"
            sd:DiagramDesigner.DefaultSize="1094,212"     
             mc:Ignorable="d" Width="1094" Height="212">
    <sd:ComponentItem.Resources>
        <Style x:Key="labelStyle" TargetType="Label">
            <Setter Property="FontSize" Value="12"></Setter>
            <Setter Property="Foreground" Value="Black"></Setter>
        </Style>
        <ControlTemplate x:Key="{dxet:ProgressBarEditThemeKey ResourceKey=PanelLeftSideHorizontalTemplate, IsThemeIndependent=True}" TargetType="{x:Type ContentControl}">
            <Grid> 
                <Rectangle x:Name="Background" Grid.RowSpan="2" Grid.ColumnSpan="2" Opacity="1" Fill="#5BB65E"/> 
            </Grid>
        </ControlTemplate>
    </sd:ComponentItem.Resources>
    <dxlc:GroupBox Padding="-2">
        <dxlc:GroupBox.Header>
            <Label Height="36" FontSize="18" VerticalContentAlignment="Center">
                <TextBlock Name="lblTitle" Text="{Binding [检验采集],Source={uic:L10N}}"/>
            </Label>
        </dxlc:GroupBox.Header>
        <Grid Margin="5" Background="#F1F5FF" Name="ctlInspect">
            <Grid.Resources>
                <Style x:Key="toggleStyle" TargetType="ToggleButton">
                    <Setter Property="Opacity" Value="0.5"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ToggleButton}">
                                <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                                    <Grid x:Name="grid">
                                        <ContentPresenter  x:Name="contentPresenter" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="ToggleButton.IsChecked" Value="True">
                                        <Setter Property="Opacity" Value="1"/> 
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="*" MinWidth="80"/>
            </Grid.ColumnDefinitions>
            <Label Grid.ColumnSpan="2" Content="{Binding Tips}" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="16" MinHeight="30" Foreground="#128BEF" Margin="5,0,0,0"></Label>
            <dxe:TextEdit Grid.Row="1" BorderBrush="#6FE7CF" Background="#DFFAF5" FontSize="28" Text="{Binding Barcode}" KeyDown="Barcode_KeyDown" Focusable="True" Margin="5,0,0,0"></dxe:TextEdit>
            <ToggleButton Grid.Row="1" Grid.Column="1" Margin="5,0,5,0" Content="{Binding [缺陷录入],Source={uic:L10N}}" Foreground="White" FontSize="16" Background="#128bef" IsChecked="{Binding HasDefect}" Style="{StaticResource toggleStyle}"></ToggleButton>
            <Label Grid.Row="2" Content="{Binding [消息提示],Source={uic:L10N}}" VerticalAlignment="Bottom" FontSize="12" Foreground="#666666" Margin="5,0,0,0"></Label>
            <Label Grid.Row="2" Grid.Column="1" Content="{Binding [任务进度],Source={uic:L10N}}" VerticalAlignment="Bottom" Margin="5,0,0,0"></Label>
            <dxe:TextEdit Grid.Row="3"  Foreground="Red" Background="#F0F0F0" Text="{Binding Error}" IsReadOnly="True" FontSize="16" Margin="5,0,0,0"></dxe:TextEdit>
            <dxe:ProgressBarEdit Grid.Row="3" Grid.Column="1" Margin="5,0,5,0" ContentDisplayMode="Content" HorizontalContentAlignment="Left" Background="#5BB65E" Foreground="White" FontSize="14" Value="{Binding Percent}" Content="{Binding Progress}" Minimum="0" Maximum="{Binding WorkOrder.PlanQty}"></dxe:ProgressBarEdit> 
            <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5">
                <Grid.Resources>
                    <Style x:Key="{x:Type Label}" TargetType="Label">
                        <Setter Property="FontSize" Value="12"></Setter>
                        <Setter Property="Foreground" Value="#128BEF"></Setter>
                        <Setter Property="FontFamily" Value="MicrosoftYaHei"></Setter>
                        <Setter Property="FontWeight" Value="400"></Setter>
                    </Style>
                </Grid.Resources>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>
                <Label Content="{Binding [工单号:],Source={uic:L10N}}" Foreground="#666666"></Label>
                <Label Grid.Column="1" Content="{Binding WorkOrder.No}" Margin="5,0,0,0"></Label>
                <Label Grid.Column="2" Margin="5,0,0,0" Content="{Binding [产品型号:],Source={uic:L10N}}" Foreground="#666666"></Label>
                <Label Grid.Column="3" Content="{Binding WorkOrder.Product.Model.Name}"  Margin="5,0,0,0"></Label>
                <Label Grid.Column="4" Margin="5,0,0,0" Content="{Binding [产品名称:],Source={uic:L10N}}" Foreground="#666666"></Label>
                <Label Grid.Column="5" Content="{Binding WorkOrder.Product.Name}" Margin="5,0,0,0"></Label>
            </Grid>
        </Grid>
    </dxlc:GroupBox>
</sd:ComponentItem>
