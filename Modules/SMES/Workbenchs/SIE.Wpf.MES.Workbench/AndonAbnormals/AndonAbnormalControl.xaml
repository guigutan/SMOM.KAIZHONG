<sd:ComponentItem x:Class="SIE.Wpf.MES.Workbench.AndonAbnormals.AndonAbnormalControl"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                  xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                  xmlns:local="clr-namespace:SIE.Wpf.MES.Workbench.AndonAbnormals"
                  xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
                  xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                  xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
                  xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
                  xmlns:ui="http://schemas.siestudio.com/winfx/xaml/controls"
                  xmlns:icon="clr-namespace:Resources.IconPacks;assembly=Resources"
                  xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                  sd:DiagramDesigner.ToolBarTitle="{Binding [生产-安灯异常], Source={uic:L10N}}"
                  sd:DiagramDesigner.DefaultSize="1000,300"
                  mc:Ignorable="d" >
    <sd:ComponentItem.Resources>
        <Style x:Key="HeadStyle" TargetType="{x:Type dxg:GridColumnHeader}">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="#E9F5FF"></Setter>
            <Setter Property="Height" Value="30"></Setter>
            <Setter Property="BorderBrush" Value="#E9F5FF"></Setter>
        </Style>
        <Style x:Key="CelStyle" TargetType="{x:Type dxg:LightweightCellEditor}">
            <Setter Property="Height" Value="50"></Setter>
        </Style>
        <Style  TargetType="{x:Type dxg:GridColumn}">
            <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
            <Setter Property="HeaderStyle" Value="{StaticResource HeadStyle}"></Setter>
            <Setter Property="CellStyle" Value="{StaticResource CelStyle}"></Setter>
            <Setter Property="EditSettings">
                <Setter.Value>
                    <dxe:TextEditSettings HorizontalContentAlignment="Center"   />
                </Setter.Value>
            </Setter>
        </Style>
    </sd:ComponentItem.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.3*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Row="0" Grid.Column="0" BorderThickness="0">
            <dxg:GridControl Name="gcAndonList" AllowInitiallyFocusedRow="False" MaxHeight="300"   Margin="0,0,0,0" ShowBorder="False" ItemsSource="{Binding Source}" BorderThickness="0" >
                <dxg:GridControl.View>
                    <dxg:TableView AllowEditing="False" AutoWidth="True" ShowGroupPanel="False" AllowCellMerge="False" ShowHorizontalLines="False"  ShowVerticalLines="False" ShowIndicator="False" VerticalScrollbarVisibility="Auto"/>
                    <!--<dxg:TableView AllowEditing="False" ShowGroupPanel="False" AllowCellMerge="False" ShowHorizontalLines="False"  ShowVerticalLines="False" ShowIndicator="False" VerticalScrollbarVisibility="Auto" />-->
                </dxg:GridControl.View>
                <dxg:GridControl.Columns>
                    <dxg:GridColumn Header="班组/线别" FieldName="ProductLineName" HorizontalHeaderContentAlignment="Center" Width="60"></dxg:GridColumn>
                    <dxg:GridColumn Header="异常类型" FieldName="ExceptionType" HorizontalHeaderContentAlignment="Center" Width="80"></dxg:GridColumn>
                    <dxg:GridColumn Header="呼叫时间" Width="125" HorizontalHeaderContentAlignment="Center">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <icon:PackIcon Kind="Phone"  Height="15" Width="15" Background="Transparent" HorizontalAlignment="Center" 
                                                   Foreground="{Binding RowData.Row.ProcessStatus, Converter={ local:AndonAbnormalViewForegroundConverters}, ConverterParameter=CallTime, Mode=OneWay}">
                                    </icon:PackIcon>
                                    <Label  Content="{Binding RowData.Row.CallTime}" HorizontalContentAlignment="Center" Margin="0,0,0,0" 
                                            Foreground="{Binding RowData.Row.ProcessStatus, Converter={local:AndonAbnormalViewForegroundConverters}, ConverterParameter=CallTime, Mode=OneWay}"/>
                                </StackPanel>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Header="处理人" FieldName="ProcesserName" Width="60" HorizontalHeaderContentAlignment="Center">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <icon:PackIcon Kind="Person"  Height="15" Width="15" Background="Transparent" HorizontalAlignment="Center" 
                                                   Visibility="{Binding RowData.Row.ProcesserName, Converter={local:AndonAbnormalViewVisibleConverters}, Mode=OneWay}"
                                                   Foreground="{Binding RowData.Row.ProcessStatus, Converter={local:AndonAbnormalViewForegroundConverters}, ConverterParameter=ProcesserName, Mode=OneWay}">
                                    </icon:PackIcon>
                                    <Label Content="{Binding RowData.Row.ProcesserName}" HorizontalContentAlignment="Center" Margin="0,0,0,0" 
                                           Foreground="{Binding RowData.Row.ProcessStatus, Converter={local:AndonAbnormalViewForegroundConverters}, ConverterParameter=ProcesserName, Mode=OneWay}">
                                    </Label>
                                </StackPanel>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Header="签到时间" FieldName="SignTime" Width="125" HorizontalHeaderContentAlignment="Center">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel  Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <icon:PackIcon Kind="ChartTimeline"  Height="15" Width="15" Background="Transparent" HorizontalAlignment="Center" 
                                                   Visibility="{Binding RowData.Row.SignTime, Converter={local:AndonAbnormalViewVisibleConverters}, Mode=OneWay}"
                                                   Foreground="{Binding RowData.Row.ProcessStatus, Converter={local:AndonAbnormalViewForegroundConverters}, ConverterParameter=SignTime, Mode=OneWay}" >
                                    </icon:PackIcon>
                                    <Label Content="{Binding RowData.Row.SignTime}" HorizontalContentAlignment="Center" Margin="0,0,0,0" 
                                           Foreground="{Binding RowData.Row.ProcessStatus, Converter={local:AndonAbnormalViewForegroundConverters}, ConverterParameter=SignTime, Mode=OneWay}">
                                    </Label>
                                </StackPanel>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn  Header="状态" FieldName="ProcessStatus"  HorizontalHeaderContentAlignment="Center" Width="60">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel  Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <icon:PackIcon Height="15" Width="15" Background="Transparent" HorizontalAlignment="Center" 
                                                   Visibility="{Binding RowData.Row.ProcessStatus, Converter={local:AndonAbnormalViewVisibleConverters}, Mode=OneWay}" 
                                                   Foreground="{Binding RowData.Row.ProcessStatus, Converter={local:AndonAbnormalViewForegroundConverters}, ConverterParameter=ProcessStatus, Mode=OneWay}"
                                                   Kind="{Binding RowData.Row.ProcessStatus, Converter={local:AndonAbnormalViewPackIconConverters}, Mode=OneWay}">
                                    </icon:PackIcon>
                                    <Label Content="{Binding RowData.Row.ProcessStatus}" HorizontalContentAlignment="Center" Margin="0,0,0,0" 
                                           Foreground="{Binding RowData.Row.ProcessStatus, Converter={local:AndonAbnormalViewForegroundConverters}, ConverterParameter=ProcessStatus, Mode=OneWay}"></Label>
                                </StackPanel>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControl.Columns>
            </dxg:GridControl>
        </Border>

        <Border Grid.Row="0" Grid.Column="1">
            <Grid Name="gdAndonChart" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="300"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Row="0" Grid.Column="0" BorderThickness="0">
                    <dxc:ChartControl x:Name="todayExcepPublishChart" BorderThickness="0">
                        <dxc:ChartControl.Titles>
                            <dxc:Title x:Name="todayExcepPublishTitle" FontSize="10" Content="{Binding [今日异常分布], Source={uic:L10N}}" HorizontalAlignment="Left" VerticalAlignment="Center" Width="60" Height="15"  FontWeight="Bold" />
                        </dxc:ChartControl.Titles>
                        <dxc:ChartControl.CrosshairOptions>
                            <dxc:CrosshairOptions ShowArgumentLine="True" CrosshairLabelMode="ShowForNearestSeries" />
                        </dxc:ChartControl.CrosshairOptions>

                        <dxc:ChartControl.Diagram>
                            <dxc:XYDiagram2D  Margin="5,5,5,10"  Name="todayExcepPublishGram" Rotated="True" SeriesDataMember="Series" EnableAxisXNavigation="False" BorderThickness="0">
                                <dxc:XYDiagram2D.AxisX>
                                    <dxc:AxisX2D x:Name="todayExcepPublishAxisX" TickmarksMinorVisible="False"
                                                 GridLinesMinorVisible="False" GridLinesVisible="False" >
                                        <dxc:AxisX2D.CrosshairAxisLabelOptions>
                                            <dxc:CrosshairAxisLabelOptions/>
                                        </dxc:AxisX2D.CrosshairAxisLabelOptions>
                                        <dxc:AxisX2D.Label>
                                            <dxc:AxisLabel Background="Transparent" BorderBrush="#FF343246" Padding="0,1" FontSize="12" Angle="90" />
                                        </dxc:AxisX2D.Label>
                                    </dxc:AxisX2D>
                                </dxc:XYDiagram2D.AxisX>

                                <dxc:XYDiagram2D.AxisY>
                                    <dxc:AxisY2D x:Name="todayExcepPublishAxisY"  GridLinesMinorVisible="False" GridLinesVisible="False"
                                                 TickmarksMinorVisible="True" Interlaced="False">
                                        <dxc:AxisY2D.VisualRange>
                                            <dxc:Range MinValue="0" MaxValue="5" SideMarginsValue="0" />
                                        </dxc:AxisY2D.VisualRange>
                                        <dxc:AxisY2D.WholeRange>
                                            <dxc:Range MinValue="0" MaxValue="5" SideMarginsValue="0" />
                                        </dxc:AxisY2D.WholeRange>
                                        <dxc:AxisY2D.Label>
                                            <dxc:AxisLabel Background="Transparent" BorderBrush="#FF343246" Padding="0,1"  FontSize="12" />
                                        </dxc:AxisY2D.Label>
                                    </dxc:AxisY2D>
                                </dxc:XYDiagram2D.AxisY>

                                <dxc:XYDiagram2D.Series>
                                    <dxc:BarSideBySideSeries2D x:Name="todayExcepPublishSerie"  CrosshairLabelPattern="{}{A}: {V}" ArgumentScaleType="Qualitative" ValueScaleType="Numerical" BarWidth="0.3" LabelsVisibility="True" ShowInLegend="True">
                                        <dxc:BarSideBySideSeries2D.Model>
                                            <dxc:BorderlessSimpleBar2DModel/>
                                        </dxc:BarSideBySideSeries2D.Model>
                                        <dxc:BarSideBySideSeries2D.Label>
                                            <dxc:SeriesLabel ConnectorVisible="False" Indent="0" Background="{x:Null}" dxc:BarSideBySideSeries2D.LabelPosition="Outside" TextPattern="{}{V}">
                                                <dxc:SeriesLabel.ElementTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding Text}" Background="Transparent" BorderThickness="0"/>
                                                    </DataTemplate>
                                                </dxc:SeriesLabel.ElementTemplate>
                                            </dxc:SeriesLabel>
                                        </dxc:BarSideBySideSeries2D.Label>
                                    </dxc:BarSideBySideSeries2D>
                                </dxc:XYDiagram2D.Series>
                                <dxc:XYDiagram2D.DefaultPane>
                                    <dxc:Pane DomainBrush="{x:Null}" BorderThickness="0" BorderBrush="{x:Null}" DomainBorderBrush="{x:Null}" />
                                </dxc:XYDiagram2D.DefaultPane>
                            </dxc:XYDiagram2D>
                        </dxc:ChartControl.Diagram>
                        <dxc:ChartControl.Legend>
                            <dxc:Legend HorizontalPosition="Right" VerticalPosition="Top" Orientation="Horizontal" ReverseItems="True" Background="{x:Null}"
                                        FontSize="10" Margin="0,-30, 0, 0" Padding="0" BorderThickness="0">
                                <dxc:Legend.CustomItems>
                                    <dxc:CustomLegendItem Text="{Binding [安灯次数], Source={uic:L10N}}" MarkerBrush="{x:Null}"></dxc:CustomLegendItem>
                                </dxc:Legend.CustomItems>
                            </dxc:Legend>
                        </dxc:ChartControl.Legend>
                    </dxc:ChartControl>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" BorderThickness="0">
                    <dxc:ChartControl x:Name="todayExcepWorkHoursChart" BorderThickness="0">
                        <dxc:ChartControl.Titles>
                            <dxc:Title x:Name="titletodayExcepWorkHours" FontSize="10" Content="{Binding [异常工时], Source={uic:L10N}}" HorizontalAlignment="Left" VerticalAlignment="Center" FontWeight="Bold" />
                        </dxc:ChartControl.Titles>
                        <dxc:ChartControl.CrosshairOptions>
                            <dxc:CrosshairOptions ShowArgumentLine="True" CrosshairLabelMode="ShowForNearestSeries" />
                        </dxc:ChartControl.CrosshairOptions>

                        <dxc:ChartControl.Diagram>
                            <dxc:XYDiagram2D Margin="5,5,5,10" Name="todayExcepWorkHoursGram" Rotated="True" SeriesDataMember="Series"  EnableAxisXNavigation="False" >
                                <dxc:XYDiagram2D.AxisX>
                                    <dxc:AxisX2D x:Name="todayExcepWorkHoursAxisX" TickmarksMinorVisible="False"
                                                 GridLinesMinorVisible="False" GridLinesVisible="False"  LabelVisibilityMode="Default">
                                        <dxc:AxisX2D.CrosshairAxisLabelOptions>
                                            <dxc:CrosshairAxisLabelOptions/>
                                        </dxc:AxisX2D.CrosshairAxisLabelOptions>
                                        <dxc:AxisX2D.Label>
                                            <dxc:AxisLabel Background="Transparent" BorderBrush="#FF343246" Padding="0,1" FontSize="12" Angle="90"/>
                                        </dxc:AxisX2D.Label>
                                    </dxc:AxisX2D>
                                </dxc:XYDiagram2D.AxisX>

                                <dxc:XYDiagram2D.AxisY>
                                    <dxc:AxisY2D x:Name="todayExcepWorkHoursAxisY"  GridLinesMinorVisible="False" GridLinesVisible="False"
                                                 TickmarksMinorVisible="True" Interlaced="False">
                                        <dxc:AxisY2D.VisualRange>
                                            <dxc:Range MinValue="0" MaxValue="200" SideMarginsValue="0" />
                                        </dxc:AxisY2D.VisualRange>
                                        <dxc:AxisY2D.WholeRange>
                                            <dxc:Range MinValue="0" MaxValue="200" SideMarginsValue="0" />
                                        </dxc:AxisY2D.WholeRange>
                                        <dxc:AxisY2D.Label>
                                            <dxc:AxisLabel Background="Transparent" BorderBrush="#FF343246" Padding="0,1"  FontSize="12" />
                                        </dxc:AxisY2D.Label>
                                    </dxc:AxisY2D>
                                </dxc:XYDiagram2D.AxisY>

                                <dxc:XYDiagram2D.Series>
                                    <dxc:BarSideBySideSeries2D x:Name="todayExcepWorkHoursSerie" CrosshairLabelPattern="{}{A}: {V}" ArgumentScaleType="Qualitative" ValueScaleType="Numerical" BarWidth="0.3" LabelsVisibility="True" ShowInLegend="True">
                                        <dxc:BarSideBySideSeries2D.Model>
                                            <dxc:BorderlessSimpleBar2DModel/>
                                        </dxc:BarSideBySideSeries2D.Model>
                                        <dxc:BarSideBySideSeries2D.Label>
                                            <dxc:SeriesLabel ConnectorVisible="False" Indent="0" Background="{x:Null}" dxc:BarSideBySideSeries2D.LabelPosition="Outside" TextPattern="{}{V}">
                                                <dxc:SeriesLabel.ElementTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding Text}" Background="Transparent" BorderThickness="0"/>
                                                    </DataTemplate>
                                                </dxc:SeriesLabel.ElementTemplate>
                                            </dxc:SeriesLabel>
                                        </dxc:BarSideBySideSeries2D.Label>
                                    </dxc:BarSideBySideSeries2D>
                                </dxc:XYDiagram2D.Series>
                                <dxc:XYDiagram2D.DefaultPane>
                                    <dxc:Pane DomainBrush="{x:Null}" BorderThickness="0" BorderBrush="{x:Null}" DomainBorderBrush="{x:Null}" />
                                </dxc:XYDiagram2D.DefaultPane>
                            </dxc:XYDiagram2D>
                        </dxc:ChartControl.Diagram>
                        <dxc:ChartControl.Legend>
                            <dxc:Legend HorizontalPosition="Right" VerticalPosition="Top" Orientation="Horizontal" ReverseItems="True" Background="{x:Null}"
                                        FontSize="10" Margin="0,-30, 0, 0" Padding="0" BorderThickness="0">
                                <dxc:Legend.CustomItems>
                                    <dxc:CustomLegendItem Text="{Binding [异常时间(分钟)], Source={uic:L10N}}" MarkerBrush="{x:Null}"></dxc:CustomLegendItem>
                                </dxc:Legend.CustomItems>
                            </dxc:Legend>
                        </dxc:ChartControl.Legend>
                    </dxc:ChartControl>
                </Border>
            </Grid>
        </Border>

    </Grid>
</sd:ComponentItem>
