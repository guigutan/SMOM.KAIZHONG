<UserControl x:Class="SIE.Wpf.MES.Workbench.KeyPerformances.CommonLineChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
             xmlns:local="clr-namespace:SIE.Wpf.MES.Workbench.KeyPerformances"
              xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
             mc:Ignorable="d" 
             BorderThickness="1"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="{DynamicResource {uit:BrushesThemeKey ResourceKey=Background}}">
        <Border BorderThickness="1" BorderBrush="#CCCCCC" CornerRadius="5">
            <dxc:ChartControl Background="{x:Null}" DataSource="{Binding}" BorderThickness="1">
                <dxc:ChartControl.Diagram>
                    <dxc:XYDiagram2D x:Name="_diagram" >
                        <dxc:XYDiagram2D.DefaultPane>
                            <dxc:Pane DomainBrush="{x:Null}" DomainBorderBrush="{x:Null}"/>
                        </dxc:XYDiagram2D.DefaultPane>
                        <dxc:XYDiagram2D.AxisX>
                            <dxc:AxisX2D x:Name="_axisX" BorderThickness="0" TickmarksMinorVisible="False" TickmarksLength ="5" GridLinesMinorVisible="False" GridLinesVisible="False">
                                <dxc:AxisX2D.Label>
                                    <dxc:AxisLabel TextPattern="{}{V:M/d}" Background="Transparent" BorderBrush="#FF343246"></dxc:AxisLabel>
                                </dxc:AxisX2D.Label>
                                <dxc:AxisX2D.DateTimeScaleOptions>
                                    <dxc:ContinuousDateTimeScaleOptions AutoGrid="False" GridSpacing="1"></dxc:ContinuousDateTimeScaleOptions>
                                </dxc:AxisX2D.DateTimeScaleOptions>
                            </dxc:AxisX2D>
                        </dxc:XYDiagram2D.AxisX>
                        <dxc:XYDiagram2D.AxisY>
                            <dxc:AxisY2D x:Name="_axisY" TickmarksMinorVisible="False" TickmarksLength ="3" GridLinesMinorVisible="False" GridLinesVisible="True" Interlaced="False">
                                <dxc:AxisY2D.Label>
                                    <dxc:AxisLabel  TextPattern="{}{V:P0}" Background="Transparent" BorderBrush="#FF343246"></dxc:AxisLabel>
                                </dxc:AxisY2D.Label>
                                <dxc:AxisY2D.NumericScaleOptions>
                                    <dxc:ContinuousNumericScaleOptions AutoGrid="False" GridSpacing="0.1"></dxc:ContinuousNumericScaleOptions>
                                </dxc:AxisY2D.NumericScaleOptions>
                                <dxc:AxisY2D.WholeRange>
                                    <dxc:Range MaxValue="1" MinValue="0" dxc:AxisY2D.AlwaysShowZeroLevel="False"></dxc:Range>
                                </dxc:AxisY2D.WholeRange>
                                <dxc:AxisY2D.VisualRange>
                                    <dxc:Range MaxValue="1" MinValue="0" dxc:AxisY2D.AlwaysShowZeroLevel="False"></dxc:Range>
                                </dxc:AxisY2D.VisualRange>
                                <dxc:AxisY2D.ConstantLinesInFront></dxc:AxisY2D.ConstantLinesInFront>
                            </dxc:AxisY2D>
                        </dxc:XYDiagram2D.AxisY>
                    </dxc:XYDiagram2D>
                </dxc:ChartControl.Diagram>
                <dxc:ChartControl.Legend>
                    <dxc:Legend x:Name="_legend" Background="{x:Null}" Orientation="Horizontal" HorizontalPosition="Center" VerticalPosition="BottomOutside">
                        <dxc:Legend.CustomItems>
                            <!--<dxc:CustomLegendItem Text="实际" MarkerBrush="SkyBlue"/>
                        <dxc:CustomLegendItem Text="目标"/>-->
                        </dxc:Legend.CustomItems>
                    </dxc:Legend>
                </dxc:ChartControl.Legend>
                <dxc:ChartControl.Titles>
                    <dxc:Title x:Name="_title" HorizontalAlignment="Center"></dxc:Title>
                </dxc:ChartControl.Titles>
            </dxc:ChartControl>
        </Border>
    </Grid>
</UserControl>
