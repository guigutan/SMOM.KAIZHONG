<sd:ComponentItem xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"  x:Class="SIE.Wpf.MES.Workbench.AlertLights.AlertLightsControl"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                  xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                  xmlns:local="clr-namespace:SIE.Wpf.MES.Workbench.AlertLights"
                  xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
                  xmlns:ui="http://schemas.siestudio.com/winfx/xaml/controls"
                  xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
                  xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
                  xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
                  sd:DiagramDesigner.ToolBarTitle="{Binding [生产-软安灯], Source={uic:L10N}}"
                  sd:DiagramDesigner.DefaultSize="362,248"
                  mc:Ignorable="d" 
                  d:DesignHeight="200" d:DesignWidth="300">
    <dxlc:GroupBox Padding="-2">
        <dxlc:GroupBox.Header>
            <Label Height="36" FontSize="18" VerticalContentAlignment="Center">
                <TextBlock Name="lblTitle" Text="{Binding [按灯],Source={uic:L10N}}"/>
            </Label>
        </dxlc:GroupBox.Header>
        <Grid Background="{DynamicResource {uit:BrushesThemeKey ResourceKey=Background}}">
            <Grid Name="gdAlertType" Visibility="Visible">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" DockPanel.Dock="Bottom" BorderBrush="{x:Null}" Background="{x:Null}">
                    <ItemsControl Name="ctlAlertType"  Height="Auto">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Name="callTypeBtn" Grid.Row="0" Height="70" Width="70" Padding="3" Margin="20,20,20,5" Click="CallTypeBtn_Click" 
                                            ToolTip="{Binding CallTypeName}" Tag="{Binding}">
                                        <Button.Content>
                                            <Image x:Name="imgLine"  Width="70" Height="70" Source="{Binding CallTypeImgSrc}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,0"></Image>
                                        </Button.Content>
                                        <Button.Template >
                                            <ControlTemplate TargetType="{x:Type Button}" >
                                                <Border BorderBrush="{TemplateBinding Control.BorderBrush}"  BorderThickness="1" CornerRadius="7,7,7,7">
                                                    <ContentPresenter Content="{TemplateBinding ContentControl.Content}" HorizontalAlignment="Center" VerticalAlignment="Center" ></ContentPresenter>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Label Name="lblLine" Grid.Row="1" Height="Auto" Width="Auto" HorizontalContentAlignment="Center"  Content="{Binding CallTypeLblContent}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel IsItemsHost="True" Margin="15,35,0,35"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Grid Name="gdExceptionType" Visibility="Hidden">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" DockPanel.Dock="Bottom" BorderBrush="{x:Null}" Background="{x:Null}">
                    <ItemsControl Name="ctlExceptionType"  Height="Auto">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="1*"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Name="ExceptionTypeBtn" Height="70" Width="70" Padding="3" Margin="20,10,20,10" Click="ExceptionTypeBtn_Click" 
                                            ToolTip="{Binding ExpTypeName, Source={uic:L10N}}" Content="{Binding ExpTypeName}" Tag="{Binding}" Background="#F1F5FF">
                                        <Button.Template >
                                            <ControlTemplate TargetType="{x:Type Button}" >
                                                <Border BorderBrush="{TemplateBinding Control.BorderBrush}" Background="#F1F5FF" BorderThickness="1" CornerRadius="7,7,7,7">
                                                    <ContentPresenter Content="{TemplateBinding ContentControl.Content}" HorizontalAlignment="Center" VerticalAlignment="Center" ></ContentPresenter>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel IsItemsHost="True" Margin="5,5,5,5"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>
        </Grid>
    </dxlc:GroupBox>
</sd:ComponentItem>
