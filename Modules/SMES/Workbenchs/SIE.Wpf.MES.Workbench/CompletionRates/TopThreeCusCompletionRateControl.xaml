<sd:ComponentItem x:Class="SIE.Wpf.MES.Workbench.CompletionRates.TopThreeCusCompletionRateControl"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
                  xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                  xmlns:local="clr-namespace:SIE.Wpf.MES.Workbench.CompletionRates"
                  xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"           
                  xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
                  sd:DiagramDesigner.ToolBarTitle="{Binding [生产-Top3客户完成/计划],Source={uic:L10N}}"
                  mc:Ignorable="d" 
                  sd:DiagramDesigner.DefaultSize="341,150"
                  d:DesignHeight="150" d:DesignWidth="341">
    <sd:ComponentItem.Resources>
        <ResourceDictionary>
            <dxc:BrushOverlayConverter x:Key="brushOverlayConverter" />
        </ResourceDictionary>
    </sd:ComponentItem.Resources>
    <Grid Background="{DynamicResource {uit:BrushesThemeKey ResourceKey=Background}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Label Name="titleName" Content="{Binding [Top3客户完成/计划], Source={uic:L10N}}" Grid.Row="0" Padding="5,0,0,0" Grid.Column="0" FontSize="20" FontWeight="Bold" Foreground="#666666"></Label>
        </Grid>
        <Grid Grid.Row="1">
            <dxc:ChartControl x:Name="chartControl" Margin="0,0,0,0" Background="Transparent"  BorderThickness="0" BorderBrush="Transparent" CustomDrawCrosshair="chartControl_CustomDrawCrosshair" CustomDrawSeriesPoint="chartControl_CustomDrawSeriesPoint">
                <dxc:ChartControl.Palette>
                    <dxc:ChameleonPalette/>
                </dxc:ChartControl.Palette>
                <dxc:XYDiagram2D  Background="{x:Null}" Margin="-10,-10,25,0" x:Name="diagram" Rotated="True"  EnableAxisXNavigation="False" EnableAxisYNavigation="False">
                    <dxc:XYDiagram2D.DefaultPane>
                        <dxc:Pane DomainBorderBrush="{x:Null}" DomainBrush="{x:Null}" BorderThickness="0" BorderBrush="{x:Null}" />
                    </dxc:XYDiagram2D.DefaultPane>
                    <!-- Rotated 横向-->
                    <dxc:XYDiagram2D.AxisY>
                        <dxc:AxisY2D x:Name="_AxisY" Visible="False"  GridLinesVisible="False"  Interlaced="False">
                            <dxc:AxisY2D.Label>
                                <dxc:AxisLabel Background="Transparent" FontSize="12" TextPattern="{}{V:P2}"/>
                                <!-- Y轴标签改为百分比格式 -->
                            </dxc:AxisY2D.Label>
                        </dxc:AxisY2D>
                    </dxc:XYDiagram2D.AxisY>
                    <dxc:XYDiagram2D.AxisX>
                        <!-- X轴设置 -->
                        <dxc:AxisX2D BorderThickness="0" Visible="False" Foreground="{x:Null}" BorderBrush="{x:Null}" TickmarksVisible="False" TickmarksMinorVisible="False" >
                            <dxc:AxisX2D.QualitativeScaleOptions>
                                <dxc:QualitativeScaleOptions AutoGrid="False"></dxc:QualitativeScaleOptions>
                            </dxc:AxisX2D.QualitativeScaleOptions>
                            <dxc:AxisX2D.Label>
                                <dxc:AxisLabel Background="Transparent"  Padding="0,1" FontSize="14">
                                    <dxc:Axis2D.ResolveOverlappingOptions>
                                        <dxc:AxisLabelResolveOverlappingOptions AllowHide="False" AllowRotate="True" AllowStagger="True" MinIndent="0" />
                                    </dxc:Axis2D.ResolveOverlappingOptions>
                                </dxc:AxisLabel>
                            </dxc:AxisX2D.Label>
                        </dxc:AxisX2D>
                    </dxc:XYDiagram2D.AxisX>

                    <dxc:RangeBarOverlappedSeries2D BorderBrush="#E9E9E9"  BorderThickness="2" x:Name="planQtySerie"
                                            ShowInLegend="True" Visible="True" ArgumentScaleType="Qualitative" Brush="#E9E9E9" BarWidth="0.60" LabelsVisibility="True">
                        <dxc:RangeBarOverlappedSeries2D.Model>
                            <dxc:CustomRangeBar2DModel>
                                <dxc:CustomRangeBar2DModel.PointTemplate>
                                    <ControlTemplate>
                                        <Grid>
                                            <Border CornerRadius="7,7,7,7" Margin="1,1,1,0" Background="#E9E9E9"/>
                                        </Grid>
                                    </ControlTemplate>
                                </dxc:CustomRangeBar2DModel.PointTemplate>
                            </dxc:CustomRangeBar2DModel>
                        </dxc:RangeBarOverlappedSeries2D.Model>
                        <dxc:RangeBarOverlappedSeries2D.Label>
                            <dxc:SeriesLabel Indent="10" TextPattern="{}{V:P1}" FontSize="14" dxc:RangeBarSeries2D.LabelKind="TwoLabels" ConnectorVisible="False">
                                <dxc:SeriesLabel.ElementTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Text}" FontSize="14" IsReadOnly="True" Background="Transparent" BorderThickness="0"/>
                                    </DataTemplate>
                                </dxc:SeriesLabel.ElementTemplate>
                            </dxc:SeriesLabel>
                        </dxc:RangeBarOverlappedSeries2D.Label>
                    </dxc:RangeBarOverlappedSeries2D>
                    <dxc:RangeBarOverlappedSeries2D x:Name="finishQtySerie" 
                                            ShowInLegend="True" Visible="True" ArgumentScaleType="Qualitative" BarWidth="0.58" LabelsVisibility="True" >
                        <dxc:RangeBarOverlappedSeries2D.Model>
                            <dxc:CustomRangeBar2DModel>
                                <dxc:CustomRangeBar2DModel.PointTemplate>
                                    <ControlTemplate>
                                        <Grid>
                                            <Border CornerRadius="7,7,7,7" Margin="1,1,1,0" >
                                                <Border.Background>
                                                    <Binding Path="PointColor" Converter="{StaticResource brushOverlayConverter}">
                                                        <Binding.ConverterParameter>
                                                            <LinearGradientBrush EndPoint="0,0.5" StartPoint="1,0.5">
                                                                <GradientStop Color="#138CEF" Offset="0" />
                                                                <GradientStop Color="#138CEF" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Binding.ConverterParameter>
                                                    </Binding>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                    </ControlTemplate>
                                </dxc:CustomRangeBar2DModel.PointTemplate>
                            </dxc:CustomRangeBar2DModel>
                        </dxc:RangeBarOverlappedSeries2D.Model>
                        <dxc:RangeBarOverlappedSeries2D.Label>
                            <dxc:SeriesLabel HorizontalContentAlignment="Center" FontSize="12" dxc:RangeBarSeries2D.LabelKind="MaxValueLabel" ResolveOverlappingMode="JustifyAllAroundPoint" ConnectorVisible="False"  TextPattern="{}{V:P1}">
                                <dxc:SeriesLabel.ElementTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Text}" Name="txtLabel" Padding="-40,0,0,0" FontSize="12" IsReadOnly="True" Background="Transparent" BorderThickness="0"/>
                                    </DataTemplate>
                                </dxc:SeriesLabel.ElementTemplate>
                            </dxc:SeriesLabel>
                        </dxc:RangeBarOverlappedSeries2D.Label>
                    </dxc:RangeBarOverlappedSeries2D>
                </dxc:XYDiagram2D>
            </dxc:ChartControl>
        </Grid>
    </Grid>
</sd:ComponentItem>
