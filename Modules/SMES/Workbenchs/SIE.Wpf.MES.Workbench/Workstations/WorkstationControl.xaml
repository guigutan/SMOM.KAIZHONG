<sd:ComponentItem x:Class="SIE.Wpf.MES.Workbench.Workstations.WorkstationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.Workbench.Workstations"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
             xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core" 
             xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
             sd:DiagramDesigner.ToolBarTitle="{Binding [生产-工序工位选择], Source={uic:L10N}}"
             sd:DiagramDesigner.DefaultSize="1092,34"
             mc:Ignorable="d">
    <Border BorderBrush="{DynamicResource {uit:BrushesThemeKey ResourceKey=BorderBrush}}" BorderThickness="1" CornerRadius="2" Background="#F1F1F1"> 
        <Grid  Margin="10,0,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <local:UserLockableLookUpEditor MaxHeight="24"/>
            <local:ResourceLockableLookUpEditor Margin="20,0,0,0" Grid.Column="1" MaxHeight="24"/>
            <local:ProcessLockableLookUpEditor Margin="20,0,0,0" Grid.Column="2" MaxHeight="24"/>
            <local:StationLockableLookUpEditor Margin="20,0,0,0" Grid.Column="3" MaxHeight="24"/>
        </Grid>
    </Border>
</sd:ComponentItem>
