<UserControl xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"  x:Class="SIE.Wpf.MES.Workbench.Workstations.ProcessLockableLookUpEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.Workbench.Workstations"
             xmlns:ui="http://schemas.siestudio.com/winfx/xaml/controls"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core" 
             xmlns:converter="clr-namespace:SIE.Wpf.MES.Workbench.Converters"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ControlTemplate x:Key="groupContentTemplate">
                <dxg:GridControl x:Name="PART_GridControl" AutoExpandAllGroups="True">
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="Name" Header="{Binding [名称], Source={uic:L10N}}" HeaderToolTip="{Binding [名称], Source={uic:L10N}}"/>
                        <dxg:GridColumn FieldName="Category.Code" Header="{Binding [产品族编码], Source={uic:L10N}}" HeaderToolTip="{Binding [产品族编码], Source={uic:L10N}}"/>
                        <dxg:GridColumn FieldName="Category.Name" Header="{Binding [产品族名称], Source={uic:L10N}}" HeaderToolTip="{Binding [产品族名称], Source={uic:L10N}}"/> 
                    </dxg:GridControl.Columns>
                    <dxg:GridControl.View>
                        <dxg:TableView
                        Name="View"
                        ShowGroupedColumns="True"
                        AutoWidth="True"
                        AllowPerPixelScrolling="True"
                        ScrollAnimationDuration="0"
                        ShowAutoFilterRow="True"
                        ShowTotalSummary="True"
                        IsSynchronizedWithCurrentItem="False">
                        </dxg:TableView>
                    </dxg:GridControl.View>
                </dxg:GridControl>
            </ControlTemplate>
        </ResourceDictionary>
    </UserControl.Resources>
    <DockPanel>
        <ToggleButton Name="btnLock" DockPanel.Dock="Right" IsTabStop="False" Padding="0" IsChecked="True" Click="Lock_Click" Margin="2,0,0,0">
            <ToggleButton.Content>
                <ui:PackIcon Kind="Lock" Width="16" Height="16"></ui:PackIcon>
            </ToggleButton.Content>
        </ToggleButton>
        <Label DockPanel.Dock="Left" Content="{Binding [工序:],Source={uic:L10N}}" Margin="0,0,5,0"></Label>
        <dxg:LookUpEdit Name="editor" IsEnabled="False" EditValue="{Binding ProcessId,Mode=TwoWay}" AllowNullInput="True" PopupWidth="400" PopupMaxWidth="500" DisplayMember="Name" ValueMember="Id" AutoPopulateColumns="False" PopupContentTemplate="{StaticResource groupContentTemplate}" PopupOpening="PopupOpening">
        </dxg:LookUpEdit>
    </DockPanel>
</UserControl>
