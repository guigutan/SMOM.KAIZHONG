<sd:ComponentItem x:Class="SIE.Wpf.MES.Workbench.LineStates.LineStateControl"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                  xmlns:local="clr-namespace:SIE.Wpf.MES.Workbench.LineStates"
                  xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
                  xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
                  xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
                  xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                  xmlns:ui="http://schemas.siestudio.com/winfx/xaml/controls"
                  xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
                  xmlns:icon="clr-namespace:Resources.IconPacks;assembly=Resources"
                  xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
                  sd:DiagramDesigner.ToolBarTitle="{Binding [生产-开线状态], Source={uic:L10N}}"
                  sd:DiagramDesigner.DefaultSize="685,268"
                  mc:Ignorable="d" 
                  >
    <DockPanel Background="{DynamicResource {uit:BrushesThemeKey ResourceKey=Background}}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" DockPanel.Dock="Bottom" BorderBrush="{x:Null}" Background="{x:Null}">
                <ItemsControl Name="ctlLineState"  Height="Auto">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border  BorderThickness="1"  CornerRadius="5" Margin="5,5,5,5"   Background="{Binding State, Converter={local:StateConverterExtension}, Mode=OneWay}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="1*"/>
                                        <!--<RowDefinition Height="1*"/>-->
                                        <RowDefinition Height="1*"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Row="0"  Content="{Binding LineName}" HorizontalContentAlignment="Center" Tag="{Binding}"  Margin="5,5,5,0" Foreground="White"/>
                                    <!--<Label  Grid.Row="1" Content="{Binding State}" HorizontalContentAlignment="Center" Margin="0,0,0,0"/>-->
                                    <icon:PackIcon Kind="ProductLines"  Height="Auto" Width="Auto" Background="Transparent" HorizontalAlignment="Center" Grid.Row="1"  Margin="5,0,5,5" Foreground="White">
                                    </icon:PackIcon>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel IsItemsHost="True" Margin="10,5,5,5"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <dxc:ChartControl Name="LineChart" BorderThickness="1"  Margin="5,10,5,10" AnimationMode="OnLoad" Grid.Column="1" AutoLayout="True">
                <dxc:ChartControl.Palette>
                    <dxc:CustomPalette>
                        <dxc:CustomPalette.Colors>
                            <Color>#128BEF</Color>
                            <Color>#FF7200</Color>
                            <Color>#5BB65E</Color>
                        </dxc:CustomPalette.Colors>
                    </dxc:CustomPalette>
                </dxc:ChartControl.Palette>
                <dxc:ChartControl.Diagram>
                    <dxc:SimpleDiagram2D Margin="-10,0,-10,0">
                        <dxc:SimpleDiagram2D.Series>
                            <dxc:PieSeries2D Name="LineSeries" HoleRadiusPercent="70" >
                                <dxc:PieSeries2D.Label>
                                    <dxc:SeriesLabel Visible="True" dxc:PieSeries.LabelPosition="Outside"  ConnectorVisible="False" TextPattern="{}{V:P0}" Background="{DynamicResource {uit:BrushesThemeKey ResourceKey=Background}}" />
                                </dxc:PieSeries2D.Label>
                            </dxc:PieSeries2D>
                        </dxc:SimpleDiagram2D.Series>
                    </dxc:SimpleDiagram2D>
                </dxc:ChartControl.Diagram>
                <dxc:ChartControl.Legend>
                    <dxc:Legend HorizontalPosition="Right" VerticalPosition="Top" Orientation="Vertical" ReverseItems="False" Background="{x:Null}"
                                FontSize="12" Margin="0,-20,-10,0" Padding="0"  BorderThickness="1"  ItemVisibilityMode="Default">
                        <dxc:Legend.CustomItems>
                            <dxc:CustomLegendItem MarkerBrush="#5BB65E" Text="正常"></dxc:CustomLegendItem>
                            <dxc:CustomLegendItem MarkerBrush="#128BEF" Text="保养"></dxc:CustomLegendItem>
                            <dxc:CustomLegendItem MarkerBrush="#FF7200" Text="停线"></dxc:CustomLegendItem>
                        </dxc:Legend.CustomItems>
                    </dxc:Legend>
                </dxc:ChartControl.Legend>
            </dxc:ChartControl>

        </Grid>
    </DockPanel>
</sd:ComponentItem>
