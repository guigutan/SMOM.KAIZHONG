<UserControl x:Class="SIE.Wpf.MES.Workbench.LineStates.LineControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.Workbench.LineStates"
             xmlns:ui="http://schemas.siestudio.com/winfx/xaml/controls"
             xmlns:cv="clr-namespace:SIE.Wpf.MES.Workbench.LineStates"
             mc:Ignorable="d" 
             Width="110"
             Height="110"
             Margin="80,10,10,0">
    <Border CornerRadius="20" Background="{Binding State,Converter={cv:StateConverter}}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="{Binding LineName}" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <ui:PackIcon Kind="Note" Width="59" Height="59" Grid.Row="1" Margin="25,10,25,5"></ui:PackIcon>
        </Grid>
    </Border>
</UserControl>
