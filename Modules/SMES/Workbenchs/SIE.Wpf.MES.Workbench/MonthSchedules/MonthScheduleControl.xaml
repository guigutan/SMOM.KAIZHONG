<sd:ComponentItem x:Class="SIE.Wpf.MES.Workbench.MonthSchedules.MonthScheduleControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:local="clr-namespace:SIE.Wpf.MES.Workbench.MonthSchedules"     
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             sd:DiagramDesigner.ToolBarTitle="{Binding [生产-月度计划], Source={uic:L10N}}"
             mc:Ignorable="d" DataContext="{Binding RelativeSource={RelativeSource Self}}"
             d:DesignHeight="300" d:DesignWidth="300">
    <sd:ComponentItem.Resources>
        <Style x:Key="CelStyle" TargetType="{x:Type dxg:LightweightCellEditor}">
            <Setter Property="Height" Value="30"></Setter>
        </Style>
        <Style  TargetType="{x:Type dxg:GridColumn}">
            <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
            <Setter Property="CellStyle" Value="{StaticResource CelStyle}"></Setter>
            <Setter Property="EditSettings">
                <Setter.Value>
                    <dxe:TextEditSettings HorizontalContentAlignment="Center"   />
                </Setter.Value>
            </Setter>
        </Style>
    </sd:ComponentItem.Resources>
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Background="{x:Null}" Name="body" BorderBrush="#666666" Grid.Row="1" Margin="0,0,0,0" MaxHeight="300">
            <dxg:GridControl  x:Name="monthSchedule" ClipboardCopyMode="ExcludeHeader" ItemsSource="{Binding MonthScheduleInfos, Mode=OneWay}" 
                               EnableSmartColumnsGeneration="False" ShowBorder="False" Margin="0" Grid.Row="1"  AllowInitiallyFocusedRow="False" Background="{x:Null}">
                <dxg:GridControl.View>
                    <dxg:TableView AllowEditing="False" ShowGroupPanel="False"   ShowHorizontalLines="False" ShowVerticalLines="False" VerticalScrollbarVisibility="Auto"  AutoWidth="True"   ShowIndicator="False"
                                   Background="{x:Null}">
                        <dxg:TableView.RowStyle>
                            <Style TargetType="dxg:RowControl" >
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Path=Row.RowColorType}" Value="0">
                                        <Setter Property="Background" Value="#FFE6E6"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Path=Row.RowColorType}" Value="1">
                                        <Setter Property="Background" Value="#EAFFF6"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Path=Row.RowColorType}" Value="8">
                                        <Setter Property="Background" Value="#EBEBEB"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Path=Row.RowColorType}" Value="9">
                                        <Setter Property="Background" Value="#F8F8F8"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </dxg:TableView.RowStyle>
                    </dxg:TableView>
                </dxg:GridControl.View>
                <dxg:GridControl.Columns>
                    <dxg:GridColumn    AllowCellMerge="False"  
                                    AllowEditing="false"
                                    FieldName="RowNum" Width="60"                            
                                    Header="{Binding [], Source={uic:L10N}}" >
                        <dxg:GridColumn.HeaderStyle>
                            <Style TargetType="dxg:GridColumnHeader" >
                                <Setter Property="Background" Value="White"></Setter>
                                <Setter Property="BorderBrush" Value="White"></Setter>
                                <Setter Property="Foreground" Value="#2895F0"/>
                                <Setter Property="Height" Value="30"></Setter>
                            </Style>
                        </dxg:GridColumn.HeaderStyle>
                    </dxg:GridColumn>
                    <dxg:GridColumn   AllowCellMerge="False"  
                                    AllowEditing="false"
                                    FieldName="PlanStartDate"
                                    Header="{Binding [计划开始], Source={uic:L10N}}"
                                    IsSmart="True">
                        <dxg:GridColumn.HeaderStyle>
                            <Style TargetType="dxg:GridColumnHeader" >
                                <Setter Property="Background" Value="White"></Setter>
                                <Setter Property="BorderBrush" Value="White"></Setter>
                                <Setter Property="Foreground" Value="#2895F0"/>
                                <Setter Property="Height" Value="30"></Setter>
                            </Style>
                        </dxg:GridColumn.HeaderStyle>
                    </dxg:GridColumn>
                    <dxg:GridColumn   AllowCellMerge="False"  
                                    AllowEditing="false"
                                    FieldName="LastFinishDate"
                                    Header="{Binding [计划完工], Source={uic:L10N}}"
                                    IsSmart="True">
                        <dxg:GridColumn.HeaderStyle>
                            <Style TargetType="dxg:GridColumnHeader" >
                                <Setter Property="Background" Value="White"></Setter>
                                <Setter Property="BorderBrush" Value="White"></Setter>
                                <Setter Property="Foreground" Value="#2895F0"/>
                                <Setter Property="Height" Value="30"></Setter>
                            </Style>
                        </dxg:GridColumn.HeaderStyle>
                    </dxg:GridColumn>
                    <dxg:GridColumn   AllowCellMerge="False"  
                                    AllowEditing="false" FieldName="WorkOrderNo"
                                    Header="{Binding [工单号], Source={uic:L10N}}"
                                    IsSmart="True">
                        <dxg:GridColumn.HeaderStyle>
                            <Style TargetType="dxg:GridColumnHeader" >
                                <Setter Property="Background" Value="White"></Setter>
                                <Setter Property="BorderBrush" Value="White"></Setter>
                                <Setter Property="Foreground" Value="#2895F0"/>
                                <Setter Property="Height" Value="30"></Setter>
                            </Style>
                        </dxg:GridColumn.HeaderStyle>
                    </dxg:GridColumn>
                    <dxg:GridColumn   AllowCellMerge="False" 
                                    AllowEditing="false" FieldName="ItemCode"
                                    Header="{Binding [物料编码], Source={uic:L10N}}"
                                    IsSmart="True">
                        <dxg:GridColumn.HeaderStyle>
                            <Style TargetType="dxg:GridColumnHeader" >
                                <Setter Property="Background" Value="White"></Setter>
                                <Setter Property="BorderBrush" Value="White"></Setter>
                                <Setter Property="Foreground" Value="#2895F0"/>
                                <Setter Property="Height" Value="30"></Setter>
                            </Style>
                        </dxg:GridColumn.HeaderStyle>
                    </dxg:GridColumn>
                    <dxg:GridColumn   AllowCellMerge="False" 
                                    AllowEditing="false" FieldName="PlanQty"
                                    Header="{Binding [需求数量], Source={uic:L10N}}">
                        <dxg:GridColumn.HeaderStyle>
                            <Style TargetType="dxg:GridColumnHeader" >
                                <Setter Property="Background" Value="White"></Setter>
                                <Setter Property="BorderBrush" Value="White"></Setter>
                                <Setter Property="Foreground" Value="#2895F0"/>
                                <Setter Property="Height" Value="30"></Setter>
                            </Style>
                        </dxg:GridColumn.HeaderStyle>
                    </dxg:GridColumn>
                    <dxg:GridColumn   AllowCellMerge="False" 
                                    AllowEditing="false" FieldName="FinishQty"
                                    Header="{Binding [完工数量], Source={uic:L10N}}">
                        <dxg:GridColumn.HeaderStyle>
                            <Style TargetType="dxg:GridColumnHeader" >
                                <Setter Property="Background" Value="White"></Setter>
                                <Setter Property="BorderBrush" Value="White"></Setter>
                                <Setter Property="Foreground" Value="#2895F0"/>
                                <Setter Property="Height" Value="30"></Setter>
                            </Style>
                        </dxg:GridColumn.HeaderStyle>
                    </dxg:GridColumn>
                    <dxg:GridColumn   AllowCellMerge="False"  
                                    AllowEditing="false" FieldName="CustomerName"
                                    Header="{Binding [客户名称], Source={uic:L10N}}"
                                    IsSmart="True">
                        <dxg:GridColumn.HeaderStyle>
                            <Style TargetType="dxg:GridColumnHeader" >
                                <Setter Property="Background" Value="White"></Setter>
                                <Setter Property="BorderBrush" Value="White"></Setter>
                                <Setter Property="Foreground" Value="#2895F0"/>
                                <Setter Property="Height" Value="30"></Setter>
                            </Style>
                        </dxg:GridColumn.HeaderStyle>
                    </dxg:GridColumn>
                    <dxg:GridColumn  AllowCellMerge="False"  
                                    AllowEditing="false" FieldName="CurrentState"
                                    Header="{Binding [当前状态], Source={uic:L10N}}"
                                    IsSmart="True">
                        <dxg:GridColumn.HeaderStyle>
                            <Style TargetType="dxg:GridColumnHeader" >
                                <Setter Property="Background" Value="White"></Setter>
                                <Setter Property="BorderBrush" Value="White"></Setter>
                                <Setter Property="Foreground" Value="#2895F0"/>
                                <Setter Property="Height" Value="30"></Setter>
                            </Style>
                        </dxg:GridColumn.HeaderStyle>
                    </dxg:GridColumn>
                    <dxg:GridColumn  AllowCellMerge="False" 
                                    AllowEditing="false" FieldName="PlanResource"
                                    Header="{Binding [计划执行资源], Source={uic:L10N}}"
                                    IsSmart="True">
                        <dxg:GridColumn.HeaderStyle>
                            <Style TargetType="dxg:GridColumnHeader" >
                                <Setter Property="Background" Value="White"></Setter>
                                <Setter Property="BorderBrush" Value="White"></Setter>
                                <Setter Property="Foreground" Value="#2895F0"/>
                                <Setter Property="Height" Value="30"></Setter>
                            </Style>
                        </dxg:GridColumn.HeaderStyle>
                    </dxg:GridColumn>
                </dxg:GridControl.Columns>
            </dxg:GridControl>
        </Border>
    </Grid>
</sd:ComponentItem>
