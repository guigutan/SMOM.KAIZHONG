<sd:ComponentItem xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"  x:Class="SIE.Wpf.MES.Workbench.EmployeeMarks.EmployeeMarkControl"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                  xmlns:local="clr-namespace:SIE.Wpf.MES.Workbench.EmployeeMarks"
                  xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                  xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
                  xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                  xmlns:ui="http://schemas.siestudio.com/winfx/xaml/controls"
                  xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"  
                  xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
                  xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core" 
                  xmlns:icon="clr-namespace:Resources.IconPacks;assembly=Resources"
                  sd:DiagramDesigner.ToolBarTitle="{Binding [生产-个人作业评分], Source={uic:L10N}}"
                  sd:DiagramDesigner.DefaultSize="350,304"
                  mc:Ignorable="d" 
                  d:DesignHeight="300" d:DesignWidth="300">
    <dxlc:GroupBox Padding="-2">
        <dxlc:GroupBox.Header>
            <Label Height="36" FontSize="18" VerticalContentAlignment="Center">
                <TextBlock Name="lblTitle" Text="{Binding [综合评分],Source={uic:L10N}}"/>
            </Label>
        </dxlc:GroupBox.Header>
        <Grid Background="{DynamicResource {uit:BrushesThemeKey ResourceKey=Background}}" Name="gdEmpMark">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <StackPanel Name="spTop" Grid.Row="0" Grid.Column="0"  Width="Auto" Height="270" VerticalAlignment="Center" Orientation="Vertical" Background="#F1F5FF">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"  Margin="0, 5,0, 5">
                    <icon:PackIcon Kind="Ranking" Foreground="#128BEF" Height="15" Width="15" Background="Transparent" HorizontalAlignment="Center" Margin="10,5,5,0" ></icon:PackIcon>
                    <Label Name="tbRankings" Foreground="#128BEF" Content="{Binding [排名榜], Source={uic:L10N}}"  Margin="5,5,5,0" >
                    </Label>
                </StackPanel>

                <StackPanel x:Name="spCenter" Orientation="Vertical" HorizontalAlignment="Left" Margin="0, 10,0, 5" Background="#F1F5FF">
                    <!--<dxg:GridControl x:Name="gcScoreTop5" AllowInitiallyFocusedRow="False"  MaxHeight="270" ShowBorder="False" ItemsSource="{Binding Source}" BorderThickness="0" >
                         <dxg:GridControl.View>
                         <dxg:TableView  AllowEditing="False" AutoWidth="True" ShowGroupPanel="False" AllowCellMerge="False" ShowHorizontalLines="False"  ShowVerticalLines="False" ShowIndicator="False" ShowColumnHeaders="False" BorderThickness="0"   VerticalScrollbarVisibility="Hidden">
                         <dxg:TableView.RowStyle>
                         <Style TargetType="dxg:RowControl" >
                         <Setter Property="Background" Value="#F1F5FF"/>
                         </Style>
                         </dxg:TableView.RowStyle>
                         </dxg:TableView>
                         </dxg:GridControl.View>
                         <dxg:GridControl.Columns>
                         <dxg:GridColumn Header="排名" FieldName="CurRank" HorizontalHeaderContentAlignment="Left">
                         <dxg:GridColumn.CellTemplate>
                         <DataTemplate>
                         <Grid>
                         <icon:PackIcon VerticalAlignment="Center" HorizontalAlignment="Center"  Kind="MedalsStar" Foreground="{Binding RowData.Row.CurRank, Converter={local:Top5IconForegroundConverters}}" Height="15" Width="15"  Margin="0,5,5,5" Visibility="{Binding RowData.Row.CurRank, Converter={local:Top5IconVisibleConverters}, Mode=OneWay}" ></icon:PackIcon>
                         <Label VerticalAlignment="Center" HorizontalAlignment="Center" Content="{Binding RowData.Row.CurRank}"  HorizontalContentAlignment="Left" Margin="0,5,5,5" Visibility="{Binding RowData.Row.CurRank, Converter={local:Top5RankVisibleConverters}, Mode=OneWay}" >
                         </Label>
                         </Grid>
                         </DataTemplate>
                         </dxg:GridColumn.CellTemplate>
                         </dxg:GridColumn>
                         <dxg:GridColumn Header="姓名" FieldName="EmployeeName" HorizontalHeaderContentAlignment="Left"></dxg:GridColumn>
                         <dxg:GridColumn Header="评分" FieldName="CurScore" HorizontalHeaderContentAlignment="Center"></dxg:GridColumn>
                         </dxg:GridControl.Columns>
                         </dxg:GridControl>-->
                    <ItemsControl Name="gcScoreTop5" Height="Auto" Width="Auto">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="1*"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>
                                    <icon:PackIcon Kind="MedalsStar" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center"   Height="15" Width="15"  Margin="5,5,5,5" 
                                                   Foreground="{Binding CurRank, Converter={local:Top5IconForegroundConverters}}" 
                                                   Visibility="{Binding CurRank, Converter={local:Top5IconVisibleConverters}, Mode=OneWay}" >
                                    </icon:PackIcon>
                                    <Label Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" HorizontalContentAlignment="Left" Content="{Binding CurRank}"   Margin="5,5,5,5" Visibility="{Binding CurRank, Converter={local:Top5RankVisibleConverters}, Mode=OneWay}" />
                                    <Label Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" Content="{Binding EmployeeName}" Margin="10,0,0,0"></Label>
                                    <Label Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left" Content="{Binding CurScore}" Margin="30,0,10,0"></Label>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel IsItemsHost="True"  Margin="5,0,0,0"></StackPanel>
                                <!--<WrapPanel IsItemsHost="True" Margin="5,0,0,0"></WrapPanel>-->
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Name="spBottom" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10,0,0,10" Visibility="{Binding CurRank, Converter={local:MeSelfRankDataVisibleConverters}, Mode=OneWay}" >
                    <Label Name="myRank" Content="{Binding [我的排名], Source={uic:L10N}}" FontSize="14"   Margin="10,10,5,5"  Foreground="#201F35" ></Label>
                    <Canvas Height="25" Width="25" Margin="10,10,5,5" >
                        <Ellipse Height="25" Width="25" Fill="#128bef" HorizontalAlignment="Center" VerticalAlignment="Center" Name="elpMeRank"></Ellipse>
                        <Label Name="myRankVaue" Height="25" Width="25" BorderThickness="0"  Content="{Binding CurRank}" FontSize="14" Foreground="#FFFFFF"
                               HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ></Label>
                    </Canvas>
                </StackPanel>

            </StackPanel>

            <StackPanel Name="spMeScore" Grid.Row="0" Grid.Column="1"  Width="Auto" Height="270" VerticalAlignment="Center" Orientation="Vertical" Background="White">
                <Image x:Name="imgCup"  Width="200" Height="180" Source="{Binding ImgCup}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,10,0,10"></Image>
                <TextBlock Name="MyScore" VerticalAlignment="Center" HorizontalAlignment="Center"  Text="{Binding CurScore}" FontSize="30" Margin="0,10,0,10"/>
            </StackPanel>
        </Grid>
    </dxlc:GroupBox> 
</sd:ComponentItem>
