<sd:ComponentItem x:Class="SIE.Wpf.MES.Workbench.ShiftProductions.ShiftProductionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
             xmlns:local="clr-namespace:SIE.Wpf.MES.Workbench.ShiftProductions"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             mc:Ignorable="d" 
             sd:DiagramDesigner.ToolBarTitle="{Binding [生产-当班产量], Source={uic:L10N}}"
             sd:DiagramDesigner.DefaultSize="1150,300"
             d:DesignHeight="300" d:DesignWidth="1150">
    <sd:ComponentItem.Resources>
        <Style x:Key="HeadStyle" TargetType="{x:Type dxg:GridColumnHeader}">
            <Setter Property="Foreground" Value="#2895F0"/>
            <Setter Property="Background" Value="#E9F5FF"></Setter>
            <Setter Property="Height" Value="30"></Setter>
            <Setter Property="BorderBrush" Value="#E9F5FF"></Setter>
        </Style>
        <Style x:Key="CelStyle" TargetType="{x:Type dxg:LightweightCellEditor}">
            <Setter Property="Height" Value="30"></Setter>
        </Style>
        <Style  TargetType="{x:Type dxg:GridColumn}">
            <Setter Property="HorizontalHeaderContentAlignment" Value="Center" />
            <Setter Property="HeaderStyle" Value="{StaticResource HeadStyle}"></Setter>
            <Setter Property="CellStyle" Value="{StaticResource CelStyle}"></Setter>
            <Setter Property="EditSettings">
                <Setter.Value>
                    <dxe:TextEditSettings HorizontalContentAlignment="Center"   />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridLineStyle" TargetType="{x:Type dxc:BarSideBySideSeries2D}">
            
        </Style>
    </sd:ComponentItem.Resources>
    <Grid  >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.8*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Border Grid.Row="0" Grid.Column="0" x:Name="body"   >
            <dxg:GridControl Background="{x:Null}"   x:Name="shiftGridControl"  ShowBorder="False"  AllowInitiallyFocusedRow="False"  MaxHeight="300"   Margin="0,0,0,0"   ItemsSource="{Binding Source}">
                <dxg:GridControl.View>
                    <dxg:TableView  Background="{x:Null}"  AllowEditing="False" ShowGroupPanel="False" VerticalScrollbarVisibility="Auto"   ShowHorizontalLines="False" ShowVerticalLines="False"  AutoWidth="True"   ShowIndicator="False"/>
                </dxg:GridControl.View>
                <!--#region Columns-->
                <dxg:GridControl.Columns>
                    <dxg:GridColumn Header="{Binding [班组/线别],Source={uic:L10N}}"    FieldName="LineName"  />
                    <dxg:GridColumn Header="{Binding [计划产量], Source={uic:L10N}}"    FieldName="PlanQty"  />
                    <dxg:GridColumn Header="{Binding [实际产量], Source={uic:L10N}}"    FieldName="FinishQty"  />
                    <dxg:GridColumn Header="{Binding [完成进度], Source={uic:L10N}}"    Width="230"  >
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                     
                                        <Border Background="#F0F0F0" Width="160" Height="16" CornerRadius="8"  Margin="20,0,0,0">
                                        <Border Background="#128BEF" Width="{Binding RowData.Row.ProcessValue}" Height="16" CornerRadius="8" HorizontalAlignment="Left">
                                            <Label FontWeight="Bold"  HorizontalContentAlignment="Right"   ></Label>
                                        </Border>
                                    </Border>
                                    <Label  Content="{Binding RowData.Row.CompleteRate}" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" Margin="5,0,0,0">
                                    </Label>
                                </StackPanel>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Header="合格率"  FieldName="PassRate"  />
                </dxg:GridControl.Columns>
                <!--#endregion-->
            </dxg:GridControl>
        </Border>
        <Border Grid.Column="1" BorderBrush="#f1f1f1" BorderThickness="1">
            <Grid x:Name="ChartGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.1*"/>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Row="0" HorizontalContentAlignment="Left" Margin="10,0" Content="数据统计" Foreground="#007ACC"></Label>
                <dxc:ChartControl Grid.Row="1" Grid.Column="1"  BorderBrush="{x:Null}" Background="{x:Null}"  x:Name="LineChart" AnimationMode="OnDataChanged"   BorderThickness="0" 
                          SelectionMode="Single" SeriesSelectionMode="Point">
                    <dxc:XYDiagram2D  Margin="-5,-5,0,0"   x:Name="diagram"  PaneOrientation="Vertical" EqualBarWidth="True" RenderTransformOrigin="0,0" BarDistance="0" LabelsResolveOverlappingMinIndent="5" >
                        <dxc:XYDiagram2D.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform AngleY="-0.103"/>
                                <RotateTransform/>
                                <TranslateTransform Y="-0.332"/>
                            </TransformGroup>
                        </dxc:XYDiagram2D.RenderTransform>
                        <dxc:XYDiagram2D.DefaultPane>
                            <dxc:Pane DomainBrush="Transparent" Foreground="Black" />
                        </dxc:XYDiagram2D.DefaultPane>

                        <dxc:XYDiagram2D.AxisY>
                            <dxc:AxisY2D TickmarksMinorVisible="True" Brush="#E6E6E6" Thickness="1" GridLinesVisible="True"  Name="y2d"   GridLinesBrush="#f1f1f1"  
                        Interlaced="False" TickmarksVisible="False">
                                <dxc:AxisY2D.CustomLabels>
                                    <dxc:CustomAxisLabel Content="0" Value="0"/>
                                    
                                    <dxc:CustomAxisLabel Content="100" Value="100"/>
                                </dxc:AxisY2D.CustomLabels>
                                <dxc:AxisY2D.WholeRange>
                                    <dxc:Range MaxValue="100" MinValue="0" AutoSideMargins="False"/>
                                </dxc:AxisY2D.WholeRange>
                                <dxc:AxisY2D.Label>
                                    <dxc:AxisLabel  Background="Transparent"  FontSize="12" Foreground="Black" />
                                </dxc:AxisY2D.Label>
                            </dxc:AxisY2D>
                        </dxc:XYDiagram2D.AxisY>
                        <dxc:XYDiagram2D.AxisX>
                            <dxc:AxisX2D  LabelVisibilityMode="Default" Brush="#E6E6E6" Thickness="1">
                                <dxc:AxisX2D.QualitativeScaleOptions>
                                    <dxc:QualitativeScaleOptions AutoGrid="False"></dxc:QualitativeScaleOptions>
                                    <!--AutoGrid 设置为False 取消合并-->
                                </dxc:AxisX2D.QualitativeScaleOptions>
                                <dxc:AxisX2D.Label>
                                    <dxc:AxisLabel  Background="Transparent"  FontSize="12" Foreground="Black" >
                                        <dxc:Axis2D.ResolveOverlappingOptions>
                                            <dxc:AxisLabelResolveOverlappingOptions  AllowHide="False" AllowRotate="False" AllowStagger="True" MinIndent="5"  />
                                            <!--AllowHide  是否允许隐藏-->
                                            <!--AllowRotate  是否允许倾斜显示-->
                                            <!--AllowStagger 是否允许标签之间上下错位显示-->
                                        </dxc:Axis2D.ResolveOverlappingOptions>
                                    </dxc:AxisLabel>
                                </dxc:AxisX2D.Label>
                            </dxc:AxisX2D>
                        </dxc:XYDiagram2D.AxisX>

                        <dxc:BarSideBySideSeries2D DisplayName="BarSeries" LabelsVisibility="True" ColorEach="False" x:Name="BarChart" 
                                           BarWidth="0.2" ArgumentScaleType="Qualitative"  CrosshairEnabled="True" CrosshairLabelVisibility="True"
                                  ArgumentDataMember="ProcessName" DataSource="{Binding}"
                                ValueDataMember="FpyRate"  AnimationAutoStartMode="SetStartState" >

                            <dxc:BarSideBySideSeries2D.Model>
                                <dxc:BorderlessSimpleBar2DModel/>
                            </dxc:BarSideBySideSeries2D.Model>

                            <dxc:BarSideBySideSeries2D.Label>
                                <dxc:SeriesLabel  ConnectorVisible="False" Indent="0" dxc:BarSideBySideSeries2D.LabelPosition="Outside" TextPattern="{}{V}%">
                                    <dxc:SeriesLabel.ElementTemplate>
                                        <DataTemplate>
                                            <Label Content="{Binding Text}" FontSize="12" Foreground="Black" />
                                        </DataTemplate>
                                    </dxc:SeriesLabel.ElementTemplate>
                                </dxc:SeriesLabel>
                            </dxc:BarSideBySideSeries2D.Label>
                            <!--<dxc:BarSideBySideSeries2D.Points>
                            <dxc:SeriesPoint Argument="1" Value="90"></dxc:SeriesPoint>
                            <dxc:SeriesPoint Argument="2" Value="20"></dxc:SeriesPoint>
                            <dxc:SeriesPoint Argument="3" Value="30"></dxc:SeriesPoint>
                        </dxc:BarSideBySideSeries2D.Points>-->
                        </dxc:BarSideBySideSeries2D>
                    </dxc:XYDiagram2D>
                    <dxc:ChartControl.Legend>
                        <dxc:Legend HorizontalPosition="Right" Visibility="Collapsed" />

                    </dxc:ChartControl.Legend>
                </dxc:ChartControl>
                
                <Grid Grid.Row="1" x:Name="Gridleft" SizeChanged="Grid_SizeChanged">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="6*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="1" Content="计划合计/产量合计" HorizontalContentAlignment="Center" FontSize="12"></Label>
                    <StackPanel Orientation="Horizontal" Margin="0,3" HorizontalAlignment="Center" Name="ChartPanel">                       
                        <StackPanel  Width="30" Margin="50,0,0,0" Name="sPQty">
                            <StackPanel.ToolTip>
                                <ToolTip>
                                    <StackPanel>
                                        <TextBlock Name="toopTipsPlan"></TextBlock>
                                        <TextBlock Name="toopTipsFin" Foreground="#4668A5"></TextBlock>
                                        <TextBlock Name="toopTipsLess" Foreground="#469EA5"></TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </StackPanel.ToolTip>
                            <Label Name="laPlanQty" Height="20" FontSize="10" VerticalContentAlignment="Bottom" HorizontalContentAlignment="Center" Margin="-30,0,-30,0"></Label>
                            <Label Background="#469EA5" Name="laCompleteRate" HorizontalContentAlignment="Center" VerticalContentAlignment="Bottom" FontSize="10"></Label>
                            <Label Background="#4668A5"  x:Name="LaFinish"  FontSize="10"></Label>
                        </StackPanel>
                        <StackPanel  Width="60">
                            <Label VerticalContentAlignment="Center" HorizontalContentAlignment="Left" Height="20"></Label>
                            <Label Name="laLessQty" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" FontSize="10"></Label>
                            <Label Name="laFinishQty" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" FontSize="10"></Label>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
            
        </Border>
        
    </Grid>
</sd:ComponentItem>
