<sd:ComponentItem xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"  x:Class="SIE.Wpf.MES.Workbench.ShiftProductions.KeyEventControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.Workbench.ShiftProductions"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core" 
             xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core" 
             xmlns:msch="clr-namespace:SIE.Wpf.MES.Workbench.MonthSchedules"
             xmlns:prore="clr-namespace:SIE.Wpf.MES.Workbench.ProductingReadies"
             xmlns:abnor="clr-namespace:SIE.Wpf.MES.Workbench.AndonAbnormals"
             xmlns:ls="clr-namespace:SIE.Wpf.MES.Workbench.LineStates"
             xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking" 
             xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
             mc:Ignorable="d" 
             sd:DiagramDesigner.DefaultSize="1370,380"
             sd:DiagramDesigner.ToolBarTitle="{Binding [生产-关键事项管控],Source={uic:L10N}}" 
             d:DesignHeight="195" d:DesignWidth="685"> 
    <dxlc:GroupBox Padding="-2">
        <dxlc:GroupBox.Header>
            <Label Height="36" FontSize="18" VerticalContentAlignment="Center">
                <TextBlock Name="lblTitle" Text="{Binding [关键事项管控],Source={uic:L10N}}"/>
            </Label>
        </dxlc:GroupBox.Header>
        <dx:DXTabControl Name="tcItems" Margin="5"  SnapsToDevicePixels="False" >
            <dx:DXTabItem Header="{Binding [月度计划],Source={uic:L10N}}" FontSize="15">
                <msch:MonthScheduleControl x:Name="monthControl"  Margin="-10" />
            </dx:DXTabItem>
            <dx:DXTabItem Header="{Binding [当班产量],Source={uic:L10N}}" FontSize="15">
                <local:ShiftProductionControl x:Name="shiftControl"  Margin="-10"/>
            </dx:DXTabItem>
            <!--功能未实现，先隐藏-->
            <!--<dx:DXTabItem Header="{Binding [产前准备],Source={uic:L10N}}" FontSize="15">
                <prore:ProductingReadyControl x:Name="proreControl"  Margin="-10"/>
            </dx:DXTabItem>-->
            <dx:DXTabItem Header="{Binding [产线状态],Source={uic:L10N}}" FontSize="15">
                <ls:LineStateControl  x:Name="itemControl"  Margin="-10"/>
            </dx:DXTabItem>
            <dx:DXTabItem Header="{Binding [AndonAbnormal] ,Source={uic:L10N},Converter={local:KeyEventConverter}, Mode=OneWay}" FontSize="15">
                <abnor:AndonAbnormalControl x:Name="logControl"  Margin="-10"/>
            </dx:DXTabItem>
        </dx:DXTabControl>
    </dxlc:GroupBox> 
</sd:ComponentItem>
