<sd:ComponentItem
    x:Class="SIE.Wpf.MES.Workbench.EmployeeManages.EmployeeManageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="clr-namespace:SIE.Wpf.MES.Workbench.Converters"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:lc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:local="clr-namespace:SIE.Wpf.MES.Workbench.EmployeeManages"
    xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
    xmlns:ui="http://schemas.siestudio.com/winfx/xaml/controls"
    xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
    xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
    sd:DiagramDesigner.DefaultSize="432,360"
    sd:DiagramDesigner.ToolBarTitle="{Binding [生产-人员出勤], Source={uic:L10N}}" Height="360" Width="432">

    <sd:ComponentItem.Resources>
        <ControlTemplate x:Key="groupBoxNormalTemplate" TargetType="dxlc:GroupBox">
            <dx:Container>
                <Border
                    x:Name="BorderElement"
                    dx:BorderExtensions.ClipChild="True"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}">
                    <StackPanel Orientation="Vertical">
                        <Grid
                            Height="35"
                            Background="{TemplateBinding TitleBackground}"
                            Visibility="{TemplateBinding TitleVisibility}">
                            <dx:DXContentPresenter
                                x:Name="DXContentPresenter1"
                                Margin="4,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Header}"
                                ContentTemplate="{TemplateBinding HeaderTemplate}" />
                        </Grid>
                        <dx:DXContentPresenter
                            x:Name="ContentElement"
                            Margin="{TemplateBinding Margin}"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding CurrentContentTemplate}" />
                    </StackPanel>
                </Border>
            </dx:Container>
        </ControlTemplate>
        <Style TargetType="dxlc:GroupBox">
            <Setter Property="NormalTemplate" Value="{StaticResource groupBoxNormalTemplate}" />
        </Style>
        <Style x:Key="{x:Type dx:SimpleButton}" TargetType="{x:Type dx:SimpleButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type dx:SimpleButton}">
                        <Border
                            x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid x:Name="grid">
                                <ContentPresenter
                                    x:Name="contentPresenter"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    RecognizesAccessKey="True"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BorderCountStyle" TargetType="Border">
            <Setter Property="Background" Value="#C1E0F9" />
            <Setter Property="Height" Value="90" />
        </Style>
        <Style x:Key="BorderEmpStyle" TargetType="Border">
            <Setter Property="Background" Value="#E7F3FD" />
            <Setter Property="BorderBrush" Value="#128BEF" />
        </Style>
        <Style x:Key="NumberLabelStyle" TargetType="Label">
            <Setter Property="FontSize" Value="42" />
            <Setter Property="FontFamily" Value="MicrosoftYaHei" />
            <Setter Property="FontWeight" Value="400" />
            <Setter Property="VerticalContentAlignment" Value="Bottom" />
        </Style>
        <Style x:Key="PersonLabelStyle" TargetType="Label">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="MicrosoftYaHei" />
            <Setter Property="FontWeight" Value="400" />
            <Setter Property="Foreground" Value="#201F35" />
        </Style>
        <Style x:Key="toolLabelStyle" TargetType="Label">
            <Setter Property="Background" Value="#F1F1F1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontFamily" Value="MicrosoftYaHei" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Padding" Value="3,0,0,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </sd:ComponentItem.Resources>

    <lc:GroupBox Padding="-2">
        <lc:GroupBox.Header>
            <Label
                Height="36"
                VerticalContentAlignment="Center"
                FontSize="18">
                <TextBlock Name="lblTitle" Text="{Binding [员工管理], Source={uic:L10N}}" />
            </Label>
        </lc:GroupBox.Header>
        <Grid Name="ctlManage" Background="{DynamicResource {uit:BrushesThemeKey ResourceKey=Background}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="90" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="#F1F5FF">
                <Grid.Resources>
                    <Style TargetType="{x:Type dx:SimpleButton}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type dx:SimpleButton}">
                                    <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                                        <Grid x:Name="grid"> 
                                            <ContentPresenter x:Name="contentPresenter" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Opacity" Value="0.7"></Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Opacity" Value="1"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Resources>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Grid IsEnabled="{Binding ElementName=btnSetting, Path=Visibility, Converter={converter:VisiblityToBoolConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Label
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        Content="{Binding [产线], Source={uic:L10N}}" />
                    <local:LineLookUpEditor
                        x:Name="ctlLine"
                        Grid.Column="1"
                        Height="24"
                        Margin="2,0,0,0" />
                    <Label
                        Grid.Column="2"
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        Content="{Binding [班次], Source={uic:L10N}}" />
                    <local:ShiftLookUpEditor
                        Grid.Column="3"
                        Height="24"
                        Margin="2,0,0,0" />
                </Grid>
                <dx:SimpleButton
                    Name="btnSetting"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Click="Setting_MouseDown" Margin="0,0,5,0">
                    <Grid Background="Transparent">
                        <ui:PackIcon
                        Height="20"
                        Foreground="#128BEF"
                        Kind="ConfigItem" />
                    </Grid>
                </dx:SimpleButton>
                <StackPanel
                    Name="btnYesNo"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Visibility="Hidden" Margin="0,0,5,0">
                    <dx:SimpleButton Name="btnYes" Click="Yes_MouseDown">
                        <Grid Background="Transparent">
                            <ui:PackIcon 
                            Height="20"
                            Foreground="Green"
                            Kind="CheckCircle"/>
                        </Grid>
                    </dx:SimpleButton>
                    <dx:SimpleButton
                        Name="btnNo"
                        Margin="5,0,0,0"
                        Click="No_MouseDown">
                        <Grid Background="Transparent">
                            <ui:PackIcon 
                            Height="20"
                            Foreground="Red"
                            Kind="ClearContent" />
                        </Grid>
                    </dx:SimpleButton>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="5,5,5,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.6*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Background="#C1E0F9">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Label
                        HorizontalAlignment="Center"
                        Content="{Binding DueQty, Converter={converter:IntToStringConverter}}"
                        Foreground="#128BEF"
                        Style="{StaticResource NumberLabelStyle}" />
                    <Label
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalContentAlignment="Top"
                        Content="{Binding [应到人数], Source={uic:L10N}}" />
                </Grid>
                <Grid
                    Grid.Column="1"
                    Margin="5,0,5,0"
                    Background="#C1E0F9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1.5*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <ui:PackIcon
                            Grid.RowSpan="2"
                            Width="45"
                            Height="48"
                            Foreground="#128BEF"
                            Kind="WorkerNew" />
                        <ui:PackIcon
                            Width="20"
                            Height="20"
                            Margin="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Foreground="#5BB65E"
                            Kind="CheckCircle" />
                    </Grid>
                    <Label
                        Grid.Row="0"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        Content="{Binding ArrivedQty, Converter={converter:ArrivedQtyConverter}}"
                        Foreground="#5BB65E"
                        Style="{StaticResource NumberLabelStyle}" />
                    <Label
                        Grid.Row="1"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalContentAlignment="Top"
                        Content="{Binding [已到人数], Source={uic:L10N}}" />
                </Grid>
                <Grid Grid.Column="2" Background="#C1E0F9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1.5*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <ui:PackIcon
                            Grid.RowSpan="2"
                            Width="45"
                            Height="48"
                            Foreground="#128BEF"
                            Kind="WorkerNew" />
                        <ui:PackIcon
                            Width="20"
                            Height="20"
                            Margin="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Foreground="#E33043"
                            Kind="AlertCircle" />
                    </Grid>
                    <Label
                        Grid.Row="0"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        Content="{Binding AbsenteeismQty, Converter={converter:IntToStringConverter}}"
                        Foreground="#E33043"
                        Style="{StaticResource NumberLabelStyle}" />
                    <Label
                        Grid.Row="1"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalContentAlignment="Top"
                        Content="{Binding [缺勤人数], Source={uic:L10N}}" />
                </Grid>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="30" />
                </Grid.RowDefinitions>
                <ScrollViewer
                    MinHeight="150"
                    MaxHeight="150"
                    Margin="4"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <ItemsControl Name="ctlEmp" ItemsSource="{Binding Employees}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="5"
                                    BorderThickness="1"
                                    CornerRadius="1">

                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Path=IsOnLoan}" Value="false">
                                                    <Setter Property="BorderBrush">
                                                        <Setter.Value>
                                                            <DrawingBrush
                                                                TileMode="Tile"
                                                                Viewport="0,0,8,8"
                                                                ViewportUnits="Absolute">
                                                                <DrawingBrush.Drawing>
                                                                    <DrawingGroup>
                                                                        <GeometryDrawing Brush="#128BEF">
                                                                            <GeometryDrawing.Geometry>
                                                                                <GeometryGroup>
                                                                                    <RectangleGeometry Rect="0,0,50,50" />
                                                                                    <RectangleGeometry Rect="50,50,50,50" />
                                                                                </GeometryGroup>
                                                                            </GeometryDrawing.Geometry>
                                                                        </GeometryDrawing>
                                                                    </DrawingGroup>
                                                                </DrawingBrush.Drawing>
                                                            </DrawingBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Path=IsOnLoan}" Value="true">
                                                    <Setter Property="BorderBrush">
                                                        <Setter.Value>
                                                            <DrawingBrush
                                                                TileMode="Tile"
                                                                Viewport="0,0,8,8"
                                                                ViewportUnits="Absolute">
                                                                <DrawingBrush.Drawing>
                                                                    <DrawingGroup>
                                                                        <GeometryDrawing Brush="#128BEF">
                                                                            <GeometryDrawing.Geometry>
                                                                                <GeometryGroup>
                                                                                    <RectangleGeometry Rect="0,0,50,50" />
                                                                                </GeometryGroup>
                                                                            </GeometryDrawing.Geometry>
                                                                        </GeometryDrawing>
                                                                    </DrawingGroup>
                                                                </DrawingBrush.Drawing>
                                                            </DrawingBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>

                                    </Border.Style>

                                    <Grid Name="gridEmployee"
                                        Background="#E7F3FD"
                                        Tag="{Binding}">
                                        <Grid.Resources>
                                            <Style x:Key="delButtonStyle" TargetType="{x:Type dx:SimpleButton}">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type dx:SimpleButton}">
                                                            <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                                                                <Grid x:Name="grid">
                                                                    <ContentPresenter  x:Name="contentPresenter" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                                </Grid>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter Property="Opacity" Value="0.3"></Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="true">
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Resources>
                                        <Grid Width="64"
                                            Height="70"
                                            Opacity="{Binding IsAbsenteeism, Converter={converter:BoolToOpacityConverter}}"
                                            Visibility="{Binding ElementName=btnAddEmployee, Path=Visibility, Converter={converter:BoolConverter}}">
                                            <Grid>
                                                <Grid.ToolTip>
                                                    <ToolTip>
                                                        <Border
                                                        Width="236"
                                                        Height="128"
                                                        Margin="-8,-4,-8,-5"
                                                        Background="White"
                                                        BorderBrush="#128BEF"
                                                        BorderThickness="1">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="30" />
                                                                    <RowDefinition Height="98" />
                                                                </Grid.RowDefinitions>
                                                                <Grid Background="#F1F5FF">
                                                                    <Label
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Content="人员信息"
                                                                    FontFamily="MicrosoftYaHei"
                                                                    FontSize="14"
                                                                    Style="{x:Null}" />
                                                                </Grid>
                                                                <Grid Grid.Row="1" Margin="5,5,0,5">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Image
                                                                    Width="72"
                                                                    Height="84"
                                                                    Source="{Binding Photo, Converter={converter:ByteToImageConverter}}" />
                                                                    <Grid Width="72" Height="84">
                                                                        <ui:PackIcon
                                                                        Width="62"
                                                                        Height="66"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Bottom"
                                                                        Foreground="#128BEF"
                                                                        Kind="WorkerNew"
                                                                        Visibility="{Binding Photo, Converter={converter:ByteToVisibilityConverter}}" />
                                                                    </Grid>
                                                                    <Grid Grid.Column="1" Margin="10,0,0,0">
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="*" />
                                                                            <RowDefinition Height="*" />
                                                                            <RowDefinition Height="*" />
                                                                            <RowDefinition Height="*" />
                                                                        </Grid.RowDefinitions>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="62" />
                                                                            <ColumnDefinition Width="74" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <Label
                                                                        Grid.Row="0"
                                                                        Grid.Column="0"
                                                                        Style="{StaticResource toolLabelStyle}">
                                                                            工号
                                                                        </Label>
                                                                        <Label
                                                                        Grid.Row="0"
                                                                        Grid.Column="1"
                                                                        Content="{Binding No}"
                                                                        Foreground="#128BEF"
                                                                        Style="{StaticResource toolLabelStyle}" />
                                                                        <Label
                                                                        Grid.Row="1"
                                                                        Grid.Column="0"
                                                                        Style="{StaticResource toolLabelStyle}">
                                                                            员工
                                                                        </Label>
                                                                        <Label
                                                                        Grid.Row="1"
                                                                        Grid.Column="1"
                                                                        Content="{Binding Name}"
                                                                        Foreground="#128BEF"
                                                                        Style="{StaticResource toolLabelStyle}" />
                                                                        <Label
                                                                        Grid.Row="2"
                                                                        Grid.Column="0"
                                                                        Style="{StaticResource toolLabelStyle}">
                                                                            员工类型
                                                                        </Label>
                                                                        <Label
                                                                        Grid.Row="2"
                                                                        Grid.Column="1"
                                                                        Content="{Binding Type}"
                                                                        Foreground="#128BEF"
                                                                        Style="{StaticResource toolLabelStyle}" />
                                                                        <Label
                                                                        Grid.Row="3"
                                                                        Grid.Column="0"
                                                                        Style="{StaticResource toolLabelStyle}">
                                                                            资质认证
                                                                        </Label>
                                                                        <Label
                                                                        Grid.Row="3"
                                                                        Grid.Column="1"
                                                                        Content="{Binding Aptitudes}"
                                                                        Foreground="#128BEF"
                                                                        Style="{StaticResource toolLabelStyle}" />
                                                                    </Grid>
                                                                </Grid>
                                                            </Grid>
                                                        </Border>
                                                    </ToolTip>
                                                </Grid.ToolTip>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="2*" />
                                                    <RowDefinition Height="1*" />
                                                </Grid.RowDefinitions>
                                                <ui:PackIcon
                                                Width="36"
                                                Height="36"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="#128BEF"
                                                IsEnabled="{Binding IsAbsenteeism, Converter={converter:BoolConverter}}"
                                                Kind="WorkerNew"
                                                Opacity="{Binding IsAbsenteeism, Converter={converter:isAbsenteeismToOpactiyConverter}}"
                                                Visibility="{Binding ElementName=btnAddEmployee, Path=Visibility, Converter={converter:BoolConverter}}" />
                                                <Label
                                                Grid.Row="1"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                Content="{Binding Name}"
                                                FontSize="12" />
                                            </Grid>
                                            <dx:SimpleButton HorizontalAlignment="Right" HorizontalContentAlignment="Center" VerticalContentAlignment="Top" Click="DeleteEmployee" Margin="0,2,2,0" Style="{StaticResource delButtonStyle}">
                                                <ui:PackIcon Kind="DoNotDisturb" Foreground="Red" Height="14" Width="14"></ui:PackIcon>
                                            </dx:SimpleButton>
                                        </Grid>
                                        <dx:SimpleButton
                                            Name="btnAddEmployee"
                                            Width="60"
                                            Height="60"
                                            Background="#E7F3FD"
                                            Click="AddOnLoanEmployee"
                                            Visibility="{Binding AddEmployee, Converter={converter:BoolToVisibilityConverter}}">
                                            <dx:SimpleButton.Content>
                                                <ui:PackIcon
                                                    Width="24"
                                                    Height="24"
                                                    Foreground="#128BEF"
                                                    Kind="Add" />
                                            </dx:SimpleButton.Content>
                                        </dx:SimpleButton>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel IsItemsHost="True" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>
                <Grid Grid.Row="1" Background="#F1F1F1">
                    <Label Content="{Binding EmployeeType}" Margin="5,0,0,0" FontSize="12" VerticalContentAlignment="Center"></Label> 
                </Grid>
            </Grid>
        </Grid>
    </lc:GroupBox>
</sd:ComponentItem>
