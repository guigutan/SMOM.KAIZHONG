<sd:ComponentItem xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"   x:Class="SIE.Wpf.MES.Workbench.Fpy.FpyWorkBenchControl"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                   xmlns:local="clr-namespace:SIE.Wpf.MES.Workbench.Fpy"
                   xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
                   xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
                   xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core" 
                   xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
                   mc:Ignorable="d" 
                   sd:DiagramDesigner.ToolBarTitle="{Binding [生产-产线直通率],Source={uic:L10N}}"
                   sd:DiagramDesigner.DefaultSize="350,304"            
                   d:DesignHeight="304" d:DesignWidth="350" >
    <sd:ComponentItem.Resources>
        <ResourceDictionary>
            <dxc:BrushOverlayConverter x:Key="brushOverlayConverter" />
        </ResourceDictionary>
    </sd:ComponentItem.Resources>
    <dxlc:GroupBox Padding="-2">
        <dxlc:GroupBox.Header>
            <Label Height="36" FontSize="18" VerticalContentAlignment="Center">
                <TextBlock Name="lblTitle" Text="{Binding [直通率],Source={uic:L10N}}"/>
            </Label>
        </dxlc:GroupBox.Header>

        <Grid Background="{DynamicResource {uit:BrushesThemeKey ResourceKey=Background}}">
            <Border BorderThickness="1" BorderBrush="#CCCCCC" CornerRadius="2">
                <Grid x:Name="chartGrid" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="89*"/>
                        <ColumnDefinition Width="241*"/>
                    </Grid.ColumnDefinitions>
                    <dxc:ChartControl Visibility="Collapsed"  Background="Transparent" MouseDown="chartGrid_MouseDown" x:Name="LineChart" AnimationMode="OnDataChanged"   BorderThickness="0" BorderBrush="Transparent"
                              SelectionMode="Single" SeriesSelectionMode="Point" Grid.ColumnSpan="2">
                        <dxc:XYDiagram2D  Margin="-5"  PaneOrientation="Vertical" EqualBarWidth="True" x:Name="LineView" RenderTransformOrigin="0,0" BarDistance="0" LabelsResolveOverlappingMinIndent="5" >
                            <dxc:XYDiagram2D.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform/>
                                    <SkewTransform AngleY="-0.103"/>
                                    <RotateTransform/>
                                    <TranslateTransform Y="-0.332"/>
                                </TransformGroup>
                            </dxc:XYDiagram2D.RenderTransform>
                            <dxc:XYDiagram2D.DefaultPane>
                                <dxc:Pane DomainBrush="Transparent" Foreground="Black" />
                            </dxc:XYDiagram2D.DefaultPane>

                            <dxc:XYDiagram2D.AxisY>
                                <dxc:AxisY2D TickmarksMinorVisible="True" Brush="{x:Null}" Thickness="0" GridLinesVisible="True"
                                     Interlaced="False" TickmarksVisible="True">
                                    <dxc:AxisY2D.CustomLabels>
                                        <dxc:CustomAxisLabel Content="0%" Value="0"/>
                                        <dxc:CustomAxisLabel Content="20%" Value="20"/>
                                        <dxc:CustomAxisLabel Content="40%" Value="40"/>
                                        <dxc:CustomAxisLabel Content="60%" Value="60"/>
                                        <dxc:CustomAxisLabel Content="80%" Value="80"/>
                                        <dxc:CustomAxisLabel Content="100%" Value="100"/>
                                    </dxc:AxisY2D.CustomLabels>
                                    <dxc:AxisY2D.WholeRange>
                                        <dxc:Range MaxValue="100" MinValue="0" AutoSideMargins="False"/>
                                    </dxc:AxisY2D.WholeRange>
                                    <dxc:AxisY2D.Label>
                                        <dxc:AxisLabel  Background="Transparent"  FontSize="8" Foreground="Black" />
                                    </dxc:AxisY2D.Label>
                                </dxc:AxisY2D>
                            </dxc:XYDiagram2D.AxisY>
                            <dxc:XYDiagram2D.AxisX>
                                <dxc:AxisX2D Brush="Transparent" LabelVisibilityMode="Default"  >
                                    <dxc:AxisX2D.QualitativeScaleOptions>
                                        <dxc:QualitativeScaleOptions AutoGrid="False"></dxc:QualitativeScaleOptions>
                                        <!--AutoGrid 设置为False 取消合并-->
                                    </dxc:AxisX2D.QualitativeScaleOptions>
                                    <dxc:AxisX2D.Label>
                                        <dxc:AxisLabel  Background="Transparent"  FontSize="8" Foreground="Black" >
                                            <dxc:Axis2D.ResolveOverlappingOptions>
                                                <dxc:AxisLabelResolveOverlappingOptions  AllowHide="False" AllowRotate="False" AllowStagger="True" MinIndent="5"  />
                                                <!--AllowHide  是否允许隐藏-->
                                                <!--AllowRotate  是否允许倾斜显示-->
                                                <!--AllowStagger 是否允许标签之间上下错位显示-->
                                            </dxc:Axis2D.ResolveOverlappingOptions>
                                        </dxc:AxisLabel>
                                    </dxc:AxisX2D.Label>
                                </dxc:AxisX2D>
                            </dxc:XYDiagram2D.AxisX>

                            <dxc:BarSideBySideSeries2D DisplayName="BarSeries" LabelsVisibility="True" ColorEach="False" 
                                               BarWidth="0.2" ArgumentScaleType="Qualitative"  CrosshairEnabled="True" CrosshairLabelVisibility="True"
                                               ArgumentDataMember="ProcessName" DataSource="{Binding}"
                                               ValueDataMember="FpyRate"  AnimationAutoStartMode="SetStartState">
                                <dxc:BarSideBySideSeries2D.Model>
                                    <!--<dxc:BorderlessSimpleBar2DModel/>-->
                                    <dxc:CustomBar2DModel>
                                        <dxc:CustomBar2DModel.PointTemplate>
                                            <ControlTemplate>
                                                <Grid>
                                                    <Border CornerRadius="10,10,10,10" Margin="1,1,1,0">
                                                        <Border.Background>
                                                            <Binding Path="PointColor" Converter="{StaticResource brushOverlayConverter}">
                                                                <Binding.ConverterParameter>
                                                                    <LinearGradientBrush EndPoint="0,0.5" StartPoint="1,0.5">
                                                                        <GradientStop Color="#138CEF" Offset="0" />
                                                                        <GradientStop Color="#138CEF" Offset="1" />
                                                                    </LinearGradientBrush>
                                                                </Binding.ConverterParameter>
                                                            </Binding>
                                                        </Border.Background>
                                                    </Border>
                                                </Grid>
                                            </ControlTemplate>
                                        </dxc:CustomBar2DModel.PointTemplate>
                                    </dxc:CustomBar2DModel>
                                </dxc:BarSideBySideSeries2D.Model>

                                <dxc:BarSideBySideSeries2D.Label>
                                    <dxc:SeriesLabel  ConnectorVisible="False" Indent="0" dxc:BarSideBySideSeries2D.LabelPosition="Outside">
                                        <dxc:SeriesLabel.ElementTemplate>
                                            <DataTemplate>
                                                <Label Content="{Binding Text}" FontSize="8" Foreground="Black"/>
                                            </DataTemplate>
                                        </dxc:SeriesLabel.ElementTemplate>
                                    </dxc:SeriesLabel>
                                </dxc:BarSideBySideSeries2D.Label>
                                <!--<dxc:BarSideBySideSeries2D.Points>
                             <dxc:SeriesPoint Argument="1" Value="90"></dxc:SeriesPoint>
                             <dxc:SeriesPoint Argument="2" Value="20"></dxc:SeriesPoint>
                             <dxc:SeriesPoint Argument="3" Value="30"></dxc:SeriesPoint>
                             </dxc:BarSideBySideSeries2D.Points>-->
                            </dxc:BarSideBySideSeries2D>
                        </dxc:XYDiagram2D>
                        <dxc:ChartControl.Legend>
                            <dxc:Legend HorizontalPosition="Right" Visibility="Collapsed" />
                        </dxc:ChartControl.Legend>

                    </dxc:ChartControl>
                    <Grid x:Name="PieGrid" Background="Transparent" MouseDown="PieGrid_MouseDown" Grid.ColumnSpan="2">
                        <Canvas Name="img" SizeChanged="img_SizeChanged" >
                        </Canvas>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal" Margin="26,0,0,0">
                            <Label Content="0" VerticalAlignment="Center" HorizontalAlignment="Center" Name="laPercentVal" FontSize="60"></Label>
                            <Label Content="%" VerticalAlignment="Bottom" HorizontalContentAlignment="Center" FontSize="18" Width="26" Name="laPercentFH" ></Label>
                        </StackPanel>
                        <Grid Height="34" Width="100" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,10" Name="gridEnt">
                            <Rectangle Fill="#5CB65E"   RadiusX="20" RadiusY="20" Name="recEnt">
                            </Rectangle>
                            <Label Foreground="White" Content="" FontSize="14"  FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" Name="laEnt"></Label>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </dxlc:GroupBox>
</sd:ComponentItem>
