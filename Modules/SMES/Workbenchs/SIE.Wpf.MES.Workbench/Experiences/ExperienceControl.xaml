<sd:ComponentItem xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"  xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"  x:Class="SIE.Wpf.MES.Workbench.Experiences.ExperienceControl"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                  xmlns:local="clr-namespace:SIE.Wpf.MES.Workbench.Experiences"
                  xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
                  xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
                  xmlns:icon="http://schemas.siestudio.com/winfx/xaml/controls" 
                  xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
                  xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                  xmlns:dxl="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                  sd:DiagramDesigner.ToolBarTitle="{Binding [生产-历史经验库],Source={uic:L10N}}"
                  sd:DiagramDesigner.DefaultSize="738,304"
                  mc:Ignorable="d" 
                  d:DesignHeight="300" d:DesignWidth="738">
    <sd:ComponentItem.Resources>
        <ResourceDictionary>
            <ControlTemplate x:Key="buttonTemplate" TargetType="Button">
                <Ellipse Fill="{TemplateBinding Foreground}" Height="5" Width="5" Margin="4,0,4,0"></Ellipse>
            </ControlTemplate>
        </ResourceDictionary>
    </sd:ComponentItem.Resources>
    <dxlc:GroupBox Padding="-2">
        <dxlc:GroupBox.Header>
            <Label Height="36" FontSize="18" VerticalContentAlignment="Center">
                <TextBlock Name="lblTitle" Text="{Binding [历史经验库],Source={uic:L10N}}"/>
            </Label>
        </dxlc:GroupBox.Header>
        <Grid Background="{DynamicResource {uit:BrushesThemeKey ResourceKey=Background}}">
            <Grid.CommandBindings>
                <CommandBinding Command="{x:Static local:ExperienceControl.Previous}" Executed="PreviousCommand_Executed" CanExecute="PreviousBinding_CanExecute"></CommandBinding>
                <CommandBinding Command="{x:Static local:ExperienceControl.Next}" Executed="NextCommand_Executed" CanExecute="NextBinding_CanExecute"></CommandBinding>
                <CommandBinding Command="{x:Static local:ExperienceControl.PreviousPage}" Executed="PrePageCommand_Executed" CanExecute="PrePageBinding_CanExecute"></CommandBinding>
                <CommandBinding Command="{x:Static local:ExperienceControl.NextPage}" Executed="NextPageCommand_Executed" CanExecute="NextPageBinding_CanExecute"></CommandBinding>
                <CommandBinding Command="{x:Static local:ExperienceControl.CenterPage}" Executed="CenterPageCommand_Executed" CanExecute="CenterPageBinding_CanExecute"></CommandBinding>
            </Grid.CommandBindings>
            <dxl:DockLayoutControl>
                <Border Margin="0,0,0,50" Width="50" dxl:DockLayoutControl.Dock="Left">
                    <Button x:Name="preBtn"  Width="30" Height="58" Margin="0,0,0,0" HorizontalAlignment="Right" Foreground="Black" Command="{x:Static local:ExperienceControl.Previous}"  Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
                        <Button.Content>
                            <icon:PackIcon Kind="ChevronLeft" Height="17" Width="10" Background="Transparent"></icon:PackIcon>
                        </Button.Content>
                    </Button>
                </Border>
                <Border Margin="0,0,0,50" Width="40" dxl:DockLayoutControl.Dock="Right">
                    <Button x:Name="nextBtn" Width="30"  Height="58" Margin="0,0,0,0" HorizontalAlignment="Left"  Foreground="Black" Command="{x:Static local:ExperienceControl.Next}"  Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
                        <Button.Content>
                            <icon:PackIcon Kind="ChevronRight" Height="17" Width="10" Background="Transparent" ></icon:PackIcon>
                        </Button.Content>
                    </Button>
                </Border>
                <Border Height="20"  dxl:DockLayoutControl.Dock="Bottom">
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <Button x:Name="prePgBtn" Template="{StaticResource buttonTemplate}" Command="{x:Static local:ExperienceControl.PreviousPage}" Foreground="#128BEF"></Button>
                        <Button x:Name="cetPgBtbn" Template="{StaticResource buttonTemplate}" Command="{x:Static local:ExperienceControl.CenterPage}" Foreground="#A6A6A6"></Button>
                        <Button x:Name="nxetPgBtn" Template="{StaticResource buttonTemplate}" Command="{x:Static local:ExperienceControl.NextPage}" Foreground="#A6A6A6"></Button>
                    </StackPanel>
                </Border>
                <ItemsControl x:Name="imageItems" Margin="0,5,0,0" dxl:DockLayoutControl.Dock="Client" ItemsSource="{Binding}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel HorizontalAlignment="Center" x:Name="grid">
                                <Border BorderThickness="3" BorderBrush="{Binding IsRight, Converter={local:IsOkToBrushConverter}}">
                                    <Grid >
                                        <dxe:ImageEdit Source="{Binding Photo,Converter={local:ByteToImageSourceConverter}}" Width="295" Height="212" Margin="5,5,5,2.5" IsReadOnly="True"></dxe:ImageEdit>
                                        <Label HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="20" FontWeight="Black" Content="{Binding IsRight, Converter={local:IsOkToDescripConverter}}" Background="{Binding IsRight, Converter={local:IsOkToBrushConverter}}" Width="50" Height="30" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Bottom"></Label>
                                    </Grid>
                                </Border>
                                <!--<Label HorizontalAlignment="Center" FontSize="14" Content="{Binding Description}" Foreground="{Binding IsOk, Converter={local:IsOkToBrushConverter}}" Margin="0,5,0,0"></Label>-->
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal" IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </dxl:DockLayoutControl>
        </Grid>
    </dxlc:GroupBox> 
</sd:ComponentItem>
