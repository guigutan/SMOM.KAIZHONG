<sd:ComponentItem x:Class="SIE.Wpf.MES.Workbench.CapacityDistributions.CapacityDisbuControl"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                  xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
                  xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
                  xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
                  xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
                  xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                  xmlns:local="clr-namespace:SIE.Wpf.MES.Workbench.CapacityDistributions"
                  sd:DiagramDesigner.ToolBarTitle="{Binding [生产-当日产能分布], Source={uic:L10N}}"
                  sd:DiagramDesigner.DefaultSize="1462,268"
                  mc:Ignorable="d" 
                  d:DesignHeight="450" d:DesignWidth="800">
    <sd:ComponentItem.Resources>
        <dxc:CustomRangeBar2DModel x:Key="bluebarModel">
            <dxc:CustomRangeBar2DModel.PointTemplate>
                <ControlTemplate>
                    <Grid x:Name="grid">
                        <!--<Border CornerRadius="7,7,7,7" Margin="1,1,1,0" Background="#22AAF3"/>-->
                        <Border  Background="#22AAF3" Margin="1,1,1,0" CornerRadius="{Binding ElementName=grid,Path=ActualWidth, Converter={local:RadiusConverterCapacity}, Mode=OneWay}"/>
                    </Grid>
                </ControlTemplate>
            </dxc:CustomRangeBar2DModel.PointTemplate>
        </dxc:CustomRangeBar2DModel>

        <dxc:CustomRangeBar2DModel x:Key="oragbarModel">
            <dxc:CustomRangeBar2DModel.PointTemplate>
                <ControlTemplate>
                    <Grid x:Name="grid">
                        <!--<Border CornerRadius="7,7,7,7" Margin="1,1,1,0" Background="#FE7201"/>-->
                        <Border  Background="#FE7201" Margin="1,1,1,0" CornerRadius="{Binding ElementName=grid,Path=ActualWidth, Converter={local:RadiusConverterCapacity}, Mode=OneWay}"/>
                    </Grid>
                </ControlTemplate>
            </dxc:CustomRangeBar2DModel.PointTemplate>
        </dxc:CustomRangeBar2DModel>

        <dxc:CustomRangeBar2DModel x:Key="greenbarModel">
            <dxc:CustomRangeBar2DModel.PointTemplate>
                <ControlTemplate>
                    <Grid x:Name="grid">
                        <!--<Border CornerRadius="7,7,7,7" Margin="1,1,1,0" Background="#5BB65E"/>-->
                        <Border  Background="#5BB65E" Margin="1,1,1,0" CornerRadius="{Binding ElementName=grid,Path=ActualWidth, Converter={local:RadiusConverterCapacity}, Mode=OneWay}"/>
                    </Grid>
                </ControlTemplate>
            </dxc:CustomRangeBar2DModel.PointTemplate>
        </dxc:CustomRangeBar2DModel>

        <dxc:CustomRangeBar2DModel x:Key="yellowbarModel">
            <dxc:CustomRangeBar2DModel.PointTemplate>
                <ControlTemplate>
                    <Grid x:Name="grid">
                        <!--<Border CornerRadius="7,7,7,7" Margin="1,1,1,0" Background="#FFCC00"/>-->
                        <Border  Background="#FFCC00" Margin="1,1,1,0" CornerRadius="{Binding ElementName=grid,Path=ActualWidth, Converter={local:RadiusConverterCapacity}, Mode=OneWay}"/>
                    </Grid>
                </ControlTemplate>
            </dxc:CustomRangeBar2DModel.PointTemplate>
        </dxc:CustomRangeBar2DModel>

        <dxc:CustomRangeBar2DModel x:Key="redbarModel">
            <dxc:CustomRangeBar2DModel.PointTemplate>
                <ControlTemplate>
                    <Grid x:Name="grid">
                        <!--<Border CornerRadius="7,7,7,7" Margin="1,1,1,0" Background="#E33043"/>-->
                        <Border  Background="#E33043" Margin="1,1,1,0" CornerRadius="{Binding ElementName=grid,Path=ActualWidth, Converter={local:RadiusConverterCapacity}, Mode=OneWay}"/>
                    </Grid>
                </ControlTemplate>
            </dxc:CustomRangeBar2DModel.PointTemplate>
        </dxc:CustomRangeBar2DModel>

        <dxc:SeriesLabel x:Key="seriesLabel" ResolveOverlappingMode="JustifyAllAroundPoint" dxc:RangeBarSeries2D.LabelKind="MaxValueLabel" ConnectorVisible="False">
            <dxc:SeriesLabel.ElementTemplate>
                <DataTemplate>
                    <TextBox Text="{Binding Text}" Padding="-40,0,0,0" FontSize="10" IsReadOnly="True" Background="Transparent" BorderThickness="0"/>
                </DataTemplate>
            </dxc:SeriesLabel.ElementTemplate>
        </dxc:SeriesLabel>
    </sd:ComponentItem.Resources>
    <dxlc:GroupBox Padding="-2">
        <dxlc:GroupBox.Header>
            <Label Height="36" FontSize="18" VerticalContentAlignment="Center">
                <TextBlock Name="lblTitle" Text="{Binding [当日产能分布],Source={uic:L10N}}"/>
            </Label>
        </dxlc:GroupBox.Header>
        <Grid Background="{DynamicResource {uit:BrushesThemeKey ResourceKey=Background}}">
            <dxc:ChartControl x:Name="lineStutChart" Visibility="Visible" Height="120" VerticalAlignment="Bottom" Background="{x:Null}" BorderThickness="1" DataSource="{Binding}" CustomDrawCrosshair="LineStutChart_CustomDrawCrosshair">
                <dxc:ChartControl.CrosshairOptions>
                    <dxc:CrosshairOptions ShowGroupHeaders="False" CrosshairLabelMode="ShowForNearestSeries"
                                          ShowArgumentLabels="False" ShowArgumentLine="False"
                                          ShowValueLabels="False" ShowValueLine="False">
                    </dxc:CrosshairOptions>
                </dxc:ChartControl.CrosshairOptions>
                <dxc:XYDiagram2D x:Name="lineStutDiagram" BorderThickness="1" Height="80" Rotated="True" Visibility="Visible"  Margin="0,0,0,-100">
                    <dxc:XYDiagram2D.DefaultPane>
                        <dxc:Pane DomainBrush="{x:Null}" DomainBorderBrush="{x:Null}" BorderThickness="0" BorderBrush="{x:Null}"/>
                    </dxc:XYDiagram2D.DefaultPane>
                    <dxc:XYDiagram2D.AxisX>
                        <dxc:AxisX2D x:Name="lineAxisX" Visible="False" Foreground="{x:Null}" TickmarksMinorVisible="False" TickmarksVisible="False">
                            <dxc:AxisX2D.Title>
                                <dxc:AxisTitle Content="异常停线" Foreground="{x:Null}"></dxc:AxisTitle>
                            </dxc:AxisX2D.Title>
                            <dxc:AxisX2D.CrosshairAxisLabelOptions>
                                <dxc:CrosshairAxisLabelOptions Visibility="False" />
                            </dxc:AxisX2D.CrosshairAxisLabelOptions>
                            <dxc:AxisX2D.Label>
                                <dxc:AxisLabel  Background="Transparent" Visible="True" Visibility="Hidden" Foreground="{x:Null}">
                                    <dxc:Axis2D.ResolveOverlappingOptions>
                                        <dxc:AxisLabelResolveOverlappingOptions AllowHide="True" AllowRotate="False" AllowStagger="True"/>
                                        <!--AllowHide  是否允许隐藏 False
                                             AllowRotate  是否允许倾斜显示
                                             AllowStagger 是否允许标签之间上下错位显示-->
                                    </dxc:Axis2D.ResolveOverlappingOptions>
                                </dxc:AxisLabel>
                            </dxc:AxisX2D.Label>
                            <dxc:AxisX2D.CustomLabels>
                                <!--<dxc:CustomAxisLabel Value="0" Content="3600"/>-->
                            </dxc:AxisX2D.CustomLabels>
                            <dxc:AxisX2D.WholeRange>
                                <dxc:Range MinValue="0" MaxValue="1" SideMarginsValue="0"/>
                            </dxc:AxisX2D.WholeRange>
                            <dxc:AxisX2D.VisualRange>
                                <dxc:Range MinValue="0" MaxValue="1"/>
                            </dxc:AxisX2D.VisualRange>
                        </dxc:AxisX2D>
                    </dxc:XYDiagram2D.AxisX>
                    <dxc:XYDiagram2D.AxisY>
                        <dxc:AxisY2D x:Name="lineAxisY" Interlaced="False" GridLinesVisible="False" Visible="False" Visibility="Visible">
                            <dxc:AxisY2D.NumericScaleOptions>
                                <dxc:ContinuousNumericScaleOptions AutoGrid="False" GridSpacing="1"></dxc:ContinuousNumericScaleOptions>
                            </dxc:AxisY2D.NumericScaleOptions>
                            <dxc:AxisY2D.WholeRange>
                                <dxc:Range MinValue="0" MaxValue="1" SideMarginsValue="0"/>
                            </dxc:AxisY2D.WholeRange>
                            <dxc:AxisY2D.VisualRange>
                                <dxc:Range MinValue="0" MaxValue="1"/>
                            </dxc:AxisY2D.VisualRange>
                        </dxc:AxisY2D>
                    </dxc:XYDiagram2D.AxisY>
                </dxc:XYDiagram2D>

                <dxc:ChartControl.Legend>
                    <dxc:Legend HorizontalPosition="RightOutside" VerticalPosition="Center" Orientation="Vertical" Background="{x:Null}" Visibility="Hidden" Margin="0">
                        <dxc:Legend.CustomItems>
                            <dxc:CustomLegendItem MarkerBrush="#FE7201" Text="实际"/>
                            <dxc:CustomLegendItem MarkerBrush="#22AAF3" Text="目标"/>
                        </dxc:Legend.CustomItems>
                    </dxc:Legend>
                </dxc:ChartControl.Legend>
            </dxc:ChartControl>

            <dxc:ChartControl x:Name="cptyChart" Background="{x:Null}" Visibility="Visible" BorderThickness="1" DataSource="{Binding}" Margin="0,0,0,25">
                <dxc:ChartControl.CrosshairOptions>
                    <dxc:CrosshairOptions ShowGroupHeaders="False" 
                                          ShowArgumentLabels="True" ShowArgumentLine="True" 
                                          ShowValueLabels="False" ShowValueLine="False">
                    </dxc:CrosshairOptions>
                </dxc:ChartControl.CrosshairOptions>
                <dxc:XYDiagram2D x:Name="cptyDiagram" BorderThickness="1" >
                    <dxc:XYDiagram2D.DefaultPane>
                        <dxc:Pane DomainBrush="{x:Null}" DomainBorderBrush="{x:Null}" BorderThickness="0" BorderBrush="{x:Null}"/>
                    </dxc:XYDiagram2D.DefaultPane>
                    <dxc:XYDiagram2D.AxisX>
                        <dxc:AxisX2D x:Name="axisX" TickmarksVisible="False" TickmarksMinorVisible="False">
                            <dxc:AxisX2D.CrosshairAxisLabelOptions>
                                <dxc:CrosshairAxisLabelOptions Pattern="{}{A:F0}" />
                            </dxc:AxisX2D.CrosshairAxisLabelOptions>
                            <dxc:AxisX2D.NumericScaleOptions>
                                <dxc:ContinuousNumericScaleOptions AutoGrid="False" GridSpacing="1"></dxc:ContinuousNumericScaleOptions>
                            </dxc:AxisX2D.NumericScaleOptions>
                            <dxc:AxisX2D.Label>
                                <dxc:AxisLabel  Background="Transparent">
                                    <dxc:Axis2D.ResolveOverlappingOptions>
                                        <dxc:AxisLabelResolveOverlappingOptions AllowHide="True" AllowRotate="False" AllowStagger="False"/>
                                        <!--AllowHide  是否允许隐藏-->
                                        <!--AllowRotate  是否允许倾斜显示-->
                                        <!--AllowStagger 是否允许标签之间上下错位显示-->
                                    </dxc:Axis2D.ResolveOverlappingOptions>
                                </dxc:AxisLabel>
                            </dxc:AxisX2D.Label>
                        </dxc:AxisX2D>
                    </dxc:XYDiagram2D.AxisX>
                    <dxc:XYDiagram2D.AxisY>
                        <dxc:AxisY2D x:Name="axisY" BorderThickness="0" BorderBrush="{x:Null}" Interlaced="False" GridLinesVisible="False" TickmarksVisible="False" TickmarksMinorVisible="False" > 
                            <!--<dxc:AxisY2D.NumericScaleOptions>
                                <dxc:ContinuousNumericScaleOptions AutoGrid="False" GridSpacing="1"></dxc:ContinuousNumericScaleOptions>
                            </dxc:AxisY2D.NumericScaleOptions>-->
                            <dxc:AxisY2D.Title>
                                <dxc:AxisTitle Content="{Binding [产品数量/每小时],Source={uic:L10N}}"></dxc:AxisTitle>
                            </dxc:AxisY2D.Title>
                        </dxc:AxisY2D>
                    </dxc:XYDiagram2D.AxisY>
                    <dxc:XYDiagram2D.Series>
                        <dxc:RangeBarOverlappedSeries2D x:Name="planSeries" DisplayName="{Binding [目标], Source={uic:L10N}}" ArgumentDataMember="Argu" ValueDataMember="StartValue" Value2DataMember="PlanValue" ArgumentScaleType="Numerical" ValueScaleType="Numerical"
                                                        BarWidth="0.25" CrosshairLabelPattern="{}{S}:{V2}" Model="{StaticResource bluebarModel}" Label="{StaticResource seriesLabel}" Brush="#22AAF3" ShowInLegend="True">
                        </dxc:RangeBarOverlappedSeries2D>

                        <dxc:RangeBarOverlappedSeries2D x:Name="actualSeries" DisplayName="{Binding [实际], Source={uic:L10N}}" ArgumentDataMember="Argu" ValueDataMember="StartValue" Value2DataMember="ActualValue" ArgumentScaleType="Numerical" ValueScaleType="Numerical"
                                                        BarWidth="0.25" CrosshairLabelPattern="{}{S}:{V2}" Model="{StaticResource oragbarModel}" Label="{StaticResource seriesLabel}" Brush="#FE7201" ShowInLegend="True">
                        </dxc:RangeBarOverlappedSeries2D>

                        <dxc:RangeBarOverlappedSeries2D x:Name="planSeriesTwo" ArgumentDataMember="Argu" ValueDataMember="StartValue" Value2DataMember="PlanValueTwo" ArgumentScaleType="Numerical" ValueScaleType="Numerical"
                                                        BarWidth="0.25" CrosshairLabelVisibility="False"  Model="{StaticResource bluebarModel}" Label="{StaticResource seriesLabel}" Brush="#FE7201" ShowInLegend="False">
                        </dxc:RangeBarOverlappedSeries2D>
                    </dxc:XYDiagram2D.Series>
                </dxc:XYDiagram2D>
                <dxc:ChartControl.Legend>
                    <dxc:Legend HorizontalPosition="RightOutside" VerticalPosition="Center" Orientation="Vertical" Background="{x:Null}" Margin="0,0,0,0">
                        <dxc:Legend.CustomItems>
                            <!--<dxc:CustomLegendItem MarkerBrush="#FE7201" Text="实际"/>
                                 <dxc:CustomLegendItem MarkerBrush="#22AAF3" Text="目标"/>-->
                        </dxc:Legend.CustomItems>
                    </dxc:Legend>
                </dxc:ChartControl.Legend>
            </dxc:ChartControl>
        </Grid>
    </dxlc:GroupBox>
</sd:ComponentItem>