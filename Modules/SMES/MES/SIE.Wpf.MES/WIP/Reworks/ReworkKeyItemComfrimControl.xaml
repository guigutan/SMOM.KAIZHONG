<UserControl x:Class="SIE.Wpf.MES.WIP.Reworks.ReworkKeyItemComfrimControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.WIP.Reworks"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core" d:DataContext="{d:DesignInstance Type=local:ReworkKeyItemComfrimControl}"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel Background="White" Grid.Row="0" >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"></RowDefinition>
                    <RowDefinition Height="1*"></RowDefinition>
                    <RowDefinition Height="1*"></RowDefinition>
                    <RowDefinition Height="1*" ></RowDefinition>
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding [请确定物料置换后处理方式], Source={uic:L10N}}" FontSize="18" Grid.Row="0" Margin="20,10,0,0"></TextBlock>
                <StackPanel  Grid.Row="1" Orientation="Vertical"  Margin="20,20,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" >
                    <RadioButton IsChecked="{Binding SelectedCancelWay}" Content="{Binding [置换后作废], Source={uic:L10N}}" FontSize="18" GroupName="repalce" Margin="100,0,0,0"></RadioButton>
                    <RadioButton IsChecked="{Binding SelectedBlankingWay}" Content="{Binding [置换后不良下料], Source={uic:L10N}}" FontSize="18" GroupName="repalce" Margin="100,0,0,0"></RadioButton>
                    <RadioButton IsChecked="{Binding SelectedGoodBlankingWay}" Content="{Binding [置换后良品下料], Source={uic:L10N}}" FontSize="18" GroupName="repalce" Margin="100,0,0,0"></RadioButton>                
                </StackPanel>
                <StackPanel  Grid.Row="2" Orientation="Horizontal" Visibility="{Binding ShowWarehouseSelection ,Converter={local:IsShowHandelWayConverter}, Mode=TwoWay}" Margin="20,40,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" >
                    <TextBlock    Text="{Binding [下料目标线边仓], Source={uic:L10N}}" FontSize="18" Grid.Row="0" Margin="20,0,0,0"></TextBlock>
                    <ComboBox DisplayMemberPath="Name" SelectedValuePath="Id" ItemsSource="{Binding WarehouseList}"
                        FontSize="18" MinWidth="150"  Margin="50,0,0,0" SelectedItem="{Binding SelectedWarehouse}">
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Row="3" MinHeight="100"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Orientation="Horizontal">
                    <dx:SimpleButton
                x:Name="btnOk"
                Width="120"
                Height="30"
                Click="btnOk_Click"
                Content="{Binding [确定], Source={uic:L10N}}" />
                    <dx:SimpleButton
                x:Name="btnCancel"
                Width="120"
                Height="30"
                Margin="50,0,0,0"
                Click="btnCancel_Click"
                Content="{Binding [取消], Source={uic:L10N}}" />
                </StackPanel>
            </Grid>

        </StackPanel>
    </Grid>
</UserControl>
