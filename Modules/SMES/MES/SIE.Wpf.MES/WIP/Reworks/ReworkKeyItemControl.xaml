<UserControl x:Class="SIE.Wpf.MES.WIP.Reworks.ReworkKeyItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.WIP.Reworks"
             mc:Ignorable="d" 
             DataContext="{Binding ReworkViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Name="gdKeyItem" Width="Auto">
        <ScrollViewer  HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" DockPanel.Dock="Bottom">
            <ItemsControl Name="ctlKeyItem" Height="Auto">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <dx:SimpleButton Margin="5,5,5,5" Tag="{Binding}" x:Name="btnSelected" Click="BtnKeyItem_Click">
                            <Grid >
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1*"/>
                                    <RowDefinition Height="2*"/>
                                    <RowDefinition Height="2*"/>
                                    <RowDefinition Height="1*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0, -5, -5, -5" Text="{Binding Qty}"/>
                                <Label Grid.Row="1" Grid.Column="0" Content="{Binding [物料编码:], Source={uic:L10N}}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                <Label Grid.Row="1" Grid.Column="1" Content="{Binding  Item.Code }" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0" />
                                <Label Grid.Row="2" Grid.Column="0" Content="{Binding SourceType , Converter={local:SourceTypeConverter}, Mode=OneWay }" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                <Label Grid.Row="2" Grid.Column="1" Content="{Binding SourceCode }" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0" />                                
                                <CheckBox x:Uid="chkbox"  Grid.Row="3" Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0, -10,-5,0" 
                                        IsChecked="{Binding IsUnbound ,Converter={local:IsUnboundConverter}, Mode=TwoWay}"  
                                        Visibility="{Binding DataContext.ReworkOperate ,RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={local:CheckBoxVisibleConverter}, Mode=OneWay }"/>
                                <!--<TextBlock VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0 0 -1 0" Text="{Binding Qty}" 
                                         Visibility="{Binding Control.AllowQty,Converter={StaticResource QtyVisibilityConverter}}" />-->
                            </Grid>
                        </dx:SimpleButton>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True"></WrapPanel>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
