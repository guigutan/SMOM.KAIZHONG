<UserControl x:Class="SIE.Wpf.MES.WIP.Reworks.ReworkControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SIE.Wpf.MES.WIP.Reworks"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Name="gdReworkCtl" HorizontalAlignment="Stretch" Width="Auto">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ContentControl  Grid.Column="0" Name="cclCollectDetails"  ></ContentControl>
        <ContentControl  Grid.Column="1"  Name="cclKeyItems"   ></ContentControl>
        <CheckBox Margin="-110,0,0,0" Grid.Column="2" Name="chkSelectAll" Content="{Binding [解绑全部关键件], Source={uic:L10N} }"  Click="ChkSelectAll_Click" 
                  IsChecked="{Binding IsSelectedAll, Mode=TwoWay}"  Visibility="{Binding ReworkOperate ,Converter={local:CheckBoxVisibleConverter}, Mode=OneWay }" />
    </Grid>
</UserControl>
