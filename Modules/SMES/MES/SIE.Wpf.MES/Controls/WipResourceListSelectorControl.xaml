<UserControl x:Class="SIE.Wpf.MES.Controls.WipResourceListSelectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">
    <UserControl.Resources>
        <!-- 箭头按钮通用样式 -->
        <Style x:Key="ArrowButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="3,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6" Background="#4A90E2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#357ABD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2868A3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 确定按钮样式 -->
        <Style x:Key="ConfirmBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Background="#4A90E2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#357ABD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2868A3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 取消按钮样式 -->
        <Style x:Key="CancelBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Background="#FF6B6B">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E55555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CC4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- 主布局：唯美渐变背景 -->
    <Grid Cursor="">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F0F9FF" Offset="0.0"/>
                <GradientStop Color="#E6F4FF" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Border Grid.Row="0" Background="#4A90E2" Padding="12,6" CornerRadius="6,6,0,0">
            <TextBlock Text="{Binding TileName}" 
                       FontSize="16" 
                       Foreground="White" 
                       FontFamily="Microsoft YaHei"
                       FontWeight="Medium"/>
        </Border>

        <!-- 中间表格 + 移动按钮区域 -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：您拥有的资源 ListBox 列表 -->
            <Border Grid.Column="0" Background="White" CornerRadius="6,0,0,6" BorderBrush="#E0E6ED" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F8F9FA" BorderThickness="0,0,0,1" BorderBrush="#E0E6ED">
                        <TextBlock Text="您拥有的资源" FontSize="14" Foreground="#2D3748" Margin="10,0" HorizontalAlignment="Left" VerticalAlignment="Center" FontWeight="Medium"/>
                    </Border>
                    <!--<ListBox Grid.Row="1" x:Name="LeftList" Margin="4" Background="Transparent" BorderThickness="0" ItemsSource="{Binding LeftResources}"  SelectionMode="Extended"/> -->
                    <ListBox 
                            Grid.Row="1" 
                            x:Name="LeftList" 
                            Margin="4" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            ItemsSource="{Binding LeftResources}"  
                            SelectionMode="Extended">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Id}" Foreground="#4A90E2" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" Foreground="#2D3748" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding OnDutyStatusName}" Foreground="OrangeRed" FontSize="14"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>


                </Grid>
            </Border>

            <!-- 中间：箭头移动按钮区域 -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0" HorizontalAlignment="Center">
                <Button Click="MoveRight_Click" Style="{StaticResource ArrowButtonStyle}" Content=">"/>
                <Button Click="MoveAllRight_Click" Style="{StaticResource ArrowButtonStyle}" Content=">>>"/>
                <Separator Height="30" Visibility="Hidden"/>
                <Button Click="MoveLeft_Click" Style="{StaticResource ArrowButtonStyle}" Content="&lt;"/>
                <Button Click="MoveAllLeft_Click" Style="{StaticResource ArrowButtonStyle}" Content="&lt;&lt;&lt;"/>
            </StackPanel>

            <!-- 右侧：已中的资源 ListBox 列表 -->
            <Border Grid.Column="2" Background="White" CornerRadius="0,6,6,0" BorderBrush="#E0E6ED" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F8F9FA" BorderThickness="0,0,0,1" BorderBrush="#E0E6ED">
                        <TextBlock Text="已选择的资源" FontSize="14" Foreground="#2D3748" Margin="10,0" HorizontalAlignment="Left" VerticalAlignment="Center" FontWeight="Medium"/>
                    </Border>
                    <!--<ListBox Grid.Row="1" x:Name="RightList" Margin="4" Background="Transparent" BorderThickness="0" ItemsSource="{Binding RightResources}"  SelectionMode="Extended"/> -->
                    <ListBox 
                            Grid.Row="1" 
                            x:Name="RightList" 
                            Margin="4" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            ItemsSource="{Binding RightResources}"  
                            SelectionMode="Extended">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Id}" Foreground="#4A90E2" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" Foreground="#2D3748" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding OnDutyStatusName}" Foreground="OrangeRed" FontSize="14"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- 底部按钮区域 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Button Click="Confirm_Click" Style="{StaticResource ConfirmBtnStyle}" Content="{Binding DutyStypeName}" Margin="0 0 20 0"/>
            <Button Click="Cancel_Click" Style="{StaticResource CancelBtnStyle}" Content="取消"/>
        </StackPanel>
    </Grid>
</UserControl>