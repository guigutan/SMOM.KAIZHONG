<UserControl
    x:Class="SIE.Wpf.MES.Controls.KZWorkCellSelectorControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
    xmlns:dxdove="http://schemas.devexpress.com/winfx/2008/xaml/docking/visualelements"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="CustomPanelStyle" TargetType="{x:Type dxdo:LayoutPanel}">
            <Setter Property="AllowFloat" Value="False" />
            <Setter Property="AllowDock" Value="False" />
            <Setter Property="AllowHide" Value="False" />
            <Setter Property="AllowClose" Value="False" />
            <Setter Property="AllowDockToDocumentGroup" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type dxdo:LayoutPanel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Border
                                x:Name="CaptionBorder"
                                Margin="1,1,1,0"
                                dxdove:DockPane.HitTestType="Header"
                                CornerRadius="3,3,0,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStop Offset="0" Color="#FF878787" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock
                                    x:Name="Caption"
                                    Margin="8,5"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="White"
                                    Text="{TemplateBinding ActualCaption}"
                                    TextWrapping="NoWrap" />
                            </Border>
                            <Border
                                x:Name="ContentBorder"
                                Grid.Row="1"
                                Margin="1,0,1,1"
                                Padding="1,0,1,1"
                                dxdove:DockPane.HitTestType="Content"
                                Background="#FFA0A0A0"
                                CornerRadius="0,0,2,2">
                                <Border
                                    x:Name="ContentBorder2"
                                    Padding="2,0,2,2"
                                    dxdove:DockPane.HitTestType="Content"
                                    Background="#FFE5E5E5"
                                    CornerRadius="0,0,1,1">
                                    <Border
                                        x:Name="ContentBorder3"
                                        Padding="1,0,1,1"
                                        dxdove:DockPane.HitTestType="Content"
                                        Background="#FFB0B0B0">
                                        <ContentPresenter Content="{TemplateBinding Control}" />
                                    </Border>
                                </Border>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <dxdo:DockLayoutManager x:Name="dockManager">
            <dxdo:LayoutGroup ItemHeight="*" Orientation="Horizontal">
                <dxdo:LayoutGroup Orientation="Vertical">
                    <dxdo:LayoutPanel Caption="搜索资源" ItemHeight="0.34*" Style="{StaticResource CustomPanelStyle}" >
                        <TextBox TextWrapping="Wrap" Name="txtBarcode" Text="" KeyUp="txtBarcode_KeyUp"/>

                    </dxdo:LayoutPanel>
                    <dxdo:LayoutPanel Caption="{Binding [资源], Source={uic:L10N}}" Style="{StaticResource CustomPanelStyle}" ItemHeight="1.66*">
                        <dx:BackgroundPanel>
                            <dxe:ListBoxEdit
                                x:Name="wipresourceListCtrl"
                                Margin="0,5,0,0"
                                HorizontalContentAlignment="Stretch"
                                AllowItemHighlighting="True"
                                Background="Gainsboro"
                                ItemsSource="{Binding WipResourceList}"
                                SelectedItem="{Binding SelectedWipResource}">
                                <dxe:ListBoxEdit.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="Gray" BorderThickness="0,0,0,1">
                                            <dxlc:LayoutControl>
                                                <dxlc:LayoutGroup Orientation="Horizontal">
                                                    <dxlc:LayoutItem>
                                                        <TextBlock Height="20" Text="{Binding Name}" />
                                                    </dxlc:LayoutItem>
                                                </dxlc:LayoutGroup>
                                            </dxlc:LayoutControl>
                                        </Border>
                                    </DataTemplate>
                                </dxe:ListBoxEdit.ItemTemplate>
                            </dxe:ListBoxEdit>
                        </dx:BackgroundPanel>
                    </dxdo:LayoutPanel>
                </dxdo:LayoutGroup>
                <!--<dxdo:LayoutPanel Caption="{Binding [工序], Source={uic:L10N}}" Style="{StaticResource CustomPanelStyle}" Visibility="Hidden">
                    <dx:BackgroundPanel>
                        <dxe:ListBoxEdit
                            x:Name="processListCtrl"
                            Margin="0,5,0,0"
                            HorizontalContentAlignment="Stretch"
                            AllowItemHighlighting="True"
                            Background="Gainsboro"
                            ItemsSource="{Binding ProcessList}"
                            SelectedItem="{Binding SelectedProcess}">
                            <dxe:ListBoxEdit.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="Gray" BorderThickness="0,0,0,1">
                                        <dxlc:LayoutControl>
                                            <dxlc:LayoutGroup Orientation="Horizontal">
                                                <dxlc:LayoutItem>
                                                    <TextBlock Height="20" Text="{Binding Name}" />
                                                </dxlc:LayoutItem>
                                            </dxlc:LayoutGroup>
                                        </dxlc:LayoutControl>
                                    </Border>
                                </DataTemplate>
                            </dxe:ListBoxEdit.ItemTemplate>
                        </dxe:ListBoxEdit>
                    </dx:BackgroundPanel>
                </dxdo:LayoutPanel>
                <dxdo:LayoutPanel Caption="{Binding [工位], Source={uic:L10N}}" Style="{StaticResource CustomPanelStyle}" Visibility="Hidden">
                    <dx:BackgroundPanel>
                        <dxe:ListBoxEdit
                            x:Name="stationListCtrl"
                            Margin="0,5,0,0"
                            HorizontalContentAlignment="Stretch"
                            AllowItemHighlighting="True"
                            Background="Gainsboro"
                            ItemsSource="{Binding StationList}"
                            SelectedItem="{Binding SelectedStation}">
                            <dxe:ListBoxEdit.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="Gray" BorderThickness="0,0,0,1">
                                        <dxlc:LayoutControl>
                                            <dxlc:LayoutGroup Orientation="Horizontal">
                                                <dxlc:LayoutItem>
                                                    <TextBlock Height="20" Text="{Binding Name}" />
                                                </dxlc:LayoutItem>
                                            </dxlc:LayoutGroup>
                                        </dxlc:LayoutControl>
                                    </Border>
                                </DataTemplate>
                            </dxe:ListBoxEdit.ItemTemplate>
                        </dxe:ListBoxEdit>
                    </dx:BackgroundPanel>
                </dxdo:LayoutPanel>-->
            </dxdo:LayoutGroup>
        </dxdo:DockLayoutManager>
        <StackPanel
            Grid.Row="1"
            Margin="0,5,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <dx:SimpleButton
                x:Name="btnOk"
                Width="120"
                Height="40"
                Click="btnOk_Click"
                Content="{Binding [确定], Source={uic:L10N}}" />
            <dx:SimpleButton
                x:Name="btnCancel"
                Width="120"
                Height="40"
                Margin="20,0,0,0"
                Click="btnCancel_Click"
                Content="{Binding [取消], Source={uic:L10N}}" />
        </StackPanel>
    </Grid>

</UserControl>
