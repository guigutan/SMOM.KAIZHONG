<UserControl
    x:Class="SIE.Wpf.MES.Controls.MeasureControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <Grid>
        <dxdo:LayoutGroup
            MaxWidth="280"
            Margin="5,5,0,5"
            AllowExpand="False"
            Caption="{Binding [维修措施], Source={uic:L10N}}"
            DockPanel.Dock="Left"
            GroupBorderStyle="GroupBox"
            ItemHeight="auto"
            ItemWidth="280"
            Orientation="Vertical"
            ShowCaption="True">
            <dxdo:LayoutControlItem ShowCaption="False">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <ItemsControl Name="ctlMeasure">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ToggleButton
                                    x:Name="btnMeasure"
                                    Width="100"
                                    Height="40"
                                    Margin="5"
                                    Click="BtnMeasure_Click"
                                    Content="{Binding Measure.Name}"
                                    IsChecked="{Binding IsChecked}"
                                    ToolTip="{Binding Measure.Name}"
                                    Tag="{Binding Measure}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel IsItemsHost="True" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>
            </dxdo:LayoutControlItem>
        </dxdo:LayoutGroup>
    </Grid>
</UserControl>
