<UserControl x:Class="SIE.Wpf.MES.Wip.Controls.DefectLookUpEditor"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid" 
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ui="http://schemas.siestudio.com/winfx/xaml/controls"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.Wip.Controls"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ControlTemplate x:Key="groupContentTemplate">
                <dxg:GridControl x:Name="PART_GridControl" AutoExpandAllGroups="True">
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn FieldName="Code" Header="{Binding [编码], Source={uic:L10N}}" HeaderToolTip="{Binding [编码], Source={uic:L10N}}"/>
                        <dxg:GridColumn FieldName="Description" Header="{Binding [描述], Source={uic:L10N}}" HeaderToolTip="{Binding [描述], Source={uic:L10N}}"/>
                    </dxg:GridControl.Columns>
                    <dxg:GridControl.View>
                        <dxg:TableView
                        Name="View"
                        ShowGroupedColumns="True"
                        AutoWidth="True"
                        AllowPerPixelScrolling="True"
                        ScrollAnimationDuration="0"
                        ShowAutoFilterRow="True"
                        ShowTotalSummary="True"
                        IsSynchronizedWithCurrentItem="False">
                        </dxg:TableView>
                    </dxg:GridControl.View>
                </dxg:GridControl>
            </ControlTemplate>
        </ResourceDictionary>
    </UserControl.Resources>
    <dxg:LookUpEdit Name="defectEditor" AllowNullInput="True" PopupWidth="400" PopupMaxWidth="500" DisplayMember="Code" ValueMember="Id" AutoPopulateColumns="False" PopupContentTemplate="{StaticResource groupContentTemplate}" EditValue="{Binding Path=.}">
    </dxg:LookUpEdit>
</UserControl>
