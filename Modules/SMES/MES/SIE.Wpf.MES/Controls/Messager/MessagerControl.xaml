<UserControl
    x:Class="SIE.Wpf.MES.Controls.Messager.MessagerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:SIE.Wpf.MES.Controls.Messager"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
    d:DesignHeight="600"
    d:DesignWidth="190"
    mc:Ignorable="d">
    <UserControl.Resources>
        <c:MessageTypeToColorConverter x:Key="MessageTypeToColorConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <WrapPanel Orientation="Horizontal">
            <dx:SimpleButton
                x:Name="btnClear"
                Width="100"
                Height="30"
                Margin="5,5,0,0"
                Click="btnClear_Click"
                Content="{Binding [清空], Source={uic:L10N}}" />
            <dx:SimpleButton
                x:Name="btnCopy"
                Width="100"
                Height="30"
                Margin="5,5,0,0"
                Click="btnCopy_Click"
                Content="{Binding [复制], Source={uic:L10N}}" />
        </WrapPanel>
        <ListBox
            Grid.Row="1"
            ItemsSource="{Binding ErrorMessageList}"
            ScrollViewer.CanContentScroll="True"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Width="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=ActualWidth}"
                            Padding="1,3,24,0"
                            FontSize="16"
                            Foreground="{Binding Type, Converter={StaticResource MessageTypeToColorConverter}}"
                            Text="{Binding Body}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
