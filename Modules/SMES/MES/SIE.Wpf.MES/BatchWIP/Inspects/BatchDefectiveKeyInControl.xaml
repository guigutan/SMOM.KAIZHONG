<UserControl x:Class="SIE.Wpf.MES.BatchWIP.Inspects.BatchDefectiveKeyInControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
             xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:local="clr-namespace:SIE.Wpf.MES.BatchWIP.Inspects"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="600">
    <Grid HorizontalAlignment="Left" Background="{DynamicResource {uit:BrushesThemeKey ResourceKey=Background}}" Margin="-5,-5,0,0"  Name="gdBatchDefectSet" Height="400" VerticalAlignment="Top">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid Width="800" Grid.Row="0" Margin="10,10,10,10" Background="Transparent" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"></ColumnDefinition>
                <ColumnDefinition Width="1.5*"></ColumnDefinition>
                <ColumnDefinition Width="1*"></ColumnDefinition>
                <ColumnDefinition Width="1.5*"></ColumnDefinition>
                <ColumnDefinition Width="1*"></ColumnDefinition>
                <ColumnDefinition Width="1*"></ColumnDefinition>
                <ColumnDefinition Width="1*"></ColumnDefinition>
                <ColumnDefinition Width="1*"></ColumnDefinition>
                <ColumnDefinition Width="1*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <Label Grid.Column="0" Content="{Binding [生产批次],Source={uic:L10N}}" HorizontalAlignment="Left" Margin="0,0,0,0"></Label>
            <dxe:TextEdit Grid.Column="1" Text="{Binding Barcode}" HorizontalAlignment="Left" Width="120" Margin="-30,0,0,0" IsReadOnly="True"></dxe:TextEdit>
            <!--<Label Grid.Column="2" Content="{Binding [子批次],Source={uic:L10N}}" HorizontalAlignment="Left" Margin="10,0,0,0"></Label>
            <dxe:TextEdit Grid.Column="3" Text="{Binding ChildBarcode}" HorizontalAlignment="Left" Width="120" Margin="-30,0,0,0" IsReadOnly="True"></dxe:TextEdit>-->
            <Label Grid.Column="3" Content="{Binding [剩余数量], Source={uic:L10N}}" HorizontalAlignment="Left" Margin="10,0,0,0"></Label>
            <dxe:TextEdit Grid.Column="4" Text="{Binding RemainQty}" HorizontalAlignment="Left" Width="80" Margin="-20,0,0,0" IsReadOnly="True" ></dxe:TextEdit>
            <Label Grid.Column="5" Content="{Binding [不良数量], Source={uic:L10N}}" HorizontalAlignment="Left" Margin="-10,0,0,0"></Label>
            <!--<dxe:TextEdit Grid.Column="5" Text="{Binding NgQty}" HorizontalAlignment="Left" Width="80" Margin="-70,0,0,0"></dxe:TextEdit>-->
            <!--<dxe:SpinEdit Grid.Column="5" Text="{Binding NgQty}" HorizontalAlignment="Left" Width="80" Margin="-70,0,0,0" MinValue="1" ></dxe:SpinEdit>-->
            <dxe:PopupCalcEdit Grid.Column="6" Text="{Binding NgQty}" HorizontalAlignment="Left" Width="80" Margin="-30,0,0,0" Mask=""></dxe:PopupCalcEdit>
            <dx:SimpleButton Grid.Column="8" Margin="-20,0,0,0" Width="80" Name="Submit" Click="Submit_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding [提交],Source={uic:L10N}}" VerticalAlignment="Center"/>
                </StackPanel>
            </dx:SimpleButton>
        </Grid>
        <ContentControl Width="800" Grid.Row="1" Name="DefectContent" Margin="10,10,0,10" HorizontalAlignment="Left"></ContentControl>
        <!--<ContentControl Width="800" Grid.Row="2" Name="DefectInfos" Margin="10,10,0,10" HorizontalAlignment="Left" ></ContentControl>-->
        <!--<Grid Width="800" Grid.Row="3" Margin="10,0,0,10" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="251*"></ColumnDefinition>
                <ColumnDefinition Width="434*"/>
                <ColumnDefinition Width="114*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"></RowDefinition>
                <RowDefinition Height="1*"></RowDefinition>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Grid.Column="0" Content="{Binding [请扫描转出载具条码], Source={uic:L10N}}" Foreground="Green" FontSize="20" FontWeight="Bold" Grid.ColumnSpan="3" Margin="0,0,114,0"></Label>
            <dxe:TextEdit Grid.Column="0" Name="txtOutVehicle" Text="{Binding OutPutContainerNo}" Background="{Binding BarcodeType, Converter={local:BatchContainerBackgroundConverters}, ConverterParameter='ContainerCtl', Mode=OneWay}" Height="40"  KeyDown="TxtOutVehicle_KeyDown" IsEnabled="{Binding BarcodeType, Converter={local:BatchContainerEnableConverters}, Mode=OneWay, ConverterParameter='ContainerCtl' }" Grid.ColumnSpan="3" Margin="0,35,114,0" Grid.RowSpan="2"/>
            <dx:SimpleButton Grid.Row="0" Grid.Column="2" Grid.RowSpan="2" HorizontalAlignment="Center"  Margin="0,10,0,0" Name="GenerateNgBatch"  Click="GenerateNgBatch_Click" IsEnabled="{Binding BarcodeType, Converter={local:BatchContainerEnableConverters}, Mode=OneWay, ConverterParameter='BatchCtl' }">
                <TextBlock Text="{Binding [生成不良批次],Source={uic:L10N}}" VerticalAlignment="Center"/>
            </dx:SimpleButton>
        </Grid>-->
    </Grid>
</UserControl>
