<UserControl x:Class="SIE.Wpf.MES.BatchWIP.Packings.Layouts.BatchAndPackingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.BatchWIP.Packings.Layouts"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <!--<dxlc:LayoutControl x:Name="mainLayout" AllowItemSizing="True" Padding="0" Orientation="Horizontal" >
        --><!--<dxlc:LayoutGroup dxlc:LayoutControl.AllowHorizontalSizing="True" Margin="0,0,2,0" Header="{Binding [工位批次列表], Source={uic:L10N}}">--><!--
        <ContentControl x:Name="batchPanel" dxlc:LayoutControl.AllowHorizontalSizing="True" Margin="0"></ContentControl>
        --><!--</dxlc:LayoutGroup>-->
        <!--<dxlc:LayoutGroup dxlc:LayoutControl.AllowHorizontalSizing="True" Margin="2,0,0,0" Header="{Binding [批次包装清单], Source={uic:L10N}}">--><!--
        <ContentControl x:Name="packingPanel" dxlc:LayoutControl.AllowHorizontalSizing="True" Margin="0" Padding="0"></ContentControl>
        --><!--</dxlc:LayoutGroup>--><!--
    </dxlc:LayoutControl>-->

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="3"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <dxlc:GroupBox x:Name="batchPanel" Grid.Column="0" Header="{Binding [工位批次列表], Source={uic:L10N}}" Margin="0" Padding="0" BorderThickness="0"/>
        <GridSplitter Grid.Column="1" Foreground="{x:Null}" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        <dxlc:GroupBox x:Name="packingPanel" Grid.Column="2" Header="{Binding [批次包装清单], Source={uic:L10N}}" Margin="0" Padding="0" BorderThickness="0"/>

    </Grid>
</UserControl>
