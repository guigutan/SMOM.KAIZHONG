<UserControl x:Class="SIE.Wpf.MES.BatchWIP.Packings.Layouts.BatchPackingLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.MES.BatchWIP.Packings.Layouts"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <DockPanel>
        <ContentControl Name="toolBar" DockPanel.Dock="Top"></ContentControl>
        <dxdo:DockLayoutManager BorderThickness="0" x:Name="dockLayoutManager">
            <dxdo:LayoutGroup Orientation="Horizontal" ItemHeight="*" AllowSplitters="True">
                <dxdo:LayoutPanel AllowDock="True" AllowClose="False" AllowFloat="False" AllowHide="False">
                    <DockPanel>
                        <ContentControl Name="workStation" DockPanel.Dock="Bottom"></ContentControl>
                        <ContentControl Name="mainView" DockPanel.Dock="Top"></ContentControl>
                        <dxe:DXTabControl Name="childrenView" Margin="3">
                            <dxe:DXTabControl.Items>
                                <dxe:DXTabItem Header="{Binding [批次包装], Source={uic:L10N}}">
                                    <local:BatchAndPackingPanel x:Name="batchAndPacking" Margin="-11"></local:BatchAndPackingPanel>
                                </dxe:DXTabItem>
                            </dxe:DXTabControl.Items>
                        </dxe:DXTabControl>
                    </DockPanel>
                </dxdo:LayoutPanel>
            </dxdo:LayoutGroup>
        </dxdo:DockLayoutManager>
    </DockPanel>
</UserControl>
