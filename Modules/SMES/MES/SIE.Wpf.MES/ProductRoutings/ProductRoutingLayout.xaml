<UserControl
    x:Class="SIE.Wpf.MES.ProductRoutings.ProductRoutingLayout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SIE.Wpf.MES.ProductRoutings"
    mc:Ignorable="d" 
    xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
    d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="6*"/>
            <RowDefinition Height="3"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="3"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid Name="productGrid" Grid.RowSpan="3" Margin="0,0,-5,0"/>
        <GridSplitter Grid.Column="2" Grid.Row="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Background="{DynamicResource {uit:BrushesThemeKey ResourceKey=Background}}"/>
        <local:ProductRoutingDesign x:Name="design" Grid.Column="2"/>
        <GridSplitter Grid.Column="1" Grid.Row="0" Grid.RowSpan="3" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Background="{DynamicResource {uit:BrushesThemeKey ResourceKey=Background}}"/>
        <TabControl Name="tabControl" Grid.Row="2" Grid.Column="2" Margin="5,0,5,5"/>
    </Grid>
</UserControl>
