<UserControl x:Class="SIE.Wpf.MES.BatchProductRoutings.RoutingLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:SIE.Wpf.MES.BatchProductRoutings"
             xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="6*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid Name="productGrid" Grid.RowSpan="3"/>
        <GridSplitter Grid.Column="2" Grid.Row="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Foreground="{x:Null}" Background="{DynamicResource {uit:BrushesThemeKey ResourceKey=BorderBrush}}"/>
        <local:BatchRoutingDesign x:Name="design" Grid.Column="2"/>
        <GridSplitter Grid.Column="1" Grid.Row="0" Grid.RowSpan="3" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Foreground="{x:Null}" Background="{DynamicResource {uit:BrushesThemeKey ResourceKey=BorderBrush}}"/>
        <TabControl Name="tabControl" Grid.Row="2" Grid.Column="2"/>
    </Grid>
</UserControl>
