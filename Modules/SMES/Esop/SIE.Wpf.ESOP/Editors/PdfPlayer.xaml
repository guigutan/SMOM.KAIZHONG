<UserControl x:Class="SIE.Wpf.ESop.Editors.PdfPlayer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.ESop.Editors"
             xmlns:dxpdf="http://schemas.devexpress.com/winfx/2008/xaml/pdf"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <dxpdf:PdfViewerControl  Name="pdfViewerControl"
                                 Grid.Row="0">
        </dxpdf:PdfViewerControl>
        <StackPanel  Grid.Row="1" Orientation="Horizontal" MaxHeight="40" Background="Transparent">
            <Button Name="btnSelect" Content="普通" Height="40" Width="80" Click="BtnSelect_Click"></Button>
            <Button Name="btnHand" Content="拖动" Height="40" Width="80" Click="BtnHand_Click"></Button>
            <Button Name="btnZoomIn" Content="放大" Height="40" Width="80" Click="BtnZoomIn_Click"></Button>
            <Button Name="btnZoomOut" Content="缩小" Height="40" Width="80" Click="BtnZoomOut_Click"></Button>
            <Button Name="btnClockwiseRotate" Content="旋转" Height="40" Width="80" Click="BtnClockwiseRotate_Click"></Button>
        </StackPanel>
    </Grid>

</UserControl>
