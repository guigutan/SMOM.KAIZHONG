<UserControl x:Class="SIE.Wpf.Packages.Packings.Layouts.PackingLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.Packages.Packings.Layouts"
             xmlns:dxdo ="http://schemas.devexpress.com/winfx/2008/xaml/docking"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
             mc:Ignorable="d">
    <DockPanel>
        <ContentControl Name="toolBar" DockPanel.Dock="Top"></ContentControl>
        <dxdo:DockLayoutManager BorderThickness="0" x:Name="dockLayoutManager">
            <dxdo:LayoutGroup Orientation="Horizontal" ItemHeight="*" AllowSplitters="True">
                <dxdo:LayoutPanel Caption="{Binding [包装清单],Source={uic:L10N}}" AllowDock="True" AllowClose="False" ItemWidth="500" MaxWidth="550">
                    <ContentControl Name="packingRelation"></ContentControl>
                </dxdo:LayoutPanel>
                <dxdo:LayoutPanel AllowDock="True" AllowClose="False" AllowFloat="False" AllowHide="False">
                    <DockPanel>
                        <ContentControl Name="workStation" DockPanel.Dock="Bottom"></ContentControl>
                        <ContentControl Name="mainView" DockPanel.Dock="Top"></ContentControl>
                        <ContentControl Name="childrenView"></ContentControl>
                    </DockPanel>
                </dxdo:LayoutPanel>
            </dxdo:LayoutGroup>
        </dxdo:DockLayoutManager>
    </DockPanel>
</UserControl>
