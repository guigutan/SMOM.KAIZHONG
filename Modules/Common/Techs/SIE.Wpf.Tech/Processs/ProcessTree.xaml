<UserControl xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"  
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"  
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"  
    x:Class="SIE.Wpf.Tech.Processs.ProcessTree"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"  
    xmlns:local="clr-namespace:SIE.Wpf.Tech.Processs"
    xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
    xmlns:ui="http://schemas.siestudio.com/winfx/xaml/controls"
    xmlns:selector="clr-namespace:SIE.Wpf.Tech.Routings"
    xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
    mc:Ignorable="d" 
    d:DesignHeight="300" d:DesignWidth="300"> 
    <DockPanel>
        <DockPanel.CommandBindings>
            <CommandBinding Command="{x:Static local:ProcessTree.Refresh}" Executed="Refresh_Executed"/>
            <CommandBinding Command="{x:Static local:ProcessTree.Add}" CanExecute="Add_CanExecute" Executed="Add_Executed"/>
            <CommandBinding Command="{x:Static local:ProcessTree.Edit}" CanExecute="Edit_CanExecute" Executed="Edit_Executed"/>
            <CommandBinding Command="{x:Static local:ProcessTree.Delete}" CanExecute="Delete_CanExecute" Executed="Delete_Executed"/>
        </DockPanel.CommandBindings>
        <ItemsControl DockPanel.Dock="Top">
            <StackPanel Orientation="Horizontal">
                <dx:SimpleButton Name="btnRefresh" Command="{x:Static local:ProcessTree.Refresh}" Margin="3,5,5,0" Width="42" ToolTip="{Binding [刷新工序],Source={uic:L10N}}">
                    <Grid>
                        <ui:PackIcon Kind="Refresh" Height="15" Width="15" Foreground="{DynamicResource {uit:ColorBrushesKey ResourceKey=IconBrush}}"></ui:PackIcon>
                    </Grid>
                </dx:SimpleButton>
                <dx:SimpleButton Name="btnAdd" Command="{x:Static local:ProcessTree.Add}" Margin="0,5,5,0" Width="42" ToolTip="{Binding [添加工序],Source={uic:L10N}}">
                    <Grid>
                        <ui:PackIcon Kind="AddEntity" Height="15" Width="15" Foreground="{DynamicResource {uit:ColorBrushesKey ResourceKey=GreenBrush}}"></ui:PackIcon>
                    </Grid> 
                </dx:SimpleButton>
                <dx:SimpleButton Name="btnEdit" Command="{x:Static local:ProcessTree.Edit}" Margin="0,5,5,0" Width="42" ToolTip="{Binding [修改工序],Source={uic:L10N}}">
                    <Grid>
                        <ui:PackIcon Kind="EditEntity" Height="15" Width="15" Foreground="{DynamicResource {uit:ColorBrushesKey ResourceKey=IconBrush}}"></ui:PackIcon>
                    </Grid>
                </dx:SimpleButton>
                <dx:SimpleButton Name="btnDelete" Command="{x:Static local:ProcessTree.Delete}" Margin="0,5,5,0" Width="42" ToolTip="{Binding [删除工序],Source={uic:L10N}}">
                    <Grid>
                        <ui:PackIcon Kind="DeleteEntity" Height="15" Width="15" Foreground="{DynamicResource {uit:ColorBrushesKey ResourceKey=RedBrush}}"></ui:PackIcon>
                    </Grid> 
                </dx:SimpleButton>
            </StackPanel> 
        </ItemsControl>
        <DockPanel DockPanel.Dock="Top">
            <dxe:ButtonEdit Name="searchEdit" IsTextEditable="True" AllowDefaultButton="False" NullText="{Binding [查找],Source={uic:L10N}}" Margin="3" KeyDown="SearchEdit_KeyDown">
                <dxe:ButtonInfo Name="btnSearch" GlyphKind="Search" ToolTip="{Binding [查找],Source={uic:L10N}}" Click="BtnSearch_Click"></dxe:ButtonInfo>
            </dxe:ButtonEdit>
        </DockPanel>
        <dxg:GridControl Name="processControl" SelectionMode="Cell"> 
            <dxg:GridControl.Columns>
                <dxg:GridColumn Header=" " FieldName="DisplayName" ReadOnly="True" Width="*"></dxg:GridColumn>
            </dxg:GridControl.Columns>
            <dxg:GridControl.View>
                <dxg:TreeListView ParentFieldName="Pid" KeyFieldName="Id" ShowNodeImages="True">
                    <dxg:TreeListView.NodeImageSelector>  
                        <selector:TreeInfoImageSelector/>
                    </dxg:TreeListView.NodeImageSelector>
                </dxg:TreeListView>
            </dxg:GridControl.View>
        </dxg:GridControl>
    </DockPanel>
</UserControl>

