<UserControl xmlns:dxprg="http://schemas.devexpress.com/winfx/2008/xaml/propertygrid"
    x:Class="SIE.Wpf.Tech.Routings.DesignPropertys.ContainerProperty"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:SIE.Wpf.Tech.Routings.DesignPropertys" 
    xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"         
    mc:Ignorable="d"
    d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <dxprg:PropertyGridControl Name="propertyGrid" ShowCategories="true" ShowDescriptionIn="Panel" ExpandCategoriesWhenSelectedObjectChanged="True" ShowProperties="WithPropertyDefinitions" SelectedObject="{Binding}">
            <dxprg:CategoryDefinition Header="{Binding [通用],Source={uic:L10N}}">
                <dxprg:PropertyDefinition Path="ShowGridLine" Header="{Binding [显示网格],Source={uic:L10N}}"/>
                <dxprg:PropertyDefinition Path="Width" IsReadOnly="True" Header="{Binding [宽],Source={uic:L10N}}"/>
                <dxprg:PropertyDefinition Path="Height" Header="{Binding [高],Source={uic:L10N}}"/>
            </dxprg:CategoryDefinition>
        </dxprg:PropertyGridControl>
    </Grid>
</UserControl>
