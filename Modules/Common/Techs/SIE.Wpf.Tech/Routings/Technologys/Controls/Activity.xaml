<UserControl 
    x:Class="SIE.Wpf.Tech.Routings.Technologys.Controls.Activity"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SIE.Wpf.Tech.Routings.Technologys.Controls"
    xmlns:cv="clr-namespace:SIE.Wpf.Tech.Routings.Technologys.Converters"
    MouseMove="UserControl_MouseMove"
    MouseLeftButtonUp="UserControl_MouseLeftButtonUp"
    MouseLeftButtonDown="UserControl_MouseLeftButtonDown"
    Panel.ZIndex="{Binding ZIndex}"
    Canvas.Left="{Binding Left}"
    ToolTip="{Binding ToolTip}"
    Canvas.Top="{Binding Top}">
    <Grid>
        <ItemsControl Width="{Binding Width}" HorizontalAlignment="Center" VerticalAlignment="Top" Visibility="{Binding Path=Self,Converter={cv:IActivityToVisibilityConverter}}" ItemsSource="{Binding Rules}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <!--Fill="{Binding Text,Converter={cv:EllipseStrokeConverter}}"-->
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Ellipse Margin="2,0" Canvas.ZIndex="100" x:Name="eiCenterEllipse" Fill="{Binding Color,Converter={cv:StringToColorConverter}}"  Stroke="Black"  Opacity="0.6" Width="15" Height="15"   Stretch="Fill" StrokeThickness="1" MouseLeftButtonDown="CenterEllipse_MouseLeftButtonDown" MouseLeftButtonUp="CenterEllipse_MouseLeftButtonUp" ToolTip="{Binding Text}"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="{Binding Width}" Height="{Binding ContainerHeight}">
            <Rectangle Fill="{Binding Path=Self, Converter={cv:InteractionFillConverter}}" Stroke="Green" StrokeThickness="1" RadiusX="10" RadiusY="10"  Width="{Binding Width}" Height="{Binding Height}" Visibility="{Binding Path=Type,Converter={cv:InteractionVisibilityConverter}}"/>
            <Grid Visibility="{Binding Path=Type,Converter={cv:InitialVisibilityConverter}}">
                <Ellipse Width="52" Height="52" Stroke="Black" StrokeThickness="2"/>
                <Ellipse Width="50" Height="50" Fill="{Binding Path=Self, Converter={cv:InitialFillConverter}}" Stretch="Fill" Stroke="White" StrokeThickness="2"/>
                <!--<Ellipse Width="50" Height="50" Fill="{Binding Path=IsSelected, Converter={cv:InitialFillConverter}}" Stretch="Fill" Stroke="White" StrokeThickness="2"/>-->
            </Grid>
            <Grid Visibility="{Binding Path=Type,Converter={cv:CompletionVisibilityConverter}}">
                <Ellipse Width="52" Height="52" Stroke="Black" StrokeThickness="2"/>
                <Ellipse Width="50" Height="50" Fill="{Binding Path=IsSelected, Converter={cv:CompletionFillConverter}}" Stretch="Fill" Stroke="White" StrokeThickness="2"/>
            </Grid>
            <TextBlock Foreground="Black" Text="{Binding Text}"  FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap"  MaxWidth="90"/>
        </Grid>
    </Grid>
</UserControl>
