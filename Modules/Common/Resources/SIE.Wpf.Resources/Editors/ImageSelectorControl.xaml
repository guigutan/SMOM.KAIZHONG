<UserControl x:Class="SIE.Wpf.Resources.Editors.ImageSelectorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.Resources.Editors"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <Button Background="{x:Null}" Click="BtnSelector_Click">点击选择图片</Button>
        <Image Name="img" Stretch="Uniform"/>
        <Button Content="+" Name="btnSelector" Click="BtnSelector_Click" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="20" Height="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="0"/>
    </Grid>
</UserControl>
