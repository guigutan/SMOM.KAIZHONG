<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/ExtJs/ext-theme.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/WorkBenchStyle.css" rel="stylesheet" asp-append-version="true" />
    <environment include="Development">
        <link href="~/ExtJs/packages/ux/classic/neptune/resources/ux-all.css" rel="stylesheet" />
        <link href="~/ExtJs/addons/pivot/build/classic/neptune/resources/pivot-all.css" rel="stylesheet" />
        <link href="~/ExtJs/addons/calendar/build/classic/neptune/resources/calendar-all.css" rel="stylesheet" />
        <link href="~/ExtJs/packages/charts/classic/neptune/resources/charts-all.css" rel="stylesheet" />
        <script src="~/ExtJs/ext-all-debug.js" asp-append-version="true"></script>
    </environment>
    <environment exclude="Development">
        <link href="~/ExtJs/packages/ux/classic/neptune/resources/ux-all.css" rel="stylesheet" />
        <link href="~/ExtJs/addons/calendar/build/classic/neptune/resources/calendar-all.css" rel="stylesheet" />
        <link href="~/ExtJs/packages/charts/classic/neptune/resources/charts-all.css" rel="stylesheet" />
        <link href="~/ExtJs/addons/pivot/build/classic/neptune/resources/pivot-all.css" rel="stylesheet" />
        <script src="~/ExtJs/ext-all.js" asp-append-version="true"></script>
    </environment>



</head>
<body>
    <div style="display: none;" id="infoPanel">
        <span id="identify">@SIE.Web.Security.HttpAuthenticateService.CookieKeyIdentify</span>
    </div>

    @RenderBody()
    <environment include="Development">
        <script src="~/ExtJs/packages/ux/classic/ux-debug.js"></script>
        <script src="~/ExtJs/addons/exporter/build/classic/exporter-debug.js"></script>
        <script src="~/ExtJs/addons/pivot/build/classic/pivot-debug.js"></script>
        <script src="~/ExtJs/addons/calendar/build/classic/calendar-debug.js"></script>
        <script src="~/ExtJs/packages/charts/classic/charts.js"></script>
        <script src="~/lib/signalr.min.js"></script>
        <script src="~/scripts/sie.common.bundle.js" asp-append-version="true"></script>
        <script src="~/scripts/EventBus.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/ExtJs/packages/ux/classic/ux.js"></script>
        <script src="~/ExtJs/addons/exporter/build/classic/exporter.js"></script>
        <script src="~/ExtJs/addons/pivot/build/classic/pivot.js"></script>
        <script src="~/ExtJs/addons/calendar/build/classic/calendar.js"></script>
        <script src="~/ExtJs/packages/charts/classic/charts.js"></script>
        <script src="~/lib/signalr.min.js"></script>
        <script src="~/scripts/sie.common.bundle.min.js" asp-append-version="true"></script>
        <script src="~/scripts/EventBus.js"></script>
    </environment>
    @RenderSection("headjs", false)
    <script type="text/javascript">
          Ext.onReady(function () {
            var userInfo = CurUserStateHelper.getSessionUser();
            var jsPath;
            if (userInfo.Culture) {
                SIE.App.CurCulture = userInfo.Culture;
                jsPath = '/ExtJs/locale/locale-' + userInfo.Culture + '.js';
            } else {
                jsPath = '/ExtJs/locale/locale-zh-CN.js';
            }
            SIE.Util.File.loadScripts({
                urls: [jsPath],
                onEnd: function () {  },
                onError: function () { console.warn('无法加载Ext语言包，请检查'); }
            });
        });
    </script>
</body>
</html>
