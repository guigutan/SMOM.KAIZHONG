<s:ComponentItem xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"  
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    x:Class="SIE.Wpf.WorkBenchCommon.Workbench.TaskManager"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:SIE.Wpf.WorkBenchCommon.Workbench"
    xmlns:s="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
    xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
    xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
    xmlns:ui="http://schemas.siestudio.com/winfx/xaml/controls"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    s:DiagramDesigner.ToolBarTitle="{Binding [任务闭环管理],Source={uic:L10N}}"
    s:DiagramDesigner.DefaultSize="520,402"
    mc:Ignorable="d" 
    SnapsToDevicePixels="True"
    d:DesignHeight="402" d:DesignWidth="520">
    <s:ComponentItem.ToolbarItem>
        <ui:PackIcon Kind="GlobeWire"/>
    </s:ComponentItem.ToolbarItem>
    <s:ComponentItem.Resources>
        <ResourceDictionary Source="/SIE.Wpf.Common;component/Themes/Generic.xaml" />
    </s:ComponentItem.Resources>
    <dxlc:GroupBox Padding="-2,2,-2,-2">
        <dxlc:GroupBox.Header>
            <DockPanel Height="36">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{DynamicResource HeaderButton}" Click="Refresh_Click">
                        <ui:PackIcon Kind="Refresh" Width="24" Height="24" Foreground="{DynamicResource ResourceKey={uit:ColorBrushesKey ResourceKey=GreenBrush}}"/>
                    </Button>
                </StackPanel>
                <Label FontSize="18" Content="{Binding [任务闭环管理],Source={uic:L10N}}" VerticalContentAlignment="Center"></Label>
            </DockPanel>
        </dxlc:GroupBox.Header>
        <dx:DXTabControl Name="tabControl" Padding="0" SnapsToDevicePixels="True">
            <dx:DXTabControl.Resources>
                <Style TargetType="dx:DXTabItem">
                    <Setter Property="Height" Value="30"/>
                    <Setter Property="Padding" Value="0,5,0,0"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                </Style>
            </dx:DXTabControl.Resources>
            <dx:DXTabItem Name="tbCreated" Width="{Binding ElementName=tabControl, Path=ActualWidth, Converter={local:TabItemWidthConverterMarkup}}">
                <dx:DXTabItem.Header>
                    <Grid Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=dx:DXTabItem},Path=ActualWidth}">
                        <StackPanel Margin="2" Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding [我创建],Source={uic:L10N}}" FontSize="17"></TextBlock>
                            <TextBlock Text="{Binding ElementName=tasksCreated, Path=Items.Count, StringFormat=({0})}" FontSize="17"></TextBlock>
                        </StackPanel>
                    </Grid>
                </dx:DXTabItem.Header>
                <DockPanel>
                    <StackPanel Margin="2" Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Top">
                        <StackPanel.Resources>
                            <dx:ObjectToBooleanConverter x:Key="cv"/>
                        </StackPanel.Resources>
                        <Button Style="{DynamicResource HeaderButton}" Click="Add_Click">
                            <ui:PackIcon Kind="AddEntity" Width="24" Height="24" Foreground="{DynamicResource ResourceKey={uit:ColorBrushesKey ResourceKey=GreenBrush}}"/>
                        </Button>
                        <Button Style="{DynamicResource HeaderButton}" Click="TasksCreatedEdit_Click" IsEnabled="{Binding ElementName=tasksCreated, Path=SelectedItem, Converter={StaticResource cv}}">
                            <ui:PackIcon Kind="EditEntity" Width="24" Height="24" Foreground="{DynamicResource ResourceKey={uit:ColorBrushesKey ResourceKey=BlueBrush}}"/>
                        </Button>
                        <Button Style="{DynamicResource HeaderButton}" Click="Cancel_Click" IsEnabled="{Binding ElementName=tasksCreated, Path=SelectedItem, Converter={StaticResource cv}}">
                            <ui:PackIcon Kind="DeleteEntity" Width="24" Height="24" Foreground="{DynamicResource ResourceKey={uit:ColorBrushesKey ResourceKey=RedBrush}}"/>
                        </Button>
                    </StackPanel>
                    <dx:DXListBox Name="tasksCreated" Style="{StaticResource ComponentListBoxStyle}" BorderThickness="1">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ResourceKey={uit:BrushesThemeKey ResourceKey=BorderBrush}}">
                                        <DockPanel DockPanel.Dock="Top">
                                            <ui:PackIcon Kind="{Binding TypeIcon}" Margin="5" Foreground="#128bef"></ui:PackIcon>
                                            <Label VerticalContentAlignment="Center" FontWeight="Bold" Foreground="{Binding Converter={local:TaskColorConvertMarkup}}">
                                                <TextBlock TextWrapping="Wrap" Text="{Binding Title}"/>
                                            </Label>
                                        </DockPanel>
                                    </Border>
                                    <Grid DockPanel.Dock="Bottom" Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding CreateByName}"/>
                                        <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding PlanEnd, StringFormat='yyyy-MM-dd'}"/>
                                        <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding StatusDisplay}"/>
                                    </Grid>
                                    <Label VerticalContentAlignment="Center" Margin="5">
                                        <TextBlock TextWrapping="Wrap" Text="{Binding Content}"/>
                                    </Label>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </dx:DXListBox>
                </DockPanel>
            </dx:DXTabItem>
            <dx:DXTabItem Name="tbPadding" Width="{Binding ElementName=tabControl, Path=ActualWidth, Converter={local:TabItemWidthConverterMarkup}}">
                <dx:DXTabItem.Header>
                    <Grid Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=dx:DXTabItem},Path=ActualWidth}">
                        <StackPanel Margin="2" Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding [待处理],Source={uic:L10N}}" FontSize="17"/>
                            <TextBlock Text="{Binding ElementName=tasksPadding, Path=Items.Count, StringFormat=({0})}" FontSize="17"/>
                        </StackPanel>
                    </Grid>
                </dx:DXTabItem.Header>
                <DockPanel>
                    <StackPanel Margin="2" Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Top">
                        <StackPanel.Resources>
                            <dx:ObjectToBooleanConverter x:Key="cv"/>
                        </StackPanel.Resources>
                        <Button Style="{DynamicResource HeaderButton}" Click="TasksPaddingEdit_Click" IsEnabled="{Binding ElementName=tasksPadding, Path=SelectedItem, Converter={StaticResource cv}}">
                            <ui:PackIcon Kind="EditEntity" Width="24" Height="24" Foreground="{DynamicResource ResourceKey={uit:ColorBrushesKey ResourceKey=BlueBrush}}"/>
                        </Button>
                    </StackPanel>
                    <dx:DXListBox Name="tasksPadding" Style="{StaticResource ComponentListBoxStyle}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ResourceKey={uit:BrushesThemeKey ResourceKey=BorderBrush}}">
                                        <DockPanel DockPanel.Dock="Top">
                                            <ui:PackIcon Kind="{Binding TypeIcon}" Margin="5" Foreground="#128bef"></ui:PackIcon>
                                            <Label VerticalContentAlignment="Center" FontWeight="Bold" Foreground="{Binding Converter={local:TaskColorConvertMarkup}}">
                                                <TextBlock TextWrapping="Wrap" Text="{Binding Title}"/>
                                            </Label>
                                        </DockPanel>
                                    </Border>
                                    <Grid DockPanel.Dock="Bottom" Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding CreateByName}"/>
                                        <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding PlanEnd, StringFormat='yyyy-MM-dd'}"/>
                                        <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding StatusDisplay}"/>
                                    </Grid>
                                    <Label VerticalContentAlignment="Center" Margin="5">
                                        <TextBlock TextWrapping="Wrap" Text="{Binding Content}"/>
                                    </Label>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </dx:DXListBox>
                </DockPanel>
            </dx:DXTabItem>
            <dx:DXTabItem Name="tbDelay" Width="{Binding ElementName=tabControl, Path=ActualWidth, Converter={local:TabItemWidthConverterMarkup}}">
                <dx:DXTabItem.Header>
                    <Grid Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=dx:DXTabItem},Path=ActualWidth}">
                        <StackPanel Margin="2" Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding [已延期],Source={uic:L10N}}" FontSize="17"/>
                            <TextBlock Text="{Binding ElementName=tasksDelay, Path=Items.Count, StringFormat=({0})}" FontSize="17"/>
                        </StackPanel>
                    </Grid>
                </dx:DXTabItem.Header>
                <DockPanel>
                    <StackPanel Margin="2" Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Top">
                        <StackPanel.Resources>
                            <dx:ObjectToBooleanConverter x:Key="cv"/>
                        </StackPanel.Resources>
                        <Button Style="{DynamicResource HeaderButton}" Click="TasksDelayEdit_Click" IsEnabled="{Binding ElementName=tasksDelay, Path=SelectedItem, Converter={StaticResource cv}}">
                            <ui:PackIcon Kind="EditEntity" Width="24" Height="24" Foreground="{DynamicResource ResourceKey={uit:ColorBrushesKey ResourceKey=BlueBrush}}"/>
                        </Button>
                    </StackPanel>
                    <dx:DXListBox Name="tasksDelay" Style="{StaticResource ComponentListBoxStyle}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ResourceKey={uit:BrushesThemeKey ResourceKey=BorderBrush}}">
                                        <DockPanel DockPanel.Dock="Top">
                                            <ui:PackIcon Kind="{Binding TypeIcon}" Margin="5" Foreground="#128bef"></ui:PackIcon>
                                            <Label VerticalContentAlignment="Center" FontWeight="Bold" Foreground="{Binding Converter={local:TaskColorConvertMarkup}}">
                                                <TextBlock TextWrapping="Wrap" Text="{Binding Title}"/>
                                            </Label>
                                        </DockPanel>
                                    </Border>
                                    <Grid DockPanel.Dock="Bottom" Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding CreateByName}"/>
                                        <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding PlanEnd, StringFormat='yyyy-MM-dd'}"/>
                                        <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding StatusDisplay}"/>
                                    </Grid>
                                    <Label VerticalContentAlignment="Center" Margin="5">
                                        <TextBlock TextWrapping="Wrap" Text="{Binding Content}"/>
                                    </Label>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </dx:DXListBox>
                </DockPanel>
            </dx:DXTabItem>
            <dx:DXTabItem Name="tbClosed" Width="{Binding ElementName=tabControl, Path=ActualWidth, Converter={local:TabItemWidthConverterMarkup}}">
                <dx:DXTabItem.Header>
                    <Grid Background="Transparent" Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=dx:DXTabItem},Path=ActualWidth}">
                        <TextBlock Margin="2" Text="{Binding [任务关闭率],Source={uic:L10N}}" HorizontalAlignment="Center" FontSize="17"/>
                    </Grid>
                </dx:DXTabItem.Header>
                <DockPanel Name="taskStatisticsPanel">
                    <Grid DockPanel.Dock="Top" Margin="16,2">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Name="totalCount" Content="{Binding Total}" FontSize="36" Foreground="{DynamicResource {uit:ColorBrushesKey ResourceKey=DarkBlueBrush}}" HorizontalContentAlignment="Center"/>
                        <Label Grid.Row="1" Content="{Binding [累计任务数],Source={uic:L10N}}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Column="1">
                            <Label VerticalAlignment="Bottom" Content="{Binding ClosedRate}" FontSize="36" Foreground="{DynamicResource {uit:ColorBrushesKey ResourceKey=DarkRedBrush}}"/>
                            <Label VerticalAlignment="Bottom" Margin="0,0,0,5" Content="%" FontSize="18" Foreground="{DynamicResource {uit:ColorBrushesKey ResourceKey=DarkRedBrush}}"/>
                        </StackPanel>
                        <Label HorizontalAlignment="Center" Grid.Column="1" Grid.Row="1" Content="{Binding [任务关闭率],Source={uic:L10N}}"/>
                        <Label Grid.Column="2" Name="closedCount" HorizontalContentAlignment="Center" Content="{Binding Closed}" FontSize="36" Foreground="{DynamicResource {uit:ColorBrushesKey ResourceKey=DarkBlueBrush}}"/>
                        <Label Grid.Column="2" Grid.Row="1" Content="{Binding [已关闭数],Source={uic:L10N}}"/>
                    </Grid>
                    <dxc:ChartControl Name="chart" ToolTipEnabled="True" DataSource="{Binding TaskCategoryStatistics}">
                        <dxc:ChartControl.Legend>
                            <dxc:Legend HorizontalPosition="RightOutside" VerticalPosition="Bottom" BorderThickness="0" Margin="-10,0,0,0"/>
                        </dxc:ChartControl.Legend>
                        <dxc:ChartControl.Diagram>
                            <dxc:SimpleDiagram2D>
                                <dxc:SimpleDiagram2D.Series>
                                    <dxc:PieSeries2D x:Name="Series" HoleRadiusPercent="50" SweepDirection="Clockwise" LegendTextPattern="{}{A}" ArgumentDataMember="Name" ValueDataMember="Qty" Rotation="-90">
                                        <dxc:PieSeries2D.Model>
                                            <dxc:BorderlessFlatPie2DModel/>
                                        </dxc:PieSeries2D.Model>
                                        <dxc:PieSeries2D.PointAnimation>
                                            <dxc:Pie2DFlyInAnimation Duration="0:0:1.5" PointOrder="Random" />
                                        </dxc:PieSeries2D.PointAnimation>
                                        <dxc:PieSeries2D.Label>
                                            <dxc:SeriesLabel dxc:PieSeries.LabelPosition="Inside" Margin="-100,0,0,0"  Visible="True" RenderMode="RectangleConnectedToCenter" TextPattern="{}{VP:P0}"/>
                                        </dxc:PieSeries2D.Label>
                                    </dxc:PieSeries2D>
                                </dxc:SimpleDiagram2D.Series>
                            </dxc:SimpleDiagram2D>
                        </dxc:ChartControl.Diagram>
                        <dxc:ChartControl.Titles>
                            <dxc:Title Dock="Top" HorizontalAlignment="Left" FontSize="12">分类统计</dxc:Title>
                        </dxc:ChartControl.Titles>
                    </dxc:ChartControl>
                </DockPanel>
            </dx:DXTabItem>
            
            <dx:DXTabItem Name="tbCopyTo" Width="{Binding ElementName=tabControl, Path=ActualWidth, Converter={local:TabItemWidthConverterMarkup}}">
                <dx:DXTabItem.Header>
                    <Grid Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=dx:DXTabItem},Path=ActualWidth}">
                        <StackPanel Margin="2" Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding [抄送我],Source={uic:L10N}}" FontSize="17"/>
                            <TextBlock Text="{Binding ElementName=tasksCopyTo, Path=Items.Count, StringFormat=({0})}" FontSize="17"/>
                        </StackPanel>
                    </Grid>
                </dx:DXTabItem.Header>
                <DockPanel>
                    <StackPanel Margin="2" Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Top">
                        <StackPanel.Resources>
                            <dx:ObjectToBooleanConverter x:Key="cv"/>
                        </StackPanel.Resources>
                        <Button Style="{DynamicResource HeaderButton}" Click="TasksCopyToView_Click" IsEnabled="{Binding ElementName=tasksCopyTo, Path=SelectedItem, Converter={StaticResource cv}}">
                            <ui:PackIcon Kind="TextDocument" Width="24" Height="24" Foreground="{DynamicResource ResourceKey={uit:ColorBrushesKey ResourceKey=BlueBrush}}"/>
                        </Button>
                    </StackPanel>
                    <dx:DXListBox Name="tasksCopyTo" Style="{StaticResource ComponentListBoxStyle}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ResourceKey={uit:BrushesThemeKey ResourceKey=BorderBrush}}">
                                        <DockPanel DockPanel.Dock="Top">
                                            <ui:PackIcon Kind="{Binding TypeIcon}" Margin="5" Foreground="#128bef"></ui:PackIcon>
                                            <Label VerticalContentAlignment="Center" FontWeight="Bold" Foreground="{Binding Converter={local:TaskColorConvertMarkup}}">
                                                <TextBlock TextWrapping="Wrap" Text="{Binding Title}"/>
                                            </Label>
                                        </DockPanel>
                                    </Border>
                                    <Grid DockPanel.Dock="Bottom" Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding CreateByName}"/>
                                        <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding PlanEnd, StringFormat='yyyy-MM-dd'}"/>
                                        <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding StatusDisplay}"/>
                                    </Grid>
                                    <Label VerticalContentAlignment="Center" Margin="5">
                                        <TextBlock TextWrapping="Wrap" Text="{Binding Content}"/>
                                    </Label>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </dx:DXListBox>
                </DockPanel>
            </dx:DXTabItem>
        </dx:DXTabControl>
    </dxlc:GroupBox>
</s:ComponentItem>
