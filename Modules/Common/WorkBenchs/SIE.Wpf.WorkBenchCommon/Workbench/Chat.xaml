<s:ComponentItem 
    x:Class="SIE.Wpf.WorkBenchCommon.Workbench.Chat"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:SIE.Wpf.WorkBenchCommon.Workbench"
    xmlns:s="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
    xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
    xmlns:ui="http://schemas.siestudio.com/winfx/xaml/controls"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:icon="http://schemas.siestudio.com/winfx/xaml/controls"
    s:DiagramDesigner.ToolBarTitle="{Binding [消息通讯],Source={uic:L10N}}"
    s:DiagramDesigner.DefaultSize="520,80"
    mc:Ignorable="d" 
    SnapsToDevicePixels="True"
    d:DesignHeight="80" d:DesignWidth="520">
    <s:ComponentItem.ToolbarItem>
        <ui:PackIcon Kind="GlobeWire"/>
    </s:ComponentItem.ToolbarItem>
    <s:ComponentItem.Resources>
        <ResourceDictionary Source="/SIE.Wpf.Common;component/Themes/Generic.xaml" />
    </s:ComponentItem.Resources>
    <Border BorderBrush="{DynamicResource {uit:BrushesThemeKey ResourceKey=BorderBrush}}" BorderThickness="1">
        <DockPanel Name="panel">
            <DockPanel.Resources>
                <Style TargetType="ToggleButton">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ToggleButton">
                                <Grid Background="Transparent">
                                    <ContentPresenter Content="{TemplateBinding Content}"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DockPanel.Resources>
            <Popup Name="popup" Width="{Binding ElementName=panel, Path=ActualWidth}" MinHeight="200" MaxHeight="400" IsOpen="{Binding ElementName=btnChat,Path=IsChecked}" PlacementTarget="{Binding ElementName=panel}" Placement="Top" AllowsTransparency="True" PopupAnimation="Slide">
                <dxlc:GroupBox Background="{DynamicResource {uit:BrushesThemeKey ResourceKey=Background}}">
                    <dxlc:GroupBox.Header>
                        <DockPanel>
                            <Label Height="36" FontSize="18" VerticalContentAlignment="Center">
                                <TextBlock Text="{Binding [消息列表],Source={uic:L10N}}"/>
                            </Label>
                        </DockPanel>
                    </dxlc:GroupBox.Header>
                    <ItemsControl Name="chatListBox" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Background="Transparent">
                                    <Path Margin="5" Data="M0,-3 5,0 10,-3 5,10z" Fill="{DynamicResource ResourceKey={uit:BrushesThemeKey ResourceKey=ListItemBackground}}" HorizontalAlignment="{Binding Path=FromId, Converter={local:ChatHorizontalAlignmentConverter}}" ></Path>
                                    <Border Margin="10,2" Padding="10" CornerRadius="5" Background="{DynamicResource ResourceKey={uit:BrushesThemeKey ResourceKey=ListItemBackground}}" HorizontalAlignment="{Binding Path=FromId, Converter={local:ChatHorizontalAlignmentConverter}}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Label Margin="0,0,10,0" TextBlock.FontWeight="Bold" Content="{Binding FromName}"/>
                                                <Label TextBlock.FontWeight="Bold" Content="{Binding SendDate}" ContentStringFormat="{}{0:HH:mm:ss}"/>
                                            </StackPanel>
                                            <Label Margin="20,0,0,0"  VerticalContentAlignment="Center">
                                                <TextBlock TextWrapping="Wrap" Text="{Binding Content}"/>
                                            </Label>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </dxlc:GroupBox>
            </Popup>
            <Button DockPanel.Dock="Right" Style="{DynamicResource HeaderButton}">
                <ui:PackIcon Kind="Cog" Foreground="{DynamicResource {uit:ColorBrushesKey ResourceKey=BlueBrush}}"/>
            </Button>
            <Border DockPanel.Dock="Right" Width="1" Margin="2,5" BorderBrush="{DynamicResource {uit:BrushesThemeKey ResourceKey=BorderBrush}}" BorderThickness="1"/>
            <Grid>
                <ToggleButton Margin="10,0" Name="btnChat" BorderThickness="0" Padding="0" Background="Transparent" ClickMode="Press" Visibility="{Binding RelativeSource={RelativeSource Mode=Self},Path=IsChecked, Converter={dx:BooleanToVisibilityConverter Invert=True}}">
                    <DockPanel>
                        <ui:PackIcon DockPanel.Dock="Right" Kind="Chat" Foreground="{DynamicResource {uit:ColorBrushesKey ResourceKey=OrangeBrush}}"/>
                        <Label DockPanel.Dock="Left" VerticalContentAlignment="Center" Content="{Binding [~~你有新消息~~],Source={uic:L10N}}" Visibility="{Binding Path=HasNewChat, Converter={dx:BooleanToVisibilityConverter}}"/>
                    </DockPanel>
                </ToggleButton>
                <DockPanel Visibility="{Binding ElementName=btnChat,Path=IsChecked, Converter={dx:BooleanToVisibilityConverter}}" Margin="5">
                    <Button DockPanel.Dock="Right" Margin="5,0" Content="{Binding [发送],Source={uic:L10N}}" Click="SendButton_Click" IsEnabled="{Binding ElementName=txtMsg,Path=Text,Converter={local:HasTextConverter}}"/>
                    <TextBox Name="txtMsg" VerticalContentAlignment="Center" />
                </DockPanel>
            </Grid>
        </DockPanel>
    </Border>
</s:ComponentItem>
