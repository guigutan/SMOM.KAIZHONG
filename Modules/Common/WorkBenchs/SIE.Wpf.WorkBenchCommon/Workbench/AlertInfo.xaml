<s:ComponentItem 
    x:Class="SIE.Wpf.WorkBenchCommon.Workbench.AlertInfo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:SIE.Wpf.WorkBenchCommon.Workbench"
    xmlns:s="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
    xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
    xmlns:ui="http://schemas.siestudio.com/winfx/xaml/controls"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    s:DiagramDesigner.DefaultSize="520,402"
    s:DiagramDesigner.ToolBarTitle="{Binding [预警信息],Source={uic:L10N}}"
    mc:Ignorable="d" 
    SnapsToDevicePixels="True"
    d:DesignHeight="400" d:DesignWidth="520">
    <s:ComponentItem.ToolbarItem>
        <ui:PackIcon Kind="GlobeWire"/>
    </s:ComponentItem.ToolbarItem>
    <s:ComponentItem.Resources>
        <ResourceDictionary Source="/SIE.Wpf.Common;component/Themes/Generic.xaml" />
    </s:ComponentItem.Resources>
    <dxlc:GroupBox Padding="-2">
        <dxlc:GroupBox.Header>
            <DockPanel>
                <Button DockPanel.Dock="Right" Click="refreshButton_Click" Style="{StaticResource HeaderButton}">
                    <ui:PackIcon Kind="Refresh" Width="24" Height="24" Foreground="{DynamicResource ResourceKey={uit:ColorBrushesKey ResourceKey=GreenBrush}}"/>
                </Button>
                <Label Height="36" FontSize="18" VerticalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding [预警信息],Source={uic:L10N}}"/>
                        <TextBlock Text="{Binding ElementName=msgListBox, Path=Items.Count, StringFormat=({0})}"/>
                    </StackPanel>
                </Label>
            </DockPanel>
        </dxlc:GroupBox.Header>
        <dx:DXListBox Name="msgListBox" ScrollViewer.HorizontalScrollBarVisibility="Disabled" dx:ScrollBarExtensions.ScrollBarMode="TouchOverlap" ScrollViewer.VerticalScrollBarVisibility="Auto" HorizontalContentAlignment="Stretch" ItemContainerStyle="{StaticResource ComponentListBoxItemStyle}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <DockPanel Margin="5">
                        <DockPanel DockPanel.Dock="Top">
                            <ui:PackIcon Kind="BellOutline" Foreground="{Binding Converter={local:AlertLevelColorConvertMarkup}}"></ui:PackIcon>
                            <Label VerticalContentAlignment="Center" DockPanel.Dock="Right" ContentStringFormat="{}{0:HH:mm:ss}" Content="{Binding ReceiveDate}"/>
                            <Label VerticalContentAlignment="Center" FontWeight="Bold">
                                <TextBlock TextWrapping="Wrap" Text="{Binding Title}"/>
                            </Label>
                        </DockPanel>
                        <Label VerticalContentAlignment="Center">
                            <TextBlock TextWrapping="Wrap" Text="{Binding Content}"/>
                        </Label>
                    </DockPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </dx:DXListBox>
    </dxlc:GroupBox>
</s:ComponentItem>
