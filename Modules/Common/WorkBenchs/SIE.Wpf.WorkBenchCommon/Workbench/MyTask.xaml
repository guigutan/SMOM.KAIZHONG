<s:ComponentItem 
    x:Class="SIE.Wpf.WorkBenchCommon.Workbench.MyTask"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:SIE.Wpf.WorkBenchCommon.Workbench"
    xmlns:s="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
    xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
    xmlns:ui="http://schemas.siestudio.com/winfx/xaml/controls"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:icon="http://schemas.siestudio.com/winfx/xaml/controls"
    s:DiagramDesigner.ToolBarTitle="{Binding [我的任务],Source={uic:L10N}}"
    s:DiagramDesigner.DefaultSize="520,402"
    mc:Ignorable="d" 
    SnapsToDevicePixels="True"
    d:DesignHeight="400" d:DesignWidth="520">
    <s:ComponentItem.ToolbarItem>
        <ui:PackIcon Kind="GlobeWire"/>
    </s:ComponentItem.ToolbarItem>
    <s:ComponentItem.Resources>
        <ResourceDictionary Source="/SIE.Wpf.Common;component/Themes/Generic.xaml" />
    </s:ComponentItem.Resources>
    <dxlc:GroupBox Padding="-2">
        <dxlc:GroupBox.Header>
            <DockPanel>
                <Button DockPanel.Dock="Right" Click="refreshButton_Click" Style="{StaticResource HeaderButton}">
                    <ui:PackIcon Kind="Refresh" Width="24" Height="24" Foreground="{DynamicResource ResourceKey={uit:ColorBrushesKey ResourceKey=GreenBrush}}"/>
                </Button>
                <Label Height="36" FontSize="18" VerticalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding [我的任务],Source={uic:L10N}}"/>
                        <TextBlock Text="{Binding ElementName=taskListBox, Path=Items.Count, StringFormat=({0})}"/>
                    </StackPanel>
                </Label>
            </DockPanel>
        </dxlc:GroupBox.Header>
        <dx:DXListBox Name="taskListBox" Style="{StaticResource ComponentListBoxStyle}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <DockPanel Margin="5">
                        <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ResourceKey={uit:BrushesThemeKey ResourceKey=BorderBrush}}">
                            <DockPanel DockPanel.Dock="Top">
                                <ui:PackIcon Kind="{Binding TypeIcon}" Margin="5" Foreground="#128bef"></ui:PackIcon>
                                <Label VerticalContentAlignment="Center" FontWeight="Bold" Foreground="{Binding Converter={local:TaskColorConvertMarkup}}">
                                    <TextBlock TextWrapping="Wrap" Text="{Binding Title}"/>
                                </Label>
                            </DockPanel>
                        </Border>
                        <Grid DockPanel.Dock="Bottom" Margin="5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding [状态:],Source={uic:L10N}}" Margin="0,0,5,0"/>
                                <TextBlock HorizontalAlignment="Right" Text="{Binding StatusDisplay}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" >
                                <TextBlock Text="{Binding [期望完成时间:],Source={uic:L10N}}" Margin="0,0,5,0"/>
                                <TextBlock HorizontalAlignment="Right" Text="{Binding PlanEnd, StringFormat='yyyy-MM-dd'}"/>
                            </StackPanel>
                        </Grid>
                        <Label VerticalContentAlignment="Center" Margin="5">
                            <TextBlock TextWrapping="Wrap" Text="{Binding Content}"/>
                        </Label>
                    </DockPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </dx:DXListBox>
    </dxlc:GroupBox>
</s:ComponentItem>
