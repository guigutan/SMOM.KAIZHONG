<s:ComponentItem 
    x:Class="SIE.Wpf.WorkBenchCommon.Workbench.InfoWidgets"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:SIE.Wpf.WorkBenchCommon.Workbench"
    xmlns:s="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
    xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
    xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
    xmlns:ui="http://schemas.siestudio.com/winfx/xaml/controls"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    s:DiagramDesigner.ToolBarTitle="{Binding [信息小部件],Source={uic:L10N}}"
    mc:Ignorable="d" 
    SnapsToDevicePixels="True"
    s:DiagramDesigner.DefaultSize="520,80"
    d:DesignHeight="80" d:DesignWidth="520">
    <s:ComponentItem.ToolbarItem>
        <ui:PackIcon Kind="GlobeWire"/>
    </s:ComponentItem.ToolbarItem>
    <s:ComponentItem.Resources>
        <ResourceDictionary Source="/SIE.Wpf.Common;component/Themes/Generic.xaml" />
    </s:ComponentItem.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.Resources>
            <Style TargetType="ui:PackIcon" x:Key="icon">
                <Setter Property="MaxHeight" Value="32"></Setter>
                <Setter Property="Foreground" Value="#128bef"></Setter>
                <Setter Property="HorizontalAlignment" Value="Center"></Setter>
                <Setter Property="VerticalAlignment" Value="Bottom"></Setter>
                <Setter Property="Width" Value="NaN"></Setter>
                <Setter Property="Height" Value="NaN"></Setter>
            </Style>
            <Style TargetType="Border" x:Key="spliter">
                <Setter Property="BorderBrush" Value="Gray"></Setter>
                <Setter Property="BorderThickness" Value="1"></Setter>
                <Setter Property="Width" Value="2"></Setter>
                <Setter Property="Margin" Value="0,10"></Setter>
            </Style>
            <Style TargetType="TextBlock" x:Key="counter">
                <Setter Property="VerticalAlignment" Value="Top"></Setter>
                <Setter Property="HorizontalAlignment" Value="Left"></Setter>
                <Setter Property="MinHeight" Value="16"></Setter>
                <Setter Property="Foreground" Value="Red"></Setter>
                <Setter Property="Margin" Value="0,8"></Setter>
            </Style>
            <Style TargetType="Label" x:Key="label">
                <Setter Property="HorizontalAlignment" Value="Center"></Setter>
                <Setter Property="FontSize" Value="14"></Setter>
                <Setter Property="Padding" Value="0"></Setter>
                <Setter Property="VerticalAlignment" Value="Top"></Setter>
            </Style>
            <Style TargetType="Grid" x:Key="grid">
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="Width" Value="{Binding  RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Button}, Path=ActualWidth}"></Setter>
                <Setter Property="Height" Value="{Binding  RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Button}, Path=ActualHeight}"></Setter>
            </Style>
            <Style TargetType="dx:DropDownButton">
                <Style.Setters>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="PopupAutoWidth" Value="False"/>
                    <Setter Property="PopupMaxWidth" Value="520"/>
                    <Setter Property="PopupMinWidth" Value="300"/>
                    <Setter Property="ArrowGlyph">
                        <Setter.Value>
                            <DrawingImage/>
                        </Setter.Value>
                    </Setter>
                </Style.Setters>
            </Style>
        </Grid.Resources>
        <dx:DropDownButton Click="Button_Click">
            <dx:DropDownButton.Content>
                <Grid Style="{StaticResource grid}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="26"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Column="2" Grid.RowSpan="2" Text="{Binding ElementName=msgListBox,Path=Items.Count}" Style="{StaticResource counter}"/>
                    <ui:PackIcon Grid.Column="1" Grid.Row="0" Kind="EarlyWarning" Style="{StaticResource icon}"/>
                    <Label Grid.Column="1" Grid.Row="1" Content="{Binding [预警], Source={uic:L10N}}" Style="{StaticResource label}"></Label>
                </Grid>
            </dx:DropDownButton.Content>
            <dx:DropDownButton.PopupContent>
                <dx:DXListBox Name="msgListBox" Style="{StaticResource ComponentListBoxStyle}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="5">
                                <DockPanel DockPanel.Dock="Top">
                                    <ui:PackIcon Kind="BellOutline" Margin="0,0,5,0" Foreground="{Binding Converter={local:AlertLevelColorConvertMarkup}}"></ui:PackIcon>
                                    <Label VerticalContentAlignment="Center" DockPanel.Dock="Right" ContentStringFormat="{}{0:HH:mm:ss}" Content="{Binding ReceiveDate}"/>
                                    <Label VerticalContentAlignment="Center" FontWeight="Bold">
                                        <TextBlock TextWrapping="Wrap" Text="{Binding Title}"/>
                                    </Label>
                                </DockPanel>
                                <Label VerticalContentAlignment="Center">
                                    <TextBlock TextWrapping="Wrap" Text="{Binding Content}"/>
                                </Label>
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </dx:DXListBox>
            </dx:DropDownButton.PopupContent>
        </dx:DropDownButton>
        <Border Grid.Column="1" Style="{StaticResource spliter}"/>
        <dx:DropDownButton Grid.Column="2" Click="Button_Click">
            <dx:DropDownButton.Content>
                <Grid Style="{StaticResource grid}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="26"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Column="2" Grid.RowSpan="2" Text="{Binding ElementName=announcementListBox,Path=Items.Count}" Style="{StaticResource counter}"/>
                    <ui:PackIcon Grid.Column="1" Grid.Row="0" Kind="Notice" Style="{StaticResource icon}"/>
                    <Label Grid.Column="1" Grid.Row="1" Content="{Binding [公告], Source={uic:L10N}}" Style="{StaticResource label}"></Label>
                </Grid>
            </dx:DropDownButton.Content>
            <dx:DXListBox Name="announcementListBox" Style="{StaticResource ComponentListBoxStyle}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <DockPanel Margin="5">
                            <DockPanel DockPanel.Dock="Top">
                                <ui:PackIcon Kind="Horn" Margin="0,0,5,0" Foreground="{DynamicResource ResourceKey={uit:ColorBrushesKey ResourceKey=GreenBrush}}"></ui:PackIcon>
                                <Label VerticalContentAlignment="Center" DockPanel.Dock="Right" ContentStringFormat="{}{0:HH:mm:ss}" Content="{Binding  PublishDate}"/>
                                <Label VerticalContentAlignment="Center" FontWeight="Bold">
                                    <TextBlock TextWrapping="Wrap" Text="{Binding Subject}"/>
                                </Label>
                            </DockPanel>
                            <Label VerticalContentAlignment="Center">
                                <TextBlock TextWrapping="Wrap" Text="{Binding Content}"/>
                            </Label>
                        </DockPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </dx:DXListBox>
        </dx:DropDownButton>
        <Border Grid.Column="3" Style="{StaticResource spliter}"/>
        <dx:DropDownButton Grid.Column="4" Click="Button_Click">
            <dx:DropDownButton.Content>
                <Grid Style="{StaticResource grid}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="26"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Column="2" Grid.RowSpan="2" Text="{Binding ElementName=concernsListBox,Path=Items.Count}" Style="{StaticResource counter}"/>
                    <ui:PackIcon Grid.Column="1" Grid.Row="0" Kind="Follow" Style="{StaticResource icon}"/>
                    <Label Grid.Column="1" Grid.Row="1" Content="{Binding [关注], Source={uic:L10N}}" Style="{StaticResource label}"></Label>
                </Grid>
            </dx:DropDownButton.Content>
            <dx:DXListBox Name="concernsListBox" Style="{StaticResource ComponentListBoxStyle}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <DockPanel Margin="5">
                            <DockPanel DockPanel.Dock="Top">
                                <ui:PackIcon Kind="Star" Margin="0,0,5,0" Foreground="{DynamicResource {uit:ColorBrushesKey ResourceKey=BlueBrush}}"></ui:PackIcon>
                                <Label VerticalContentAlignment="Center" FontWeight="Bold">
                                    <TextBlock TextWrapping="Wrap" Text="{Binding Name}"/>
                                </Label>
                            </DockPanel>
                        </DockPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </dx:DXListBox>
        </dx:DropDownButton>
    </Grid>
</s:ComponentItem>
