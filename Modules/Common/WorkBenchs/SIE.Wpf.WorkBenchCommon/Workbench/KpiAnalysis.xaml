<s:ComponentItem 
    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"  
    x:Class="SIE.Wpf.WorkBenchCommon.Workbench.KpiAnalysis"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:SIE.Wpf.WorkBenchCommon.Workbench"
    xmlns:icon="clr-namespace:Resources.IconPacks;assembly=Resources"
    xmlns:s="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
    xmlns:ui="http://schemas.siestudio.com/winfx/xaml/controls"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    s:DiagramDesigner.ToolBarTitle="{Binding [当月绩效分析],Source={uic:L10N}}"
    s:DiagramDesigner.DefaultSize="520,402"
    mc:Ignorable="d" 
    SnapsToDevicePixels="True"
    d:DesignHeight="402" d:DesignWidth="520">
    <s:ComponentItem.ToolbarItem>
        <ui:PackIcon Kind="GlobeWire"/>
    </s:ComponentItem.ToolbarItem>
    <dxlc:GroupBox Padding="-2">
        <dxlc:GroupBox.Header>
            <DockPanel>
                <Button DockPanel.Dock="Right" Name="btnSetting" Click="btnSetting_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Foreground="Gray"  Background="Transparent">
                    <Button.Content>
                        <icon:PackIcon Kind="SoftwareSetting" Background="Transparent"></icon:PackIcon>
                    </Button.Content>
                </Button>
                <Label DockPanel.Dock="Left" Height="36" FontSize="18" Content="{Binding [当月绩效分析],Source={uic:L10N}}" VerticalContentAlignment="Center"/>                
            </DockPanel>
        </dxlc:GroupBox.Header>
        <dxg:GridControl Name="grid" SelectionMode="Cell" MaxHeight="1000" dx:ScrollBarExtensions.ScrollBarMode="TouchOverlap">
            <dxg:GridControl.Columns>
                <dxg:GridColumn Width="2*" Header="{Binding [KPI],Source={uic:L10N}}" FieldName="Name"></dxg:GridColumn>
                <dxg:GridColumn Width="*" Header="{Binding [目标],Source={uic:L10N}}" FieldName="GoalFormat"></dxg:GridColumn>
                <dxg:GridColumn Width="*" Header="{Binding [实际达成],Source={uic:L10N}}" FieldName="ActualFormat"></dxg:GridColumn>
                <dxg:GridColumn Width="*" Header="{Binding [预警标识],Source={uic:L10N}}" FieldName="Grade">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="20" Height="20" Fill="{Binding RowData.Row, Converter={local:KipGradeColorConverterMarkup}}"></Ellipse>
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
            </dxg:GridControl.Columns>
            <dxg:GridControl.View>
                <dxg:TableView  ShowGroupPanel="False" AllowColumnMoving="False" AllowColumnFiltering="False" AllowSorting="False" ShowIndicator="False" ShowVerticalLines="False" RowMinHeight="46" ShowSearchPanelMode="Never" IsRowCellMenuEnabled="False" FontSize="16" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <dxg:TableView.ColumnHeaderContentStyle>
                        <Style TargetType="ContentControl">
                            <Setter Property="FontSize" Value="18"/>
                        </Style>
                    </dxg:TableView.ColumnHeaderContentStyle>
                </dxg:TableView>
            </dxg:GridControl.View>
        </dxg:GridControl>
    </dxlc:GroupBox>
</s:ComponentItem>
