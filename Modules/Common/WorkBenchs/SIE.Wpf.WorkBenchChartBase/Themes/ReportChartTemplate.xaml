<Grid x:Class="SIE.Wpf.WorkBenchChartBase.Commons.ReportChartTemplate"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.WorkBenchChartBase.Commons"
             mc:Ignorable="d" 
            xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
            xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
             d:DesignHeight="300" d:DesignWidth="300">
    <dxc:ChartControl Background="{x:Null}" DataSource="{Binding ChartDataSource}" Name="chart">
        <dxc:ChartControl.Diagram>
            <dxc:XYDiagram2D Name="diagram">
                <dxc:XYDiagram2D.DefaultPane>
                    <dxc:Pane DomainBrush="{x:Null}" BorderThickness="0" BorderBrush="{x:Null}" DomainBorderBrush="{x:Null}" />
                </dxc:XYDiagram2D.DefaultPane>
                <dxc:XYDiagram2D.Series>
                    <dxc:LineSeries2D>
                        <dxc:LineSeries2D.Label>
                            <dxc:SeriesLabel Name="seriesLabel" >
                                <dxc:SeriesLabel.ElementTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" Opacity="0.75" CornerRadius="2" Padding="0,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Path=Text}" Foreground="{DynamicResource {uit:BrushesThemeKey ResourceKey=Foreground}}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </dxc:SeriesLabel.ElementTemplate>
                            </dxc:SeriesLabel> 
                        </dxc:LineSeries2D.Label>
                    </dxc:LineSeries2D>
                    <dxc:LineSeries2D>
                        <dxc:LineSeries2D.Label>
                            <dxc:SeriesLabel Name="seriesLabel2" >
                                <dxc:SeriesLabel.ElementTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" Opacity="0.75" CornerRadius="2" Padding="0,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Path=Text}" Foreground="White"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </dxc:SeriesLabel.ElementTemplate>
                            </dxc:SeriesLabel>
                        </dxc:LineSeries2D.Label>
                    </dxc:LineSeries2D>
                    <!--SeriesLabel无底-->
                    <dxc:LineSeries2D>
                        <dxc:LineSeries2D.Label>
                            <dxc:SeriesLabel Name="seriesLabel3" >
                                <dxc:SeriesLabel.ElementTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" VerticalAlignment="Bottom"  Opacity="0.75" CornerRadius="2" Padding="0,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Path=Text}" Foreground="Black"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </dxc:SeriesLabel.ElementTemplate>
                            </dxc:SeriesLabel>
                        </dxc:LineSeries2D.Label>
                    </dxc:LineSeries2D>
                    <!--柱状图圆角模板-->
                    <dxc:BarSideBySideSeries2D Name="barSideBySideSeries2D">
                        <dxc:BarSideBySideSeries2D.Model>
                            <dxc:CustomBar2DModel >
                                <dxc:CustomBar2DModel.PointTemplate>
                                    <ControlTemplate>
                                        <Grid Name="grid">
                                            <Border  Background="#21A7F3" CornerRadius="{Binding ElementName=grid,Path=ActualWidth, Converter={local:RadiusConverter}, Mode=OneWay}" Name="border" Margin="1.5,0,1.5,0" >
                                             
                                            </Border>
                                        </Grid>
                                    </ControlTemplate>
                                </dxc:CustomBar2DModel.PointTemplate>
                            </dxc:CustomBar2DModel>
                        </dxc:BarSideBySideSeries2D.Model>
                    </dxc:BarSideBySideSeries2D>
              
                </dxc:XYDiagram2D.Series>
            </dxc:XYDiagram2D>
        </dxc:ChartControl.Diagram>
    </dxc:ChartControl>
</Grid>
