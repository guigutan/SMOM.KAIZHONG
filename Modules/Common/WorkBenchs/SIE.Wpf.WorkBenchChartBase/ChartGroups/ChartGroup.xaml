<diagram:ComponentItem 
    x:Class="SIE.Wpf.WorkBenchChartBase.ChartGroups.ChartGroup"    
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:SIE.Wpf.WorkBenchChartBase.ChartGroups"
    xmlns:diagram="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
    xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
    xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
    xmlns:ui="http://schemas.siestudio.com/winfx/xaml/controls"
    diagram:DiagramDesigner.ToolBarTitle="{Binding [图表容器],Source={uic:L10N}}"
    diagram:DiagramDesigner.DefaultSize="1370,350"
    mc:Ignorable="d" 
    d:DesignHeight="350" d:DesignWidth="1370">
    <diagram:ComponentItem.Resources>
        <ResourceDictionary Source="/SIE.Wpf.Common;component/Themes/Generic.xaml" />
    </diagram:ComponentItem.Resources>
    <dxlc:GroupBox Padding="-2">
        <dxlc:GroupBox.Header>
            <DockPanel>
                <Button DockPanel.Dock="Right" Command="{Binding MoreCommand}" Style="{StaticResource HeaderButton}">
                    <Label Content="{Binding [更多],Source={uic:L10N}}" VerticalAlignment="Center"></Label>
                </Button>
                <Label Height="36" FontSize="18" VerticalContentAlignment="Center">
                    <TextBlock Name="lblTitle" Text="{Binding [图表容器],Source={uic:L10N}}"/>
                </Label>
            </DockPanel>
        </dxlc:GroupBox.Header>
        <Grid>
            <Grid.Resources>
                <Style TargetType="Border" x:Key="chartBorder">
                    <Setter Property="CornerRadius" Value="5"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource {uit:BrushesThemeKey ResourceKey=BorderBrush}}"/>
                </Style>
                <Style TargetType="Button" x:Key="navButton">
                    <Setter Property="Opacity" Value="0.5"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Height" Value="80"/>
                    <Setter Property="Width" Value="10"/>
                    <Setter Property="Padding" Value="0"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter Property="Opacity" Value="1"/>
                            <Setter Property="Width" Value="50"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Grid.Resources>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource chartBorder}" Margin="10,10,5,10">
                <ContentControl Content="{Binding Chart1}"/>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource chartBorder}" Margin="5,10,5,10">
                <ContentControl Content="{Binding Chart2}"/>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource chartBorder}" Margin="5,10,10,10">
                <ContentControl Content="{Binding Chart3}"/>
            </Border>
            <Button HorizontalAlignment="Left" Command="{Binding PrevCommand}" Style="{StaticResource navButton}">
                <Grid>
                    <Path HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,5 10,0 10,10z" Fill="{DynamicResource {uit:BrushesThemeKey ResourceKey=Foreground}}"/>
                </Grid>
            </Button>
            <Button Grid.Column="2" HorizontalAlignment="Right" Command="{Binding NextCommand}" Style="{StaticResource navButton}">
                <Grid>
                    <Path HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 10,5 0,10z" Fill="{DynamicResource {uit:BrushesThemeKey ResourceKey=Foreground}}"/>
                </Grid></Button>
        </Grid>
    </dxlc:GroupBox>
</diagram:ComponentItem>
