<UserControl 
    x:Class="SIE.Wpf.WorkBenchChartBase.ChartGroups.ChartInfo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:SIE.Wpf.WorkBenchChartBase.ChartGroups"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
    xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
    xmlns:ui="http://schemas.siestudio.com/winfx/xaml/controls"
    mc:Ignorable="d" 
    d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel IsItemsHost="True" Margin="0,0,0,0"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ToggleButton IsChecked="{Binding IsSelected}" Margin="5">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="border" BorderThickness="1" BorderBrush="{DynamicResource {uit:BrushesThemeKey ResourceKey=BorderBrush}}">
                                    <ContentPresenter Content="{TemplateBinding Content}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="true">
                                        <Trigger.Setters>
                                            <Setter TargetName="border" Property="Background" Value="{DynamicResource {uit:BrushesThemeKey ResourceKey=SelectedBackground}}"/>
                                        </Trigger.Setters>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                        <StackPanel Background="Transparent">
                            <dxe:CheckEdit IsChecked="{Binding IsSelected}" Content="{Binding Definition.Title}" FontSize="18" VerticalAlignment="Center"  HorizontalAlignment="Left" Margin="5"/>
                            <Grid Width="300" Height="200">
                                <ui:PackIcon Kind="{Binding Icon}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="20" Width="80" Height="80" Visibility="{Binding Definition.Url, Converter={local:VisibleConverter Invert=True}}"  Foreground="{DynamicResource {uit:ColorBrushesKey ResourceKey=DarkBlueBrush}}"/>
                                <dxe:ImageEdit Name="simpleImage" Visibility="{Binding Definition.Url, Converter={local:VisibleConverter}}" Source="{Binding Definition.Url}" Margin="5" IsReadOnly="True"/>
                            </Grid>
                        </StackPanel>
                    </ToggleButton>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
