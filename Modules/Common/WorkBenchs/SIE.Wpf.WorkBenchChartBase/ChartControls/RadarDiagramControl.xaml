<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SIE.Wpf.WorkBenchChartBase.Commons;assembly=SIE.Wpf.WorkBenchChartBase"
      xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
      xmlns:uit="http://schemas.siestudio.com/winfx/xaml/themes"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800">
    <local:ChartHeaderControl x:Name="header" Background="{DynamicResource {uit:BrushesThemeKey ResourceKey=Background}}">
        <dxc:ChartControl DataSource="{Binding ChartDataSource}">
            <dxc:ChartControl.Diagram>
                <dxc:RadarDiagram2D Background="{x:Null}" DomainBrush="{x:Null}" BorderThickness="0" BorderBrush="{x:Null}" DomainBorderBrush="{x:Null}">
                </dxc:RadarDiagram2D>
            </dxc:ChartControl.Diagram>
        </dxc:ChartControl>
    </local:ChartHeaderControl>
</Grid>