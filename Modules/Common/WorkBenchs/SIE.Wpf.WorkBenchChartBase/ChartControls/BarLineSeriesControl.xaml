<sd:ComponentItem xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:sd="clr-namespace:SIE.Wpf.Common.Diagram;assembly=SIE.Wpf.Common"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                  xmlns:local="clr-namespace:SIE.Wpf.WorkBenchChartBase.Commons;assembly=SIE.Wpf.WorkBenchChartBase"             
                  xmlns:dxpg="http://schemas.devexpress.com/winfx/2008/xaml/pivotgrid"
                  xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                  xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
                  xmlns:dxdb="http://schemas.devexpress.com/winfx/2008/xaml/demobase"
                  xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
                  xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                  xmlns:icon="http://schemas.siestudio.com/winfx/xaml/controls"
                  xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core" 
                  mc:Ignorable="d" 
                  sd:DiagramDesigner.DefaultSize="443,358"
                  d:DesignHeight="358" d:DesignWidth="443" DataContext="{Binding RelativeSource={RelativeSource Self}}">
    <sd:ComponentItem.Resources>
        <ResourceDictionary>
            <dxc:BrushOverlayConverter x:Key="brushOverlayConverter" />
        </ResourceDictionary>
    </sd:ComponentItem.Resources>
    <Border BorderThickness="0.5" BorderBrush="Transparent" Padding="5" CornerRadius="5" Margin="5">
        <dxc:ChartControl x:Name="chartControl">
            <dxc:ChartControl.Palette>
                <dxc:ChameleonPalette/>
            </dxc:ChartControl.Palette>
            <dxc:ChartControl.Legend>
                <dxc:Legend Background="{x:Null}" HorizontalPosition="Center" VerticalPosition="BottomOutside" 
                                        Orientation="Horizontal" FontSize="12" Margin="0" Padding="0" BorderThickness="0">
                    <dxc:Legend.CustomItems>
                        <dxc:CustomLegendItem Name="LegendBatch"  Text="{Binding [不良批次数],Source={uic:L10N}}" MarkerBrush ="#128BEF"/>
                        <dxc:CustomLegendItem Name="LegendPercenta"  Text="{Binding [占比],Source={uic:L10N}}"  MarkerBrush ="#FFA500"/>
                    </dxc:Legend.CustomItems>
                </dxc:Legend>
            </dxc:ChartControl.Legend>
            <dxc:XYDiagram2D x:Name="diagram" Rotated="False" EnableAxisXNavigation="False" EnableAxisYNavigation="False">

                <dxc:XYDiagram2D.AxisY>
                    <!--<dxc:AxisY2D x:Name="_AxisY" GridLinesVisible="False" Interlaced="False">-->
                    <dxc:AxisY2D x:Name="_AxisY" Interlaced="False">
                        <dxc:AxisY2D.Label>
                            <dxc:AxisLabel Background="Transparent" BorderBrush="#FF343246" Padding="0,1"  FontSize="12"/>
                        </dxc:AxisY2D.Label>
                    </dxc:AxisY2D>
                </dxc:XYDiagram2D.AxisY>
                <dxc:XYDiagram2D.SecondaryAxesY>
                    <!-- 第二Y轴设置 -->
                    <dxc:SecondaryAxisY2D x:Name="_SecondaryAxisY2D">
                        <dxc:AxisY2D.Label>
                            <dxc:AxisLabel Background="Transparent" FontSize="12" TextPattern="{}{V}%"/>
                            <!-- Y轴标签改为百分比格式 -->
                        </dxc:AxisY2D.Label>
                    </dxc:SecondaryAxisY2D>
                </dxc:XYDiagram2D.SecondaryAxesY>

                <dxc:XYDiagram2D.AxisX>
                    <!-- X轴设置 -->
                    <dxc:AxisX2D TickmarksVisible="True" TickmarksMinorVisible="False">
                        <dxc:AxisX2D.QualitativeScaleOptions>
                            <dxc:QualitativeScaleOptions AutoGrid="False"></dxc:QualitativeScaleOptions>
                        </dxc:AxisX2D.QualitativeScaleOptions>
                        <dxc:AxisX2D.Label>
                            <dxc:AxisLabel Background="Transparent" BorderBrush="#FF343246" Padding="0,1" TextPattern="{}{A}" Angle="-45" >
                                <dxc:AxisLabel.ElementTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" Opacity="0.75" CornerRadius="2" MaxWidth="100">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Path=Value}" Foreground="Black" FontSize="12"></TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </dxc:AxisLabel.ElementTemplate>
                                <dxc:Axis2D.ResolveOverlappingOptions>
                                    <dxc:AxisLabelResolveOverlappingOptions AllowHide="False" AllowRotate="False" AllowStagger="True" MinIndent="5" />
                                </dxc:Axis2D.ResolveOverlappingOptions>
                            </dxc:AxisLabel>
                        </dxc:AxisX2D.Label>
                    </dxc:AxisX2D>
                </dxc:XYDiagram2D.AxisX>

                <dxc:BarSideBySideSeries2D Brush="#128BEF" Name="BarSeries"  DisplayName="不良批次数">
                    <dxc:BarSideBySideSeries2D.Model>
                        <dxc:CustomBar2DModel>
                            <dxc:CustomBar2DModel.PointTemplate>
                                <ControlTemplate>
                                    <Grid Name="BarGrid" MaxWidth="25">
                                        <Border Background="{Binding Path=PointColor, ConverterParameter=Gray, Converter={StaticResource brushOverlayConverter}}" 
                                                        CornerRadius="{Binding ElementName=BarGrid,Path=ActualWidth, Converter={local:RadiusConverter}, Mode=OneWay}" Margin="4,0,4,0">
                                            <Border CornerRadius="{Binding ElementName=BarGrid,Path=ActualWidth, Converter={local:RadiusConverter}, Mode=OneWay}" Margin="1,1,1,0">
                                                <Border.Background>
                                                    <Binding Path="PointColor" Converter="{StaticResource brushOverlayConverter}">
                                                        <Binding.ConverterParameter>
                                                            <LinearGradientBrush EndPoint="0,0.5" StartPoint="1,0.5">
                                                                <GradientStop Color="#FFB2B2B2" Offset="0" />
                                                                <GradientStop Color="#FFC2C2C2" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Binding.ConverterParameter>
                                                    </Binding>
                                                </Border.Background>
                                            </Border>
                                        </Border>
                                    </Grid>
                                </ControlTemplate>
                            </dxc:CustomBar2DModel.PointTemplate>
                        </dxc:CustomBar2DModel>
                    </dxc:BarSideBySideSeries2D.Model>
                </dxc:BarSideBySideSeries2D>

                <dxc:LineSeries2D Brush="#FFA500" Name="LineSeries" DisplayName="占比"  LabelsVisibility="True" MarkerSize="12" MarkerVisible="True" dxc:XYDiagram2D.SeriesAxisY="{Binding ElementName=_SecondaryAxisY2D}">
                    <dxc:LineSeries2D.MarkerModel>
                        <dxc:CircleMarker2DModel />
                    </dxc:LineSeries2D.MarkerModel>
                    <dxc:LineSeries2D.Label>
                        <dxc:SeriesLabel
                                                Background="Transparent"
                                                Opacity="0.75"
                                                ConnectorVisible="False"
                                                ResolveOverlappingMode="Default"
                                                Indent="20"
                                                Visible="True"
                                                dxc:MarkerSeries2D.Angle="90"
                                                TextPattern="{}{V}%" >
                            <dxc:SeriesLabel.ElementTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent" Opacity="0.75" CornerRadius="2" Padding="8,2,8,2">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Path=Text}" Foreground="Black"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </dxc:SeriesLabel.ElementTemplate>
                        </dxc:SeriesLabel>
                    </dxc:LineSeries2D.Label>
                </dxc:LineSeries2D>
            </dxc:XYDiagram2D>
        </dxc:ChartControl>
    </Border>
</sd:ComponentItem>