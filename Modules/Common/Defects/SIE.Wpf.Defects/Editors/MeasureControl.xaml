<UserControl xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"  
             xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"  
             x:Class="SIE.Wpf.Defects.Editors.MeasureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SIE.Wpf.Defects.Editors"
             xmlns:uic="http://schemas.siestudio.com/winfx/xaml/core"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <dxdo:LayoutGroup Caption="{Binding [维修措施],Source={uic:L10N}}" DockPanel.Dock="Left" ShowCaption="True" GroupBorderStyle="GroupBox" AllowExpand="False" ItemWidth="280" Orientation="Vertical" Margin="5,5,0,5" ItemHeight="auto" MaxWidth="280">
            <dxdo:LayoutControlItem ShowCaption="False">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <ItemsControl Name="ctlMeasure">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ToggleButton Margin="5" Width="100" Height="40"  x:Name="btnMeasure" Click="BtnMeasure_Click" Content="{Binding Measure.Name}" ToolTip="{Binding Measure.Name}" Tag="{Binding Measure}" IsChecked="{Binding IsChecked}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel IsItemsHost="True"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>
            </dxdo:LayoutControlItem>
        </dxdo:LayoutGroup> 
    </Grid>
</UserControl>
