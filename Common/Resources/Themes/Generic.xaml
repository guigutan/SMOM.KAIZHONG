<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Resources.IconPacks">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Resources;component/Themes/IconPacks.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="{x:Type local:PackIcon}" BasedOn="{StaticResource Res.Styles.PackIcon}" />

</ResourceDictionary>
