<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SIE.CrossPlatform.Collect.Common.Forms.XPFormChangeInvOrg"
		 xmlns:ctl="using:SIE.CrossPlatform.Collect.Common.Controls"
        Title="切换工作单元" Width="600" Height="450">
	<Border BorderThickness="1" BorderBrush="{DynamicResource SIEWindowDialogBorderColor}"
			BoxShadow="0 0 10 4 #ccc" CornerRadius="3">
		<Grid  ShowGridLines="False">
			<Grid.RowDefinitions>
				<RowDefinition Height="60"></RowDefinition>
				<RowDefinition Height="*"></RowDefinition>
			</Grid.RowDefinitions>
			<ctl:XPDialogTitle Grid.Row="0"  VerticalContentAlignment="Stretch" x:Name="XPDialogTitle"/>
			<ListBox  Grid.Row="1"  x:Name="xpListBox1"></ListBox>
		</Grid>
	</Border>
</Window>
