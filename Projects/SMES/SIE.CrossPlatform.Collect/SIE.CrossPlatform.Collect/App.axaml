<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SIE.CrossPlatform.Collect.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <FluentTheme />
		<Style Selector="ListBoxItem">
			<Setter Property="Height" Value="48"></Setter>
			<Setter  Property="VerticalContentAlignment" Value="Center"></Setter>
		</Style>
		<Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
			<Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}" />
		</Style>

		<!--  Pressed State  -->
		<Style Selector="ListBoxItem:pressed /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource SystemControlHighlightListMediumBrush}" />
			<Setter Property="Foreground" Value="{DynamicResource SIEListBoxSelectedForegroundColor}" />
		</Style>

		<!--  Selected State  -->
		<Style Selector="ListBoxItem:selected">

			<Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
				<Setter Property="Background" Value="{DynamicResource SIEListBoxSelectedBackgroundColor}" />
				<Setter Property="Foreground" Value="{DynamicResource SIEListBoxSelectedForegroundColor}" />
			</Style>

			<!--  Selected Unfocused State  -->
			<Style Selector="^:not(:focus) /template/ ContentPresenter#PART_ContentPresenter">
				<Setter Property="Background" Value="{DynamicResource SIEListBoxSelectedBackgroundColor}" />
				<Setter Property="Foreground" Value="{DynamicResource SIEListBoxSelectedForegroundColor}" />
			</Style>

			<!--  Selected PointerOver State  -->
			<Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
				<Setter Property="Background" Value="{DynamicResource SIEListBoxSelectedBackgroundColor}" />
				<Setter Property="Foreground" Value="{DynamicResource SIEListBoxSelectedForegroundColor}" />
			</Style>

			<!--  Selected Pressed State  -->
			<Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
				<Setter Property="Background" Value="{DynamicResource SIEListBoxSelectedBackgroundColor}" />
				<Setter Property="Foreground" Value="{DynamicResource SIEListBoxSelectedForegroundColor}" />
			</Style>
		</Style>
    </Application.Styles>
	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceInclude Source="avares://LoadingIndicators.Avalonia/LoadingIndicators.axaml" />
			</ResourceDictionary.MergedDictionaries>
			<Color x:Key="SIEListBoxSelectedBackgroundColor">#b0293c</Color>
			<Color x:Key="SIEListBoxSelectedForegroundColor">#FFFFFF</Color>
			<Color x:Key="SIEWindowDialogBorderColor">#A9A9A9</Color>
		</ResourceDictionary>
	</Application.Resources>
</Application>