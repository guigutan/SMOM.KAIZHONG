<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SIE.CrossPlatform.Collect.MoveWindow"
	    xmlns:ctl="using:SIE.CrossPlatform.Collect.Common.Controls"
        Title=""  Loaded="Window_Loaded">
	<Grid >
		<Grid.RowDefinitions>
			<RowDefinition Height="88"></RowDefinition>
			<RowDefinition Height="1*"></RowDefinition>
			<RowDefinition Height="1*"></RowDefinition>
		</Grid.RowDefinitions>
		<ctl:XPTitle x:Name="xpTitle" Grid.Row="0"></ctl:XPTitle>
	</Grid>
</Window>
